# Example environment file. Copy to `.env` for local development — never
# commit real secrets. Production values live in the deploy target's own
# systemd unit / compose file / secrets manager.

# ── ach-server (Rust backend at server/) ───────────────────────────────

# Port the Axum server binds to. ach-server bindea a 127.0.0.1 siempre;
# nginx / Cloudflare / the container network fronts the public domain.
ACH_PORT=3100

# Exact origin allowed by CORS. No wildcards. For local Astro dev, this is
# the Vite/Astro dev server (default 4321). In production, it's the
# public domain.
ACH_CORS_ORIGIN=http://localhost:4321

# tracing-subscriber filter. `ach_server=info` covers the server's own
# logs; bump to `debug` for verbose tower/axum traces.
RUST_LOG=ach_server=info

# ── Container image tag (docker-compose only) ──────────────────────────

# Override when pinning to a specific published image in prod.
# ACH_SERVER_TAG=2026-04-16-a1b2c3d
