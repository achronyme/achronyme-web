---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const r = t(locale).roadmap;
---

<div class="mx-auto max-w-[1400px] border-x border-t border-subtle/77 relative">
  <!-- Top corner dots — preserve workspace identity -->
  <div class="grid-dot absolute -top-[3px] -left-[3px] z-10"></div>
  <div class="grid-dot absolute -top-[3px] -right-[3px] z-10"></div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- HERO + METRIC STRIP                                         -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="border-b border-subtle/77 px-6 sm:px-8 lg:px-16 py-14 lg:py-20 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>

    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/[0.04] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-text-secondary">
        <span class="h-1.5 w-1.5 rounded-full bg-proof animate-pulse"></span>
        {r.livingPill}
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight">{r.title}</h1>
      <p class="mt-4 text-text-secondary text-lg max-w-2xl leading-relaxed">{r.subtitle}</p>
    </div>

    <!-- 5 Double-Bezel metric mini-cards — receipts up front -->
    <div class="reveal mt-10 lg:mt-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
      <div class="rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
        <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] py-4 px-4 text-center">
          <span class="block text-xl sm:text-2xl font-bold tracking-tight text-text-primary">{r.metrics.startedValue}</span>
          <span class="mt-1 block text-[10px] text-text-muted uppercase tracking-[0.2em]">{r.metrics.started}</span>
        </div>
      </div>
      <div class="rounded-2xl bg-proof/[0.05] ring-1 ring-proof/15 p-1.5">
        <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-proof/15 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] py-4 px-4 text-center">
          <span class="block text-base sm:text-lg font-bold font-mono tracking-tight text-proof-light">v0.1.0-beta.19</span>
          <span class="mt-1 block text-[10px] text-text-muted uppercase tracking-[0.2em]">{r.metrics.version}</span>
        </div>
      </div>
      <div class="rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
        <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] py-4 px-4 text-center">
          <span class="block text-xl sm:text-2xl font-bold tracking-tight text-text-primary">11</span>
          <span class="mt-1 block text-[10px] text-text-muted uppercase tracking-[0.2em]">{r.metrics.crates}</span>
        </div>
      </div>
      <div class="rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
        <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] py-4 px-4 text-center">
          <span class="block text-xl sm:text-2xl font-bold tracking-tight text-text-primary">2,700+</span>
          <span class="mt-1 block text-[10px] text-text-muted uppercase tracking-[0.2em]">{r.metrics.tests}</span>
        </div>
      </div>
      <div class="rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
        <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] py-4 px-4 text-center">
          <span class="block text-xl sm:text-2xl font-bold tracking-tight text-text-primary">0</span>
          <span class="mt-1 block text-[10px] text-text-muted uppercase tracking-[0.2em]">{r.metrics.deps}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- TIMELINE: vertical spine + 5 phases                         -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <div class="relative">
    <!-- Spine: gradient rail (desktop only) — color shifts mark progression -->
    <div aria-hidden="true" class="hidden md:block absolute left-10 top-0 bottom-0 w-px bg-gradient-to-b from-valid/60 via-proof/40 via-30% via-info/20 via-60% to-text-muted/10 pointer-events-none"></div>

    <!-- ═══ PHASE 1: NOW (SHIPPED) ═══ -->
    <section id="now" class="relative border-b border-subtle/77">
      <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
      <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
      <div aria-hidden="true" class="hidden md:block absolute left-[33px] top-9 w-3.5 h-3.5 rounded-full bg-valid ring-4 ring-valid/15 shadow-[0_0_12px_rgba(52,211,153,0.4)]"></div>

      <header class="reveal px-6 sm:px-8 md:pl-20 md:pr-16 pt-10 pb-6">
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <span class="inline-flex items-center rounded-full bg-valid/10 ring-1 ring-valid/25 px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-valid">
            {r.status.shipped}
          </span>
          <span class="font-mono text-sm text-text-primary">{r.phases.now.anchor}</span>
          <span class="text-sm text-text-muted">· {r.phases.now.desc}</span>
        </div>
        <h2 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight">{r.phases.now.label}</h2>
      </header>

      <!-- Bento asymmetric: featured (12) → 7/5 zig-zag → 12 footer.
           Avoids the banned uniform 3-col grid. -->
      <div class="px-6 sm:px-8 md:pl-20 md:pr-16 pb-10 grid gap-4 lg:grid-cols-12">
        <!-- FEATURED: Generic FieldBackend -->
        <article class="reveal lg:col-span-12 rounded-2xl bg-valid/[0.04] ring-1 ring-valid/15 shadow-[inset_0_1px_0_rgba(52,211,153,0.06)] p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-valid/[0.12] shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] p-6 lg:p-8">
            <h3 class="text-lg sm:text-xl font-bold text-text-primary tracking-tight">{r.items.multiPrime}</h3>
            <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed max-w-3xl">{r.items.multiPrimeDesc}</p>
            <div class="mt-5 flex flex-wrap gap-x-5 gap-y-1.5 text-[12px] font-mono text-text-muted items-center">
              <span><span class="text-valid">→</span> {r.receipts.released} v0.1.0-beta.19</span>
              <span class="text-text-muted/60">·</span>
              <span>+43 commits</span>
              <span class="text-text-muted/60">·</span>
              <span>2026-04-02</span>
              <span class="text-text-muted/60">·</span>
              <a href="https://github.com/achronyme/achronyme/releases/tag/v0.1.0-beta.19" target="_blank" rel="noopener noreferrer" class="receipt-link group inline-flex items-center gap-1 text-proof-light hover:text-proof active:scale-[0.97]">
                <span>{r.receipts.viewRelease}</span>
                <span class="receipt-arrow inline-block">↗</span>
              </a>
            </div>
          </div>
        </article>

        <!-- Zig-zag satellites: 7/5 split -->
        <article class="reveal lg:col-span-7 rounded-2xl bg-valid/[0.025] ring-1 ring-valid/10 p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-valid/[0.08] p-5 lg:p-6 h-full flex flex-col">
            <h3 class="text-sm font-semibold text-text-primary tracking-tight">{r.items.proveIR}</h3>
            <p class="mt-2 text-[13px] text-text-secondary leading-relaxed flex-1">{r.items.proveIRDesc}</p>
            <div class="mt-4 text-[11px] font-mono text-text-muted">
              <span class="text-valid">→</span> beta.14 · 186+ tests
            </div>
          </div>
        </article>
        <article class="reveal lg:col-span-5 rounded-2xl bg-valid/[0.025] ring-1 ring-valid/10 p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-valid/[0.08] p-5 lg:p-6 h-full flex flex-col">
            <h3 class="text-sm font-semibold text-text-primary tracking-tight">{r.items.solidity}</h3>
            <p class="mt-2 text-[13px] text-text-secondary leading-relaxed flex-1">{r.items.solidityDesc}</p>
            <div class="mt-4 text-[11px] font-mono text-text-muted">
              <span class="text-valid">→</span> Groth16 verifier
            </div>
          </div>
        </article>

        <!-- Wide footer card -->
        <article class="reveal lg:col-span-12 rounded-2xl bg-valid/[0.025] ring-1 ring-valid/10 p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-valid/[0.08] p-5 lg:p-6 h-full flex flex-col sm:flex-row sm:items-center sm:gap-6">
            <div class="flex-1">
              <h3 class="text-sm font-semibold text-text-primary tracking-tight">{r.items.r1csOptimizer}</h3>
              <p class="mt-2 text-[13px] text-text-secondary leading-relaxed">{r.items.r1csOptimizerDesc}</p>
            </div>
            <div class="mt-4 sm:mt-0 shrink-0 text-[11px] font-mono text-text-muted">
              <span class="text-valid">→</span> 3.6x perf gain
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- ═══ PHASE 2: WIP (IN PROGRESS, shimmering) ═══ -->
    <section id="wip" class="relative border-b border-subtle/77">
      <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
      <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
      <div aria-hidden="true" class="hidden md:block absolute left-[33px] top-9 w-3.5 h-3.5 rounded-full bg-proof ring-4 ring-proof/15 wip-pulse"></div>

      <header class="reveal px-6 sm:px-8 md:pl-20 md:pr-16 pt-10 pb-6">
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-proof/15 ring-1 ring-proof/30 px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-proof-light">
            <span class="h-1.5 w-1.5 rounded-full bg-proof animate-pulse"></span>
            {r.status.inProgress}
          </span>
          <span class="font-mono text-sm text-text-primary">{r.phases.wip.anchor}</span>
          <span class="text-sm text-text-muted">· {r.phases.wip.desc}</span>
        </div>
        <h2 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight">{r.phases.wip.label}</h2>
      </header>

      <div class="px-6 sm:px-8 md:pl-20 md:pr-16 pb-10 grid gap-4 lg:grid-cols-12">
        <!-- FEATURED: Circom Frontend with split text/code (full row) -->
        <article class="reveal lg:col-span-12 rounded-2xl bg-proof/[0.06] ring-1 ring-proof/25 shadow-[inset_0_1px_0_rgba(168,85,247,0.08)] p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-proof/15 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] overflow-hidden grid lg:grid-cols-5">
            <div class="lg:col-span-3 p-6 lg:p-8">
              <h3 class="text-lg sm:text-xl font-bold text-text-primary tracking-tight">{r.items.circomFrontend}</h3>
              <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed">{r.items.circomFrontendDesc}</p>
              <div class="mt-5 flex flex-wrap gap-1.5">
                <span class="rounded-md bg-valid/10 ring-1 ring-valid/20 px-2 py-0.5 text-[10px] font-mono text-valid">Poseidon ✓</span>
                <span class="rounded-md bg-valid/10 ring-1 ring-valid/20 px-2 py-0.5 text-[10px] font-mono text-valid">MiMCSponge ✓</span>
                <span class="rounded-md bg-valid/10 ring-1 ring-valid/20 px-2 py-0.5 text-[10px] font-mono text-valid">EscalarMulAny ✓</span>
                <span class="rounded-md bg-valid/10 ring-1 ring-valid/20 px-2 py-0.5 text-[10px] font-mono text-valid">BabyJubjub ✓</span>
                <span class="rounded-md bg-warn/10 ring-1 ring-warn/20 px-2 py-0.5 text-[10px] font-mono text-warn">EdDSA · pending</span>
              </div>
              <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1.5 text-[12px] font-mono text-text-muted items-center">
                <span><span class="text-proof-light">⚡</span> {r.receipts.branch}: main</span>
                <span class="text-text-muted/60">·</span>
                <span>180+ circom commits</span>
                <span class="text-text-muted/60">·</span>
                <a href="https://github.com/achronyme/achronyme/commits/main?path=circom" target="_blank" rel="noopener noreferrer" class="receipt-link group inline-flex items-center gap-1 text-proof-light hover:text-proof active:scale-[0.97]">
                  <span>{r.receipts.viewBranch}</span>
                  <span class="receipt-arrow inline-block">↗</span>
                </a>
              </div>
            </div>
            <div class="lg:col-span-2 relative bg-[#08080D] border-t lg:border-t-0 lg:border-l border-white/[0.06] p-5 lg:p-6 flex items-center">
              <pre class="text-[11px] lg:text-[12px] font-mono leading-relaxed overflow-x-auto w-full"><code><span class="text-text-muted">// import circomlib directly</span>
<span class="text-proof-light">use</span> circom <span class="text-warn">"poseidon.circom"</span>

<span class="text-proof-light">let</span> hash <span class="text-text-muted">=</span> <span class="text-info">Poseidon</span>(<span class="text-warn">2</span>)
  .compute([secret, salt])

<span class="text-proof font-bold">prove</span>(hash: <span class="text-valid">Public</span>) <span class="text-text-muted">&#123;</span>
  <span class="text-info">assert_eq</span>(
    <span class="text-info">Poseidon</span>(<span class="text-warn">2</span>).hash([secret, salt]),
    hash
  )
<span class="text-text-muted">&#125;</span>

<span class="text-text-muted">// 240 constraints — matches O2</span></code></pre>
            </div>
          </div>
        </article>

        <!-- Wide satellite (full row) -->
        <article class="reveal lg:col-span-12 rounded-2xl bg-proof/[0.03] ring-1 ring-proof/15 p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-proof/10 p-5 lg:p-6 h-full flex flex-col sm:flex-row sm:items-center sm:gap-6">
            <div class="flex-1">
              <h3 class="text-sm font-semibold text-text-primary tracking-tight">{r.items.adversarialTests}</h3>
              <p class="mt-2 text-[13px] text-text-secondary leading-relaxed">{r.items.adversarialTestsDesc}</p>
            </div>
            <div class="mt-4 sm:mt-0 shrink-0 text-[11px] font-mono text-text-muted">
              <span class="text-proof-light">⚡</span> 4 forge-attempt tests
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- ═══ PHASE 3: NEXT (PLANNED) ═══ -->
    <section id="next" class="relative border-b border-subtle/77">
      <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
      <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
      <div aria-hidden="true" class="hidden md:block absolute left-[33px] top-9 w-3.5 h-3.5 rounded-full bg-info/40 ring-4 ring-info/10"></div>

      <header class="reveal px-6 sm:px-8 md:pl-20 md:pr-16 pt-10 pb-6">
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <span class="inline-flex items-center rounded-full bg-info/10 ring-1 ring-info/25 px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-info">{r.status.planned}</span>
          <span class="font-mono text-sm text-text-primary">{r.phases.next.anchor}</span>
          <span class="text-sm text-text-muted">· {r.phases.next.desc}</span>
        </div>
        <h2 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight">{r.phases.next.label}</h2>
      </header>

      <div class="px-6 sm:px-8 md:pl-20 md:pr-16 pb-10 grid gap-4 lg:grid-cols-2">
        <article class="reveal rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] p-6 h-full flex flex-col">
            <h3 class="text-base font-semibold text-text-primary tracking-tight">{r.items.playground}</h3>
            <p class="mt-2 text-[13.5px] text-text-secondary leading-relaxed flex-1">{r.items.playgroundDesc}</p>
            <div class="mt-4 text-[11px] font-mono text-text-muted">
              <span class="text-info">○</span> WASM feasibility verified · beta.16
            </div>
          </div>
        </article>
        <article class="reveal rounded-2xl bg-white/[0.025] ring-1 ring-white/[0.05] p-1.5">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] p-6 h-full flex flex-col">
            <h3 class="text-base font-semibold text-text-primary tracking-tight">{r.items.multiFieldVM}</h3>
            <p class="mt-2 text-[13.5px] text-text-secondary leading-relaxed flex-1">{r.items.multiFieldVMDesc}</p>
            <div class="mt-4 text-[11px] font-mono text-text-muted">
              <span class="text-info">○</span> blocked by VM single-field assumption
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- ═══ PHASE 4: LATER (EXPLORATORY, dashed) ═══ -->
    <section id="later" class="relative border-b border-subtle/77">
      <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
      <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
      <div aria-hidden="true" class="hidden md:block absolute left-[33px] top-9 w-3.5 h-3.5 rounded-full bg-text-muted/40 ring-4 ring-text-muted/10"></div>

      <header class="reveal px-6 sm:px-8 md:pl-20 md:pr-16 pt-10 pb-6">
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <span class="inline-flex items-center rounded-full bg-text-muted/10 ring-1 ring-text-muted/20 px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-text-muted">{r.status.exploratory}</span>
          <span class="font-mono text-sm text-text-secondary">{r.phases.later.anchor}</span>
          <span class="text-sm text-text-muted">· {r.phases.later.desc}</span>
        </div>
        <h2 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight text-text-secondary">{r.phases.later.label}</h2>
      </header>

      <!-- Bento 7/5 + full footer. STARK is the strategic anchor for Goldilocks. -->
      <div class="px-6 sm:px-8 md:pl-20 md:pr-16 pb-10 grid gap-4 lg:grid-cols-12">
        <article class="reveal lg:col-span-7 rounded-2xl border border-dashed border-white/[0.10] p-6 bg-transparent flex flex-col">
          <h3 class="text-sm font-semibold text-text-secondary tracking-tight">{r.items.starkBackend}</h3>
          <p class="mt-2 text-[13px] text-text-muted leading-relaxed flex-1">{r.items.starkBackendDesc}</p>
          <div class="mt-4 text-[11px] font-mono text-text-muted/70">○ research scoped · Plonky3</div>
        </article>
        <article class="reveal lg:col-span-5 rounded-2xl border border-dashed border-white/[0.10] p-6 bg-transparent flex flex-col">
          <h3 class="text-sm font-semibold text-text-secondary tracking-tight">{r.items.noirFrontend}</h3>
          <p class="mt-2 text-[13px] text-text-muted leading-relaxed flex-1">{r.items.noirFrontendDesc}</p>
          <div class="mt-4 text-[11px] font-mono text-text-muted/70">○ post-Circom</div>
        </article>
        <article class="reveal lg:col-span-12 rounded-2xl border border-dashed border-white/[0.10] p-6 bg-transparent flex flex-col sm:flex-row sm:items-center sm:gap-6">
          <div class="flex-1">
            <h3 class="text-sm font-semibold text-text-secondary tracking-tight">{r.items.rustSDK}</h3>
            <p class="mt-2 text-[13px] text-text-muted leading-relaxed">{r.items.rustSDKDesc}</p>
          </div>
          <div class="mt-4 sm:mt-0 shrink-0 text-[11px] font-mono text-text-muted/70">○ 3-phase plan</div>
        </article>
      </div>
    </section>

    <!-- ═══ PHASE 5: 1.0 TARGET ═══ -->
    <section id="target" class="relative border-b border-subtle/77">
      <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
      <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
      <div aria-hidden="true" class="hidden md:block absolute left-[31px] top-9 w-4 h-4 rounded-full bg-gradient-to-br from-proof to-info ring-4 ring-proof/10"></div>

      <header class="reveal px-6 sm:px-8 md:pl-20 md:pr-16 pt-10 pb-6">
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
          <span class="inline-flex items-center rounded-full bg-gradient-to-r from-proof/15 to-info/15 ring-1 ring-proof/30 px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium text-proof-light">{r.status.target}</span>
          <span class="font-mono text-sm text-text-primary">{r.phases.target.anchor}</span>
          <span class="text-sm text-text-muted">· {r.phases.target.desc}</span>
        </div>
        <h2 class="mt-3 text-xl sm:text-2xl font-bold tracking-tight">{r.phases.target.label}</h2>
      </header>

      <div class="px-6 sm:px-8 md:pl-20 md:pr-16 pb-12">
        <article class="reveal rounded-2xl bg-gradient-to-br from-proof/[0.06] to-info/[0.04] ring-1 ring-proof/15 p-1.5 max-w-2xl">
          <div class="rounded-[calc(1rem-0.375rem)] bg-[#0C0C12] ring-1 ring-white/[0.08] shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] p-6">
            <h3 class="text-base font-semibold text-text-primary tracking-tight">{r.items.apiFreeze}</h3>
            <p class="mt-2 text-[13.5px] text-text-secondary leading-relaxed">{r.items.apiFreezeDesc}</p>
          </div>
        </article>
      </div>
    </section>

  </div>
</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
