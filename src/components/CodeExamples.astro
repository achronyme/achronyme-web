---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);
---

<section id="code" class="relative px-6 py-24 sm:py-32">
  <div class="relative mx-auto max-w-6xl border border-subtle/30">
    <!-- Corner nodes -->
    <div class="corner-node absolute -top-1 -left-1"></div>
    <div class="corner-node absolute -top-1 -right-1"></div>
    <div class="corner-node absolute -bottom-1 -left-1"></div>
    <div class="corner-node absolute -bottom-1 -right-1"></div>
    <!-- Label -->
    <span class="frame-label top-0 left-8 -translate-y-1/2">.repl</span>

    <div class="p-8 sm:p-10 lg:p-12">
      <div class="reveal text-center">
        <span class="mb-4 inline-block text-xs font-medium uppercase tracking-widest text-proof">
          {locale === 'en' ? 'Examples' : 'Ejemplos'}
        </span>
        <h2 class="mb-4 text-2xl font-bold tracking-tight sm:text-4xl">
          {s.code.title}
        </h2>
        <p class="mx-auto mb-12 max-w-xl text-sm text-text-secondary">
          {locale === 'en'
            ? 'From simple programs to zero-knowledge proofs — all in one language.'
            : 'Desde programas simples hasta pruebas zero-knowledge — todo en un solo lenguaje.'}
        </p>
      </div>

      <div class="reveal">
        <!-- Tabs -->
        <div class="flex gap-1 rounded-[10px] bg-surface/80 p-1 border border-subtle backdrop-blur-sm">
        <button data-tab="zk" class="tab-btn active flex-1 rounded-[6px] px-3 py-2.5 text-xs font-medium transition-all">
          {s.code.tab1}
        </button>
        <button data-tab="vm" class="tab-btn flex-1 rounded-[6px] px-3 py-2.5 text-xs font-medium transition-all">
          {s.code.tab2}
        </button>
        <button data-tab="cli" class="tab-btn flex-1 rounded-[6px] px-3 py-2.5 text-xs font-medium transition-all">
          {s.code.tab3}
        </button>
      </div>

      <!-- Code panels -->
      <div class="relative mt-4">
        <div class="absolute -inset-3 rounded-[20px] bg-gradient-to-b from-proof/8 to-transparent blur-xl"></div>

        <div class="relative overflow-hidden rounded-[14px] border border-subtle bg-surface/90 backdrop-blur-sm">
          <!-- ZK Proof -->
          <div id="panel-zk" class="code-panel">
            <div class="flex items-center justify-between border-b border-subtle px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="ml-3 text-xs text-text-muted">prove_chain.ach</span>
              </div>
              <span class="rounded-full bg-proof/10 px-2 py-0.5 text-[10px] text-proof">ZK</span>
            </div>
            <div class="flex overflow-x-auto">
              <div class="flex-none select-none border-r border-subtle py-5 pl-4 pr-3 text-right text-xs leading-relaxed text-text-muted/40">
                <div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div><div>10</div><div>11</div><div>12</div><div>13</div><div>14</div><div>15</div><div>16</div><div>17</div><div>18</div><div>19</div>
              </div>
              <pre class="flex-1 py-5 pl-4 pr-5 text-[13px] leading-relaxed"><code><span class="text-text-muted">// Prove commitment + nullifier from same secret</span>
<span class="text-proof-light">let</span> secret <span class="text-text-muted">=</span> <span class="text-warn">0p12345</span>
<span class="text-proof-light">let</span> blinding <span class="text-text-muted">=</span> <span class="text-warn">0p98765</span>

<span class="text-text-muted">// Commitment proof</span>
<span class="text-proof font-bold">prove</span> <span class="text-text-muted">&#123;</span>
    <span class="text-info">witness</span> secret
    <span class="text-info">witness</span> blinding
    <span class="text-valid">public</span> commitment
    <span class="text-proof-light">let</span> cm <span class="text-text-muted">=</span> <span class="text-info">poseidon</span>(secret, blinding)
    <span class="text-info">assert_eq</span>(cm, commitment)
<span class="text-text-muted">&#125;</span>

<span class="text-text-muted">// Nullifier from same secret</span>
<span class="text-proof font-bold">prove</span> <span class="text-text-muted">&#123;</span>
    <span class="text-info">witness</span> secret
    <span class="text-info">witness</span> leaf_index
    <span class="text-valid">public</span> nullifier
    <span class="text-proof-light">let</span> nf <span class="text-text-muted">=</span> <span class="text-info">poseidon</span>(secret, leaf_index)
    <span class="text-info">assert_eq</span>(nf, nullifier)
<span class="text-text-muted">&#125;</span></code></pre>
            </div>
          </div>

          <!-- VM Mode -->
          <div id="panel-vm" class="code-panel hidden">
            <div class="flex items-center justify-between border-b border-subtle px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="ml-3 text-xs text-text-muted">algorithms.ach</span>
              </div>
              <span class="rounded-full bg-valid/10 px-2 py-0.5 text-[10px] text-valid">VM</span>
            </div>
            <div class="flex overflow-x-auto">
              <div class="flex-none select-none border-r border-subtle py-5 pl-4 pr-3 text-right text-xs leading-relaxed text-text-muted/40">
                <div>1</div><div>2</div><div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div><div>10</div><div>11</div><div>12</div><div>13</div><div>14</div><div>15</div><div>16</div><div>17</div>
              </div>
              <pre class="flex-1 py-5 pl-4 pr-5 text-[13px] leading-relaxed"><code><span class="text-text-muted">// Binary search — full VM mode</span>
<span class="text-proof-light">fn</span> <span class="text-info">binary_search</span>(arr, target) <span class="text-text-muted">&#123;</span>
    <span class="text-proof-light">mut</span> lo <span class="text-text-muted">=</span> <span class="text-warn">0</span>
    <span class="text-proof-light">mut</span> hi <span class="text-text-muted">=</span> <span class="text-info">len</span>(arr) <span class="text-text-muted">-</span> <span class="text-warn">1</span>
    <span class="text-proof-light">while</span> lo <span class="text-text-muted">&lt;=</span> hi <span class="text-text-muted">&#123;</span>
        <span class="text-proof-light">let</span> mid <span class="text-text-muted">=</span> (lo <span class="text-text-muted">+</span> hi) <span class="text-text-muted">/</span> <span class="text-warn">2</span>
        <span class="text-proof-light">if</span> arr[mid] <span class="text-text-muted">==</span> target <span class="text-text-muted">&#123;</span> <span class="text-proof-light">return</span> mid <span class="text-text-muted">&#125;</span>
        <span class="text-proof-light">if</span> arr[mid] <span class="text-text-muted">&lt;</span> target <span class="text-text-muted">&#123;</span>
            lo <span class="text-text-muted">=</span> mid <span class="text-text-muted">+</span> <span class="text-warn">1</span>
        <span class="text-text-muted">&#125;</span> <span class="text-proof-light">else</span> <span class="text-text-muted">&#123;</span>
            hi <span class="text-text-muted">=</span> mid <span class="text-text-muted">-</span> <span class="text-warn">1</span>
        <span class="text-text-muted">&#125;</span>
    <span class="text-text-muted">&#125;</span>
    <span class="text-proof-light">return</span> <span class="text-warn">-1</span>
<span class="text-text-muted">&#125;</span>

<span class="text-proof-light">let</span> sorted <span class="text-text-muted">=</span> [<span class="text-warn">2</span>, <span class="text-warn">5</span>, <span class="text-warn">8</span>, <span class="text-warn">12</span>, <span class="text-warn">16</span>, <span class="text-warn">23</span>, <span class="text-warn">38</span>]
<span class="text-info">assert</span>(<span class="text-info">binary_search</span>(sorted, <span class="text-warn">23</span>) <span class="text-text-muted">==</span> <span class="text-warn">5</span>)</code></pre>
            </div>
          </div>

          <!-- CLI -->
          <div id="panel-cli" class="code-panel hidden">
            <div class="flex items-center justify-between border-b border-subtle px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-text-muted/30"></span>
                <span class="ml-3 text-xs text-text-muted">terminal</span>
              </div>
              <span class="rounded-full bg-warn/10 px-2 py-0.5 text-[10px] text-warn">CLI</span>
            </div>
            <pre class="overflow-x-auto p-5 text-[13px] leading-relaxed"><code><span class="text-text-muted"># Run a program</span>
<span class="text-valid">$</span> ach run hello.ach
<span class="text-text-secondary">Hello, world!</span>

<span class="text-text-muted"># Compile to R1CS circuit</span>
<span class="text-valid">$</span> ach circuit proof.ach --backend r1cs
<span class="text-text-secondary">R1CS: 362 constraints, 3 public inputs</span>

<span class="text-text-muted"># Generate + verify proof (Groth16)</span>
<span class="text-valid">$</span> ach run proof.ach --prove --prove-backend r1cs
<span class="text-valid">Proof generated</span> <span class="text-text-muted">(Groth16, 192 bytes)</span>
<span class="text-valid">Proof verified</span>

<span class="text-text-muted"># Export Solidity verifier</span>
<span class="text-valid">$</span> ach circuit proof.ach --solidity Verifier.sol
<span class="text-text-secondary">Wrote Verifier.sol</span></code></pre>
          </div>
        </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tab-btn {
    color: var(--color-text-muted);
  }
  .tab-btn:hover {
    color: var(--color-text-secondary);
    background-color: color-mix(in srgb, var(--color-subtle) 50%, transparent);
  }
  .tab-btn.active {
    background-color: var(--color-subtle);
    color: var(--color-text-primary);
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.05);
  }
</style>

<script>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.code-panel').forEach((p) => p.classList.add('hidden'));
      document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
    });
  });
</script>
