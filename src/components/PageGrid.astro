---
import type { Locale } from '../i18n';
import { t } from '../i18n';
import TerminalMockup from './TerminalMockup.astro';
import HeroCircuit from './HeroCircuit.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);
---

<div class="mx-auto max-w-[1400px] border-x border-t border-subtle/77 relative">

  <!-- Outer top corner dots -->
  <div class="grid-dot absolute -top-[3px] -left-[3px] z-10"></div>
  <div class="grid-dot absolute -top-[3px] -right-[3px] z-10"></div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- HERO                                                      -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <section class="grid grid-cols-1 lg:grid-cols-2 border-b border-subtle/77 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>

    <!-- Left: text -->
    <div class="p-8 lg:p-10">
      <div class="reveal mb-10">
        <span class="text-xs tracking-widest uppercase text-text-muted">BY</span>
        <a href="https://eddn.dev" target="_blank" rel="noopener noreferrer" class="ml-2 text-xs tracking-widest uppercase font-semibold text-text-primary hover:text-proof-light transition-colors">eddndev</a>
      </div>

      <h1 class="reveal text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold tracking-tight leading-[1.08] text-text-primary">
        {s.hero.headline1}<br />
        {s.hero.headline2}
      </h1>

      <p class="reveal mt-6 max-w-md text-base sm:text-lg leading-relaxed text-text-secondary">
        {s.hero.subtitle}
      </p>

      <div class="reveal mt-8 flex flex-wrap gap-3">
        <a
          href="https://github.com/achronyme/achronyme/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-proof px-6 py-3 text-sm font-medium text-white transition-all hover:bg-proof-dim hover:shadow-[0_0_24px_rgba(168,85,247,0.25)]"
        >
          {s.hero.cta}
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a
          href="https://github.com/achronyme/achronyme"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-subtle px-6 py-3 text-sm font-medium text-text-secondary transition-all hover:text-text-primary hover:border-proof/30"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          {s.hero.github}
        </a>
      </div>

      <!-- Install command -->
      <div class="reveal mt-14 max-w-md">
        <div class="rounded-lg border border-subtle/60 bg-[#0C0C12] px-5 py-3.5 font-mono text-sm flex items-center gap-2">
          <span class="text-text-muted select-none">$</span>
          <el-copyable id="install-cmd" class="text-text-secondary min-w-0 truncate">curl -fsSL https://achrony.me/install.sh | sh</el-copyable>
          <button command="--copy" commandfor="install-cmd" type="button" class="group ml-auto shrink-0 rounded p-1.5 text-text-muted transition-colors hover:text-text-secondary hover:bg-subtle/30" aria-label="Copy install command">
            <svg class="h-4 w-4 group-data-[copied]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="9" y="9" width="13" height="13" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
            <svg class="hidden h-4 w-4 text-valid group-data-[copied]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Right: circuit visual -->
    <div class="hidden lg:block relative overflow-hidden text-proof">
      <HeroCircuit />
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- ECOSYSTEM BAR                                             -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <div class="border-b border-subtle/77 px-8 lg:px-10 py-5 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="reveal flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <span class="text-sm text-text-muted">{s.ecosystem.title}</span>
      <div class="flex flex-wrap gap-2">
        {s.ecosystem.outputs.map((item: string) => (
          <span class="rounded-full border border-subtle/60 bg-surface/40 px-3 py-1 text-xs font-medium text-proof-light">{item}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- FEATURES (scroll-driven sticky nav)                       -->
  <!-- ══════════════════════════════════════════════════════════ -->

  <div id="features-wrapper">
  <!-- Sticky feature nav — sits below banner (36px) + header (56px) = 92px -->
  <nav id="feature-nav" class="sticky top-[92px] z-40 bg-void border-b border-subtle/77 flex">
    <a href="#feat-vm" class="feature-tab flex-1 px-4 py-4 text-center text-sm font-medium text-text-muted transition-colors hover:text-text-primary" data-target="feat-vm">VM</a>
    <a href="#feat-circuit" class="feature-tab flex-1 px-4 py-4 text-center text-sm font-medium text-text-muted transition-colors hover:text-text-primary" data-target="feat-circuit">Circuit</a>
    <a href="#feat-deploy" class="feature-tab flex-1 px-4 py-4 text-center text-sm font-medium text-text-muted transition-colors hover:text-text-primary" data-target="feat-deploy">Deploy</a>
    <a href="#feat-prove" class="feature-tab flex-1 px-4 py-4 text-center text-sm font-medium text-text-muted transition-colors hover:text-text-primary" data-target="feat-prove">Prove</a>
  </nav>

  <!-- VM Section -->
  <section id="feat-vm" class="border-b border-subtle/77 grid grid-cols-1 lg:grid-cols-2 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="p-8 lg:p-10 lg:border-r border-subtle/77">
      <span class="text-xs tracking-widest uppercase text-text-muted">ACH RUN</span>
      <h3 class="mt-4 text-xl sm:text-2xl font-bold">{s.featureVM.title}</h3>
      <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed">{s.featureVM.desc}</p>
    </div>
    <div class="p-6 lg:p-8">
      <TerminalMockup filename="algorithms.ach" badge="VM" badgeColor="text-valid">
        <pre><code><span class="text-text-muted">// Binary search — full VM mode</span>
<span class="text-proof-light">fn</span> <span class="text-info">binary_search</span>(arr, target) <span class="text-text-muted">&#123;</span>
    <span class="text-proof-light">mut</span> lo <span class="text-text-muted">=</span> <span class="text-warn">0</span>
    <span class="text-proof-light">mut</span> hi <span class="text-text-muted">=</span> <span class="text-info">len</span>(arr) <span class="text-text-muted">-</span> <span class="text-warn">1</span>
    <span class="text-proof-light">while</span> lo <span class="text-text-muted">&lt;=</span> hi <span class="text-text-muted">&#123;</span>
        <span class="text-proof-light">let</span> mid <span class="text-text-muted">=</span> (lo <span class="text-text-muted">+</span> hi) <span class="text-text-muted">/</span> <span class="text-warn">2</span>
        <span class="text-proof-light">if</span> arr[mid] <span class="text-text-muted">==</span> target <span class="text-text-muted">&#123;</span> <span class="text-proof-light">return</span> mid <span class="text-text-muted">&#125;</span>
        <span class="text-proof-light">if</span> arr[mid] <span class="text-text-muted">&lt;</span> target <span class="text-text-muted">&#123;</span>
            lo <span class="text-text-muted">=</span> mid <span class="text-text-muted">+</span> <span class="text-warn">1</span>
        <span class="text-text-muted">&#125;</span> <span class="text-proof-light">else</span> <span class="text-text-muted">&#123;</span>
            hi <span class="text-text-muted">=</span> mid <span class="text-text-muted">-</span> <span class="text-warn">1</span>
        <span class="text-text-muted">&#125;</span>
    <span class="text-text-muted">&#125;</span>
    <span class="text-proof-light">return</span> <span class="text-warn">-1</span>
<span class="text-text-muted">&#125;</span>

<span class="text-proof-light">let</span> sorted <span class="text-text-muted">=</span> [<span class="text-warn">2</span>, <span class="text-warn">5</span>, <span class="text-warn">8</span>, <span class="text-warn">12</span>, <span class="text-warn">16</span>, <span class="text-warn">23</span>, <span class="text-warn">38</span>]
<span class="text-info">assert</span>(<span class="text-info">binary_search</span>(sorted, <span class="text-warn">23</span>) <span class="text-text-muted">==</span> <span class="text-warn">5</span>)</code></pre>
      </TerminalMockup>
    </div>
  </section>

  <!-- Circuit Section -->
  <section id="feat-circuit" class="border-b border-subtle/77 grid grid-cols-1 lg:grid-cols-2 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="p-8 lg:p-10 lg:border-r border-subtle/77">
      <span class="text-xs tracking-widest uppercase text-text-muted">ACH CIRCUIT</span>
      <h3 class="mt-4 text-xl sm:text-2xl font-bold">{s.featureCircuit.title}</h3>
      <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed">{s.featureCircuit.desc}</p>
    </div>
    <div class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-proof-dim via-proof to-proof-dim"></div>
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(115deg, transparent, transparent 8px, rgba(255,255,255,0.03) 8px, rgba(255,255,255,0.03) 9px);"></div>
      <div class="relative p-6 lg:p-8">
        <TerminalMockup filename="terminal" badge="CLI" badgeColor="text-info">
          <pre><code><span class="text-valid">$</span> ach circuit vote.ach --inputs "..." --backend r1cs

<span class="text-valid">Compiling</span> <span class="text-text-secondary">vote.ach...</span>
<span class="text-text-secondary">    IR: 18 instructions</span>
<span class="text-text-secondary">    Optimized: 3 eliminated (constant folding + DCE)</span>
<span class="text-text-secondary">    Boolean propagation: 2 proven</span>

<span class="text-valid">R1CS generated:</span>
<span class="text-text-secondary">    Constraints:    2,179</span>
<span class="text-text-secondary">    Public inputs:  4</span>
<span class="text-text-secondary">    Private inputs: 5</span>
<span class="text-text-secondary">    Wrote vote.r1cs (932 bytes)</span>
<span class="text-text-secondary">    Wrote witness.wtns (236 bytes)</span> <span class="text-text-muted">—</span> <span class="text-valid">verified OK</span></code></pre>
        </TerminalMockup>
      </div>
    </div>
  </section>

  <!-- Deploy Section -->
  <section id="feat-deploy" class="border-b border-subtle/77 grid grid-cols-1 lg:grid-cols-2 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="p-8 lg:p-10 lg:border-r border-subtle/77">
      <span class="text-xs tracking-widest uppercase text-text-muted">--SOLIDITY</span>
      <h3 class="mt-4 text-xl sm:text-2xl font-bold">{s.featureSolidity.title}</h3>
      <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed">{s.featureSolidity.desc}</p>
    </div>
    <div class="p-6 lg:p-8">
      <TerminalMockup filename="terminal" badge="CLI" badgeColor="text-warn">
        <pre><code><span class="text-valid">$</span> ach run proof.ach --prove-backend r1cs
<span class="text-valid">Proof generated</span> <span class="text-text-muted">(Groth16, 855 bytes)</span>
<span class="text-valid">Proof verified</span> <span class="text-text-muted">— 5 constraints</span>

<span class="text-valid">$</span> ach circuit proof.ach --solidity Verifier.sol
<span class="text-text-secondary">    Wrote Verifier.sol</span> <span class="text-text-muted">(Solidity Groth16 verifier)</span>

<span class="text-text-muted">// Deploy and verify on-chain</span></code></pre>
      </TerminalMockup>
    </div>
  </section>

  <!-- Prove Section -->
  <section id="feat-prove" class="border-b border-subtle/77 grid grid-cols-1 lg:grid-cols-2 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="p-8 lg:p-10 lg:border-r border-subtle/77">
      <span class="text-xs tracking-widest uppercase text-text-muted">PROVE &#123;&#125;</span>
      <h3 class="mt-4 text-xl sm:text-2xl font-bold">{s.featureProve.title}</h3>
      <p class="mt-3 text-sm sm:text-[15px] text-text-secondary leading-relaxed">{s.featureProve.desc}</p>
    </div>
    <div class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-proof-dim via-proof to-proof-dim"></div>
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(135deg, transparent, transparent 8px, rgba(255,255,255,0.03) 8px, rgba(255,255,255,0.03) 9px);"></div>
      <div class="relative p-6 lg:p-8">
        <TerminalMockup filename="commitment.ach" badge="ZK" badgeColor="text-proof">
          <pre><code><span class="text-proof-light">let</span> secret <span class="text-text-muted">=</span> <span class="text-warn">0p12345</span>
<span class="text-proof-light">let</span> blinding <span class="text-text-muted">=</span> <span class="text-warn">0p98765</span>

<span class="text-proof font-bold">prove</span> <span class="text-text-muted">&#123;</span>
    <span class="text-info">witness</span> secret
    <span class="text-info">witness</span> blinding
    <span class="text-valid">public</span> commitment
    <span class="text-proof-light">let</span> cm <span class="text-text-muted">=</span> <span class="text-info">poseidon</span>(secret, blinding)
    <span class="text-info">assert_eq</span>(cm, commitment)
<span class="text-text-muted">&#125;</span>

<span class="text-text-muted">// proof is a first-class value</span>
<span class="text-proof-light">let</span> json <span class="text-text-muted">=</span> <span class="text-info">proof_json</span>(proof)
<span class="text-info">assert</span>(<span class="text-info">verify_proof</span>(proof))</code></pre>
        </TerminalMockup>
      </div>
    </div>
  </section>
  </div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- SECTION HEADER: The difference                            -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <div class="border-b border-subtle/77 py-16 lg:py-24 px-8 text-center relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="reveal">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">{s.comparison.title}</h2>
      <p class="mt-4 text-text-secondary text-lg max-w-2xl mx-auto">{s.comparison.subtitle}</p>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- COMPARISON ROW                                            -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <div class="grid grid-cols-1 lg:grid-cols-2 border-b border-subtle/77 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] left-1/2 -translate-x-1/2 z-10 hidden lg:block"></div>

    <!-- Circom side -->
    <div class="p-8 lg:p-10 border-b lg:border-b-0 lg:border-r border-subtle/77">
      <div class="reveal">
        <TerminalMockup filename={s.comparison.circomLabel} badge={s.comparison.circomSteps} badgeColor="text-error">
          <pre><code><span class="text-text-muted">// 1. Write the circuit (Circom DSL)</span>
<span class="text-text-secondary">template Commitment() &#123;</span>
<span class="text-text-secondary">    signal input secret;</span>
<span class="text-text-secondary">    signal input blinding;</span>
<span class="text-text-secondary">    signal output cm;</span>
<span class="text-text-secondary">    component h = Poseidon(2);</span>
<span class="text-text-secondary">    h.inputs[0] &lt;== secret;</span>
<span class="text-text-secondary">    h.inputs[1] &lt;== blinding;</span>
<span class="text-text-secondary">    cm &lt;== h.out;</span>
<span class="text-text-secondary">&#125;</span>

<span class="text-text-muted">// 2. Compile</span>
<span class="text-text-secondary">$ circom commitment.circom --r1cs --wasm</span>

<span class="text-text-muted">// 3. Witness (JavaScript)</span>
<span class="text-text-secondary">const input = &#123; secret: "12345", blinding: "98765" &#125;;</span>
<span class="text-text-secondary">const w = await circuit.calculateWitness(input);</span>

<span class="text-text-muted">// 4. Powers of Tau</span>
<span class="text-text-secondary">$ wget ptau.hermez.io/powersOfTau28_12.ptau</span>

<span class="text-text-muted">// 5. Trusted setup</span>
<span class="text-text-secondary">$ snarkjs groth16 setup commitment.r1cs pot.ptau key.zkey</span>
<span class="text-text-secondary">$ snarkjs zkey contribute key.zkey final.zkey</span>

<span class="text-text-muted">// 6. Prove</span>
<span class="text-text-secondary">$ snarkjs groth16 prove final.zkey witness.wtns proof.json</span>

<span class="text-text-muted">// 7. Verify</span>
<span class="text-text-secondary">$ snarkjs groth16 verify vkey.json public.json proof.json</span></code></pre>
        </TerminalMockup>
      </div>
    </div>

    <!-- Achronyme side (highlighted) -->
    <div class="flex flex-col">
      <div class="relative overflow-hidden flex-1">
        <div class="absolute inset-0 bg-gradient-to-r from-proof-dim via-proof to-proof-dim"></div>
        <div class="absolute inset-0" style="background-image: repeating-linear-gradient(135deg, transparent, transparent 8px, rgba(255,255,255,0.03) 8px, rgba(255,255,255,0.03) 9px);"></div>
        <div class="relative p-6 pt-8 flex flex-col h-full justify-center">
          <TerminalMockup filename={s.comparison.achLabel} badge={s.comparison.achSteps} badgeColor="text-proof">
            <pre><code><span class="text-proof-light">let</span> secret <span class="text-text-muted">=</span> <span class="text-warn">0p12345</span>
<span class="text-proof-light">let</span> blinding <span class="text-text-muted">=</span> <span class="text-warn">0p98765</span>

<span class="text-proof font-bold">prove</span> <span class="text-text-muted">&#123;</span>
    <span class="text-info">witness</span> secret
    <span class="text-info">witness</span> blinding
    <span class="text-valid">public</span> commitment
    <span class="text-proof-light">let</span> cm <span class="text-text-muted">=</span> <span class="text-info">poseidon</span>(secret, blinding)
    <span class="text-info">assert_eq</span>(cm, commitment)
<span class="text-text-muted">&#125;</span>

<span class="text-text-muted">// Proof generated + verified (Groth16)</span></code></pre>
          </TerminalMockup>

          <div class="mt-4">
          <TerminalMockup filename="terminal" badge="output" badgeColor="text-valid">
            <pre><code><span class="text-valid">$</span> ach run commitment.ach

<span class="text-valid">Proof generated</span> <span class="text-text-muted">(Groth16, 855 bytes)</span>
<span class="text-valid">Proof verified</span> <span class="text-text-muted">— 361 constraints</span></code></pre>
          </TerminalMockup>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════ -->
  <!-- STATS BAR                                                 -->
  <!-- ══════════════════════════════════════════════════════════ -->
  <div class="border-b border-subtle/77 px-8 py-8 relative">
    <div class="grid-dot absolute -bottom-[3px] -left-[3px] z-10"></div>
    <div class="grid-dot absolute -bottom-[3px] -right-[3px] z-10"></div>
    <div class="reveal flex flex-wrap justify-center gap-6 sm:gap-10">
      <div class="text-center">
        <span class="block text-2xl sm:text-3xl font-bold text-text-primary">1,300+</span>
        <span class="text-xs text-text-muted uppercase tracking-wider">tests</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl sm:text-3xl font-bold text-text-primary">2</span>
        <span class="text-xs text-text-muted uppercase tracking-wider">proof backends</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl sm:text-3xl font-bold text-text-primary">43</span>
        <span class="text-xs text-text-muted uppercase tracking-wider">natives</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl sm:text-3xl font-bold text-text-primary">0</span>
        <span class="text-xs text-text-muted uppercase tracking-wider">JS deps</span>
      </div>
    </div>
  </div>

</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // -- Feature nav: scroll-driven active tab --
  const featureTabs = document.querySelectorAll('.feature-tab');
  const featureSections = document.querySelectorAll('[id^="feat-"]');
  const activeClass = 'text-proof-light';
  const borderClass = 'border-b-2';
  const borderColorClass = 'border-proof';

  function setActiveTab(id) {
    featureTabs.forEach((tab) => {
      const isActive = tab.getAttribute('data-target') === id;
      tab.classList.toggle(activeClass, isActive);
      tab.classList.toggle(borderClass, isActive);
      tab.classList.toggle(borderColorClass, isActive);
      if (isActive) {
        tab.classList.remove('text-text-muted');
      } else {
        tab.classList.add('text-text-muted');
      }
    });
  }

  const featureObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActiveTab(entry.target.id);
        }
      });
    },
    { rootMargin: '-50% 0px -50% 0px' }
  );
  featureSections.forEach((section) => featureObserver.observe(section));

  // Smooth scroll on tab click (offset for sticky elements)
  featureTabs.forEach((tab) => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById(tab.getAttribute('data-target'));
      if (target) {
        const navHeight = document.getElementById('feature-nav').offsetHeight;
        const stickyHeader = document.querySelector('.sticky.top-0');
        const headerHeight = stickyHeader ? stickyHeader.offsetHeight : 0;
        const offset = headerHeight + navHeight + 4;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
</script>
