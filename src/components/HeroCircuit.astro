<script>
  import { gsap } from 'gsap';

  function initHeroCircuit() {
    const svg = document.getElementById('hero-svg');
    if (!svg) return;

    // -- Chip pulse (glow on nodes) --
    const chips = svg.querySelectorAll('.chip');
    chips.forEach((chip, i) => {
      gsap.to(chip, {
        opacity: 0.6,
        duration: 2 + i * 0.5,
        repeat: -1,
        yoyo: true,
        ease: 'power1.inOut',
        delay: i * 1.2,
      });
    });

    // -- Wire current flow (opacity pulse per group) --
    const wireGroups = svg.querySelectorAll('.wire-group');
    wireGroups.forEach((group, gi) => {
      const wires = group.querySelectorAll('path');
      wires.forEach((wire, wi) => {
        gsap.fromTo(wire,
          { opacity: 0.4 },
          {
            opacity: 1,
            duration: 1.5,
            repeat: -1,
            yoyo: true,
            ease: 'power1.inOut',
            delay: wi * 0.08 + gi * 1.5,
          }
        );
      });
    });
  }

  // Run after DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroCircuit);
  } else {
    initHeroCircuit();
  }
</script>
