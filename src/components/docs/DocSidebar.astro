---
import type { SidebarConfig } from '../../data/docs-sidebar';
import { getLabel } from '../../data/docs-sidebar';

interface Props {
  sidebar: SidebarConfig;
  currentSlug: string;
  locale: string;
  baseUrl: string;
}

const { sidebar, currentSlug, locale, baseUrl } = Astro.props;
---

<nav class="hidden md:block w-[260px] shrink-0 border-r border-subtle/30">
  <div class="sticky top-[92px] max-h-[calc(100vh-92px)] overflow-y-auto py-6 pl-6 pr-4 doc-scroll">
    {sidebar.map((group, gi) => {
      const hasActive = group.items.some(i => i.slug === currentSlug);
      const disclosureId = `sidebar-group-${gi}`;
      return (
        <div class:list={['pb-4', gi > 0 && 'pt-4 border-t border-subtle/20']}>
          <button
            command="--toggle"
            commandfor={disclosureId}
            type="button"
            class="flex items-center gap-1.5 w-full text-left text-[13px] font-bold text-text-primary pb-2 cursor-pointer select-none hover:text-proof-light transition-colors"
          >
            {getLabel(group, locale)}
          </button>
          <el-disclosure id={disclosureId} hidden={!hasActive ? true : undefined} data-group={gi}>
            <ul class="space-y-0.5">
              {group.items.map(item => {
                const isActive = item.slug === currentSlug;
                return (
                  <li>
                    <a
                      href={`${baseUrl}${item.slug}`}
                      class:list={[
                        'block py-1 text-[13.5px] transition-colors duration-150',
                        isActive
                          ? 'text-proof-light font-medium'
                          : 'text-text-muted hover:text-text-primary',
                      ]}
                    >
                      {getLabel(item, locale)}
                    </a>
                  </li>
                );
              })}
            </ul>
          </el-disclosure>
        </div>
      );
    })}
  </div>
</nav>

<script>
  const STORAGE_KEY = 'docs-sidebar-state';

  function readState(): Record<string, boolean> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch { return {}; }
  }

  function init() {
    const disclosures = document.querySelectorAll<HTMLElement>('el-disclosure[data-group]');
    const saved = readState();

    // Restore saved state (active group stays open regardless)
    disclosures.forEach(el => {
      const key = el.dataset.group!;
      if (key in saved) {
        if (saved[key] && el.hidden) el.removeAttribute('hidden');
        else if (!saved[key] && !el.hidden) el.setAttribute('hidden', '');
      }
    });

    // Listen for toggle events to persist state
    disclosures.forEach(el => {
      el.addEventListener('toggle', () => {
        const state = readState();
        state[el.dataset.group!] = !el.hidden;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      });
    });
  }

  if (customElements.get('el-disclosure')) {
    init();
  } else {
    window.addEventListener('elements:ready', init);
  }
</script>
