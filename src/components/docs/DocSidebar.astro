---
import type { SidebarConfig } from '../../data/docs-sidebar';
import { getLabel } from '../../data/docs-sidebar';

interface Props {
  sidebar: SidebarConfig;
  currentSlug: string;
  locale: string;
  baseUrl: string;
}

const { sidebar, currentSlug, locale, baseUrl } = Astro.props;
---

<nav class="hidden md:block w-[260px] shrink-0 border-r border-subtle/30">
  <div class="sticky top-[92px] max-h-[calc(100vh-92px)] overflow-y-auto py-6 pl-6 pr-4 doc-scroll">
    {sidebar.map((group, gi) => {
      const hasActive = group.items.some(i => i.slug === currentSlug);
      const disclosureId = `sidebar-group-${gi}`;
      return (
        <div class:list={['pb-4', gi > 0 && 'pt-4 border-t border-subtle/20']}>
          <button
            command={hasActive ? undefined : '--toggle'}
            commandfor={hasActive ? undefined : disclosureId}
            type="button"
            class="flex items-center gap-1.5 w-full text-left text-[13px] font-bold text-text-primary pb-2 cursor-pointer select-none hover:text-proof-light transition-colors"
          >
            {getLabel(group, locale)}
          </button>
          <el-disclosure id={disclosureId} hidden={!hasActive ? true : undefined}>
            <ul class="space-y-0.5">
              {group.items.map(item => {
                const isActive = item.slug === currentSlug;
                return (
                  <li>
                    <a
                      href={`${baseUrl}${item.slug}`}
                      class:list={[
                        'block py-1 text-[13.5px] transition-colors duration-150',
                        isActive
                          ? 'text-proof-light font-medium'
                          : 'text-text-muted hover:text-text-primary',
                      ]}
                    >
                      {getLabel(item, locale)}
                    </a>
                  </li>
                );
              })}
            </ul>
          </el-disclosure>
        </div>
      );
    })}
  </div>
</nav>
