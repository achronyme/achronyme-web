---
import type { SidebarConfig } from '../../data/docs-sidebar';
import { getLabel } from '../../data/docs-sidebar';

interface Props {
  sidebar: SidebarConfig;
  currentSlug: string;
  locale: string;
  baseUrl: string;
}

const { sidebar, currentSlug, locale, baseUrl } = Astro.props;
---

<nav class="hidden md:block w-[260px] shrink-0 border-r border-subtle/40">
  <div class="sticky top-[92px] max-h-[calc(100vh-92px)] overflow-y-auto py-6 pl-6 pr-4 doc-scroll">
    {sidebar.map(group => {
      const hasActive = group.items.some(i => i.slug === currentSlug);
      return (
        <details open={hasActive} class="mb-5 group">
          <summary class="flex items-center justify-between cursor-pointer text-[11px] uppercase tracking-[0.08em] text-text-muted/80 font-medium py-1.5 select-none hover:text-text-secondary transition-colors list-none [&::-webkit-details-marker]:hidden">
            <span>{getLabel(group, locale)}</span>
            <svg class="w-3 h-3 opacity-50 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </summary>
          <ul class="mt-1.5 ml-0.5 border-l border-subtle/30 space-y-px">
            {group.items.map(item => {
              const isActive = item.slug === currentSlug;
              return (
                <li>
                  <a
                    href={`${baseUrl}${item.slug}`}
                    class:list={[
                      'block py-1.5 pl-3 text-[13px] transition-colors duration-150 rounded-r-sm',
                      isActive
                        ? 'text-proof-light border-l-2 border-proof -ml-px bg-proof/5 font-medium'
                        : 'text-text-muted hover:text-text-secondary',
                    ]}
                  >
                    {getLabel(item, locale)}
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      );
    })}
  </div>
</nav>
