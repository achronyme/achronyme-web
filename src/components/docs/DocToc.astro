---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  label: string;
}

const { headings, label } = Astro.props;
const filtered = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <aside class="hidden xl:block w-[220px] shrink-0 border-l border-subtle/30">
    <nav class="sticky top-[92px] max-h-[calc(100vh-92px)] overflow-y-auto py-8 pl-5 pr-4 doc-scroll">
      <p class="flex items-center gap-1.5 text-sm text-text-secondary font-semibold mb-4">
        <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />
        </svg>
        {label}
      </p>
      <ul class="space-y-0.5" id="toc-list">
        {filtered.map(h => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'toc-link block py-1.5 text-sm leading-snug transition-all duration-150',
                'text-text-muted hover:text-text-primary',
                h.depth === 3 ? 'pl-3' : '',
              ]}
              data-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script>
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  if (tocLinks.length > 0) {
    const slugs = Array.from(tocLinks).map(a => a.dataset.slug!);
    const headings = slugs.map(s => document.getElementById(s)).filter(Boolean) as HTMLElement[];

    const activate = (slug: string) => {
      tocLinks.forEach(a => {
        const isActive = a.dataset.slug === slug;
        a.style.color = isActive ? 'var(--color-text-primary)' : '';
        a.style.fontWeight = isActive ? '600' : '';
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activate(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '-80px 0px -75% 0px' }
    );

    headings.forEach(h => observer.observe(h));
  }
</script>
