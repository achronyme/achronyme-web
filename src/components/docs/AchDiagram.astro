---
/**
 * Build-time SVG diagram wrapper.
 *
 * Receives a fully-rendered SVG string from the @achronyme/achdiagrams library
 * (rendered at Astro build time, not in the browser). The component just
 * styles the surrounding panel and forwards a11y metadata.
 */
interface Props {
  svg: string;
  ariaLabel?: string;
  align?: 'left' | 'center';
}

const { svg, ariaLabel, align = 'center' } = Astro.props;
---

<div class="ach-diagram" role="figure" aria-label={ariaLabel} data-align={align}>
  <Fragment set:html={svg} />
</div>

<style>
  .ach-diagram {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--ach-diag-panel-bg, #111114);
    border: 1px solid var(--ach-diag-panel-border, #1f1f24);
    border-radius: 12px;
    /* Scroll in both axes when the SVG is bigger than the panel — vertical
       for tall TB pipelines, horizontal for wide LR overviews. */
    overflow: auto;
    max-height: 80vh;
  }

  .ach-diagram :global(svg) {
    display: block;
    margin: 0 auto;
    /* Stretch up to fill the panel when the natural SVG is narrower
       (no more wasted horizontal margins on tall+narrow diagrams), but
       never shrink below the natural width — wider diagrams overflow into
       horizontal scroll instead of squashing their nodes. */
    width: 100%;
    min-width: max-content;
    height: auto;
  }

  @media (prefers-color-scheme: light) {
    .ach-diagram {
      background: var(--ach-diag-panel-bg, #ffffff);
      border-color: var(--ach-diag-panel-border, #e4e4e7);
    }
  }
</style>
