---
/**
 * Build-time SVG diagram wrapper.
 *
 * Receives a fully-rendered SVG string from the @achronyme/achdiagrams library
 * (rendered at Astro build time, not in the browser). The component just
 * styles the surrounding panel and forwards a11y metadata.
 *
 * Sizing policy:
 *  - The SVG keeps its natural width and height — never rescaled.
 *  - The panel grows vertically to fit (no `max-height`, no vertical scroll).
 *  - When the SVG is wider than the panel, a thin horizontal scrollbar appears
 *    styled with the same tokens as `.doc-scroll` and `.doc-prose pre` in
 *    `src/styles/global.css`.
 */
interface Props {
  svg: string;
  ariaLabel?: string;
  align?: 'left' | 'center';
}

const { svg, ariaLabel, align = 'center' } = Astro.props;
---

<div class="ach-diagram" role="figure" aria-label={ariaLabel} data-align={align}>
  <Fragment set:html={svg} />
</div>

<style>
  .ach-diagram {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--ach-diag-panel-bg, #111114);
    border: 1px solid var(--ach-diag-panel-border, #1f1f24);
    border-radius: 12px;
    /* Horizontal scroll only — let the panel grow to whatever vertical
       space the SVG needs. */
    overflow-x: auto;
    overflow-y: visible;
    /* Firefox */
    scrollbar-width: thin;
    scrollbar-color: var(--color-subtle, #303038) transparent;
  }

  .ach-diagram :global(svg) {
    /* Natural size — no rescaling. The SVG carries its own width/height
       attributes from the layout engine. Centering is done with auto
       margins so the diagram sits in the middle when it's narrower than
       the panel; wider diagrams overflow into the horizontal scroll. */
    display: block;
    margin: 0 auto;
  }

  .ach-diagram[data-align='left'] :global(svg) {
    margin-left: 0;
    margin-right: auto;
  }

  /* Webkit scrollbar — matches `.doc-scroll` / `.doc-prose pre`. */
  .ach-diagram::-webkit-scrollbar {
    height: 6px;
  }
  .ach-diagram::-webkit-scrollbar-track {
    background: transparent;
    margin: 0 10px;
  }
  .ach-diagram::-webkit-scrollbar-thumb {
    background: var(--color-subtle, #303038);
    border-radius: 3px;
  }
  .ach-diagram::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted, #A6A6BC);
  }

  @media (prefers-color-scheme: light) {
    .ach-diagram {
      background: var(--ach-diag-panel-bg, #ffffff);
      border-color: var(--ach-diag-panel-border, #e4e4e7);
    }
  }
</style>
