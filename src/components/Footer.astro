---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = t(locale);
const year = new Date().getFullYear();
---

<footer class="bg-surface/30 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <span class="text-lg font-bold text-text-primary">achronyme</span>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-text-muted">{s.footer.tagline}</p>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-widest text-text-secondary">{s.footer.resources}</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/achronyme/achronyme" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">{s.footer.github}</a></li>
          <li><a href="https://github.com/achronyme/achronyme/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">{s.footer.releases}</a></li>
          <li><a href="https://github.com/achronyme/achronyme-editor" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">{s.footer.vsCode}</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h4 class="mb-4 text-xs font-semibold uppercase tracking-widest text-text-secondary">{s.footer.community}</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/achronyme/achronyme/discussions" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">{s.footer.discussions}</a></li>
          <li><a href="https://github.com/achronyme/achronyme/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">{s.footer.issues}</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider + copyright -->
    <div class="border-t border-subtle/30 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="text-xs text-text-muted">&copy; {year} Achronyme Contributors</span>
      <div class="flex items-center gap-4 text-xs text-text-muted">
        <span>{s.footer.builtWith}</span>
        <span>{s.footer.license}</span>
      </div>
    </div>
  </div>
</footer>
