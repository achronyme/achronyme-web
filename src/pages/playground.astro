---
// Standalone playground page — mini-IDE with file system
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Achronyme Playground — Write and run ZK programs in your browser" />
  <title>Playground — Achronyme</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style is:global>
    :root {
      --bg-titlebar: #1e1e1e;
      --bg-activitybar: #181818;
      --bg-sidebar: #1e1e1e;
      --bg-editor: #1e1e1e;
      --bg-terminal: #181818;
      --bg-statusbar: #7c3aed;
      --bg-active-tab: #1e1e1e;
      --bg-inactive-tab: #2d2d2d;
      --bg-tab-row: #181818;
      --bg-breadcrumb: #1e1e1e;
      --bg-input: #313131;
      --border: #2b2b2b;
      --border-active: #414141;
      --text-primary: #cccccc;
      --text-secondary: #969696;
      --text-muted: #5a5a5a;
      --text-bright: #e8e8e8;
      --accent: #a855f7;
      --accent-dim: #7c3aed;
      --focus: rgba(168, 85, 247, 0.4);
      --green: #4ec9b0;
      --green-bright: #73d0b5;
      --red: #f14c4c;
      --yellow: #cca700;
      --blue: #569cd6;
      --orange: #ce9178;
      --font-mono: "JetBrains Mono Variable", "JetBrains Mono", "Cascadia Code", "Fira Code", "Consolas", monospace;
      --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; background: var(--bg-editor); color: var(--text-primary); font-family: var(--font-mono); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    ::selection { background: rgba(168, 85, 247, 0.35); }

    /* ═══ SHELL GRID ═══ */
    .shell {
      display: grid;
      grid-template-rows: 30px 1fr 22px;
      grid-template-columns: 48px 240px 1fr;
      height: 100vh; width: 100vw;
    }

    /* ═══ TITLE BAR ═══ */
    .titlebar {
      grid-column: 1 / -1;
      background: var(--bg-titlebar);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      position: relative;
      -webkit-app-region: drag;
    }
    .titlebar-left { position: absolute; left: 12px; display: flex; align-items: center; gap: 8px; -webkit-app-region: no-drag; }
    .window-dots { display: flex; gap: 8px; }
    .window-dots span { width: 12px; height: 12px; border-radius: 50%; }
    .dot-close { background: #ff5f57; } .dot-min { background: #ffbd2e; } .dot-max { background: #28c840; }
    .titlebar-center { font-family: var(--font-sans); font-size: 11px; color: var(--text-secondary); letter-spacing: 0.01em; }
    .titlebar-center em { font-style: normal; color: var(--text-primary); font-weight: 500; }
    .titlebar-right { position: absolute; right: 12px; display: flex; gap: 14px; -webkit-app-region: no-drag; }
    .titlebar-right a { font-family: var(--font-sans); font-size: 11px; color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
    .titlebar-right a:hover { color: var(--text-primary); }

    /* ═══ ACTIVITY BAR ═══ */
    .activitybar {
      grid-row: 2 / 3;
      background: var(--bg-activitybar);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; align-items: center;
      padding-top: 4px; gap: 2px;
    }
    .activity-icon {
      width: 48px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; border-left: 2px solid transparent;
      color: var(--text-muted); transition: color 0.15s;
    }
    .activity-icon:hover { color: var(--text-primary); }
    .activity-icon.active { color: var(--text-primary); border-left-color: var(--text-primary); }
    .activity-icon svg { width: 22px; height: 22px; }
    .activity-spacer { flex: 1; }

    /* ═══ SIDEBAR ═══ */
    .sidebar {
      grid-row: 2 / 3;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; overflow: hidden;
      position: relative; transition: width 0.15s, border 0.15s, opacity 0.15s;
    }
    .sidebar-title {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 8px 0 20px; height: 35px;
      font-family: var(--font-sans); font-size: 11px; font-weight: 400;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-secondary);
    }
    .sidebar-actions { display: flex; gap: 2px; opacity: 0; transition: opacity 0.15s; }
    .sidebar:hover .sidebar-actions { opacity: 1; }
    .sidebar-btn {
      width: 22px; height: 22px;
      display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-secondary);
      cursor: pointer; border-radius: 3px;
    }
    .sidebar-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }
    .sidebar-section {
      display: flex; align-items: center; gap: 2px;
      padding: 0 8px; height: 22px;
      font-family: var(--font-sans); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-primary);
      cursor: pointer; user-select: none;
      background: #252526;
    }
    .sidebar-section:hover { background: #2a2d2e; }
    .sidebar-section svg { width: 9px; height: 9px; color: var(--text-secondary); transition: transform 0.1s; }
    .sidebar-section.collapsed svg { transform: rotate(-90deg); }
    .file-tree { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 0; }
    .file-row {
      display: flex; align-items: center; gap: 6px;
      padding: 0 8px; height: 22px;
      font-size: 13px; color: var(--text-primary);
      cursor: pointer; user-select: none;
      outline: 1px solid transparent; outline-offset: -1px;
    }
    .file-row:hover { background: #2a2d2e; }
    .file-row.active { background: #04395e; color: #fff; outline-color: #007fd4; }
    .file-row.focused { background: #04395e; outline-color: #007fd4; color: #fff; }
    .file-row.dir-row { color: var(--text-primary); font-weight: 400; }
    .file-icon { display: flex; align-items: center; flex-shrink: 0; width: 16px; height: 16px; }
    .file-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; line-height: 22px; }
    .tree-chevron {
      width: 16px; height: 16px; display: flex; align-items: center; justify-content: center;
      color: var(--text-secondary); transition: transform 0.1s; flex-shrink: 0;
    }
    .tree-chevron.expanded { transform: rotate(90deg); }
    .tree-children { }

    /* Inline folder action buttons (visible on hover) */
    .dir-actions {
      margin-left: auto; display: flex; gap: 0; opacity: 0; flex-shrink: 0;
      transition: opacity 0.1s;
    }
    .dir-row:hover .dir-actions { opacity: 1; }
    .dir-action-btn {
      width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-muted); cursor: pointer; border-radius: 3px;
      padding: 0;
    }
    .dir-action-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }

    /* Drag-and-drop: drop target highlight on dirs */
    .file-row.drop-target { background: rgba(168, 85, 247, 0.15); outline: 1px solid var(--accent); outline-offset: -1px; }
    .file-row.dragging { opacity: 0.4; }
    .file-tree.drop-target-root { background: rgba(168, 85, 247, 0.06); }
    .file-row[draggable="true"] { cursor: grab; }
    .file-row[draggable="true"]:active { cursor: grabbing; }
    /* Inline rename input */
    .file-row .rename-input {
      flex: 1; min-width: 0; height: 18px;
      font-family: var(--font-mono); font-size: 13px;
      background: var(--bg-input); color: var(--text-primary);
      border: 1px solid var(--accent); border-radius: 2px;
      padding: 0 4px; outline: none;
    }

    .sidebar-footer {
      padding: 8px; border-top: 1px solid var(--border);
      display: flex; flex-direction: column; gap: 6px;
    }
    .footer-actions {
      display: flex; gap: 4px;
    }
    .footer-btn {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: 4px;
      font-family: var(--font-sans); font-size: 11px;
      background: var(--bg-input); color: var(--text-secondary);
      border: 1px solid var(--border); border-radius: 3px;
      padding: 3px 6px; cursor: pointer;
    }
    .footer-btn:hover { color: var(--text-primary); border-color: var(--text-muted); }
    .template-select {
      width: 100%; font-family: var(--font-sans); font-size: 11px;
      background: var(--bg-input); color: var(--text-primary);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 4px 8px; cursor: pointer; outline: none;
    }
    .template-select:hover, .template-select:focus { border-color: var(--accent); }
    .template-select option { background: var(--bg-input); }

    /* ═══ EDITOR GROUPS ═══ */
    .editor-groups-wrapper { flex: 1; display: flex; overflow: hidden; min-height: 100px; min-width: 0; }
    .editor-group { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
    .editor-group.active .group-tabbar { border-top: 1px solid var(--accent); }
    .group-split-handle { width: 4px; cursor: col-resize; flex-shrink: 0; position: relative; }
    .group-split-handle::after { content: ""; position: absolute; top: 0; bottom: 0; left: 1px; width: 2px; background: var(--border); }
    .group-split-handle:hover::after, .group-split-handle.dragging::after { background: var(--accent); }

    /* ═══ TAB BAR (per group) ═══ */
    .group-tabbar {
      background: var(--bg-tab-row);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: stretch; overflow-x: auto;
      flex-shrink: 0; height: 35px; border-top: 1px solid transparent;
    }
    .group-tabbar::-webkit-scrollbar { height: 0; }
    .tab {
      display: flex; align-items: center; gap: 4px;
      padding: 0 3px 0 10px; height: 35px;
      font-size: 13px;
      color: var(--text-muted); background: var(--bg-inactive-tab);
      border-right: 1px solid #1b1b1b;
      cursor: pointer; white-space: nowrap; user-select: none;
      position: relative; min-width: 0; max-width: 160px;
    }
    .tab.active {
      color: var(--text-bright); background: var(--bg-active-tab);
    }
    .tab.active::after {
      content: ""; position: absolute; top: 0; left: 0; right: 0;
      height: 1px; background: var(--accent);
    }
    .tab.active::before {
      content: ""; position: absolute; bottom: 0; left: 0; right: 0;
      height: 1px; background: var(--bg-active-tab);
    }
    .tab:hover:not(.active) { background: #2a2a2a; }
    .tab-icon { display: flex; align-items: center; flex-shrink: 0; }
    .tab-icon svg { width: 14px; height: 14px; }
    .tab-label { font-size: 13px; overflow: hidden; text-overflow: ellipsis; }
    .tab-dot {
      width: 9px; height: 9px; min-width: 9px; border-radius: 50%;
      flex-shrink: 0; display: none;
    }
    .tab.modified .tab-dot { display: flex; background: var(--text-primary); }
    .tab.modified .tab-close { display: none; }
    .tab.modified:hover .tab-dot { display: none; }
    .tab.modified:hover .tab-close { display: flex; }
    .tab-close {
      width: 20px; height: 20px; min-width: 20px;
      display: flex; align-items: center; justify-content: center;
      border: none; background: none; color: var(--text-muted);
      cursor: pointer; border-radius: 3px;
      opacity: 0; flex-shrink: 0;
    }
    .tab:hover .tab-close, .tab.active .tab-close { opacity: 1; }
    .tab-close:hover { background: rgba(255,255,255,0.1); color: var(--text-primary); }
    .tab-actions {
      margin-left: auto; display: flex; align-items: center; gap: 8px;
      padding: 0 10px; flex-shrink: 0;
    }
    .run-btn {
      font-family: var(--font-sans); font-size: 11px; font-weight: 600;
      letter-spacing: 0.02em;
      color: #fff; background: var(--accent-dim);
      border: none; border-radius: 3px; padding: 4px 14px;
      cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: background 0.15s;
    }
    .run-btn:hover { background: var(--accent); }
    .run-btn:active { background: #6d28d9; }
    .run-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .run-btn svg { width: 10px; height: 10px; fill: #fff; }
    .tab-action-btn {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-muted); cursor: pointer; border-radius: 3px; flex-shrink: 0;
    }
    .tab-action-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }

    /* ═══ MAIN AREA ═══ */
    .main-area { display: flex; flex-direction: column; overflow: hidden; }

    /* ═══ BREADCRUMB (per group) ═══ */
    .group-breadcrumb {
      height: 22px; padding: 0 12px;
      display: flex; align-items: center;
      font-family: var(--font-sans); font-size: 11px; color: var(--text-muted);
      background: var(--bg-breadcrumb); border-bottom: 1px solid var(--border);
      gap: 4px; flex-shrink: 0;
    }
    .breadcrumb-sep { color: var(--text-muted); font-size: 10px; }
    .breadcrumb-item { color: var(--text-secondary); }
    .breadcrumb-item:last-child { color: var(--text-primary); }

    /* ═══ LAYOUT SYSTEM ═══ */
    .layout-root { flex: 1; display: flex; overflow: hidden; position: relative; }
    .layout-center { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
    .layout-handle-h {
      width: 4px; cursor: col-resize; flex-shrink: 0; position: relative;
    }
    .layout-handle-h::after {
      content: ""; position: absolute; top: 0; bottom: 0; left: 1px;
      width: 2px; background: var(--border);
    }
    .layout-handle-h:hover::after, .layout-handle-h.dragging::after { background: var(--accent); }
    .layout-handle-v {
      height: 4px; cursor: row-resize; flex-shrink: 0; position: relative;
    }
    .layout-handle-v::after {
      content: ""; position: absolute; left: 0; right: 0; top: 1px;
      height: 2px; background: var(--border);
    }
    .layout-handle-v:hover::after, .layout-handle-v.dragging::after { background: var(--accent); }

    /* Drop zones */
    .drop-zones { position: absolute; inset: 0; z-index: 50; display: none; }
    .drop-zones.active { display: block; }
    .drop-zone {
      position: absolute; background: rgba(168, 85, 247, 0.04);
      border: 2px dashed rgba(168, 85, 247, 0.15); transition: all 0.15s;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-sans); font-size: 11px; color: transparent;
      text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;
    }
    .drop-zone.hover { background: rgba(168, 85, 247, 0.12); border-color: var(--accent); color: var(--accent); }
    .drop-zone.left { top: 0; left: 0; bottom: 0; width: 20%; }
    .drop-zone.right { top: 0; right: 0; bottom: 0; width: 20%; }
    .drop-zone.bottom { bottom: 0; left: 20%; right: 20%; height: 25%; }

    .group-editor { flex: 1; overflow: hidden; }
    .group-editor .cm-editor { height: 100%; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; }
    .group-editor .cm-editor .cm-scroller { font-family: var(--font-mono) !important; }
    .group-editor .cm-editor.cm-focused { outline: none; }
    .group-editor .cm-gutters { background: var(--bg-editor); border-right: none; color: var(--text-muted); min-width: 48px; padding-right: 8px; }
    .group-editor .cm-lineNumbers .cm-gutterElement { font-size: 12px; padding: 0; text-align: right; min-width: 32px; }
    .group-editor .cm-activeLineGutter { color: var(--text-secondary); }
    .group-editor .cm-cursor { border-left: 2px solid var(--text-bright); }
    .group-editor .cm-selectionBackground { background: rgba(168, 85, 247, 0.25) !important; }
    .group-editor .cm-activeLine { background: rgba(255,255,255,0.02); }
    .group-editor .cm-matchingBracket { color: var(--text-bright) !important; outline: 1px solid var(--text-muted); background: rgba(255,255,255,0.06); }

    /* ═══ OUTPUT ═══ */
    .output-panel {
      display: flex; flex-direction: column; overflow: hidden;
    }
    .output-header {
      display: flex; align-items: center;
      padding: 0 12px; height: 35px;
      background: var(--bg-terminal);
      border-bottom: 1px solid var(--border); flex-shrink: 0;
      cursor: grab;
    }
    .output-header:active { cursor: grabbing; }
    .output-tabs { display: flex; gap: 0; }
    .output-tab {
      font-family: var(--font-sans); font-size: 12px;
      text-transform: uppercase; letter-spacing: 0.04em;
      color: var(--text-muted); cursor: pointer;
      padding: 8px 12px; border-bottom: 1px solid transparent;
    }
    .output-tab.active { color: var(--text-primary); border-bottom-color: var(--accent); }
    .output-scroll { flex: 1; overflow: auto; background: var(--bg-terminal); padding: 8px 16px; }
    .output-line { font-size: 13px; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
    .output-line.stdout { color: var(--text-primary); }
    .output-line.error { color: var(--red); }
    .output-line.info { color: var(--text-muted); }
    .output-line.timing { color: var(--yellow); font-size: 12px; }
    .output-cursor {
      display: inline-block; width: 7px; height: 14px;
      background: var(--text-primary); animation: blink 1s step-end infinite;
      vertical-align: text-bottom; margin-left: 2px; opacity: 0.7;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* ═══ PROOF PANEL ═══ */
    .proof-empty {
      display: flex; align-items: center; gap: 8px;
      padding: 16px; color: var(--text-muted);
      font-family: var(--font-sans); font-size: 13px;
    }
    .proof-empty code {
      background: rgba(168,85,247,0.12); color: var(--accent);
      padding: 1px 5px; border-radius: 3px; font-size: 12px;
    }
    .proof-artifact {
      border: 1px solid var(--border); border-radius: 6px;
      margin: 8px 12px; overflow: hidden;
    }
    .proof-artifact-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 12px; background: rgba(255,255,255,0.03);
      border-bottom: 1px solid var(--border); cursor: pointer; user-select: none;
    }
    .proof-artifact-header:hover { background: rgba(255,255,255,0.05); }
    .proof-artifact-title {
      font-family: var(--font-sans); font-size: 13px; font-weight: 600;
      color: var(--text-primary); display: flex; align-items: center; gap: 8px;
    }
    .proof-artifact-title .proof-badge {
      font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
      padding: 1px 6px; border-radius: 3px;
      background: rgba(168,85,247,0.15); color: var(--accent);
    }
    .proof-stats {
      display: flex; gap: 16px; font-family: var(--font-sans); font-size: 12px; color: var(--text-muted);
    }
    .proof-stat-val { color: var(--text-primary); font-weight: 600; }
    .proof-downloads {
      display: flex; gap: 4px; padding: 8px 12px;
      flex-wrap: wrap; border-bottom: 1px solid var(--border);
    }
    .proof-dl-btn {
      font-family: var(--font-sans); font-size: 11px; font-weight: 500;
      background: rgba(255,255,255,0.05); color: var(--text-secondary);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 4px 10px; cursor: pointer; display: flex; align-items: center; gap: 4px;
      transition: all 0.15s;
    }
    .proof-dl-btn:hover { background: rgba(168,85,247,0.1); border-color: var(--accent); color: var(--text-primary); }
    .proof-dl-btn svg { width: 12px; height: 12px; }
    .proof-json-preview {
      max-height: 200px; overflow: auto; padding: 8px 12px;
      font-family: var(--font-mono); font-size: 12px; line-height: 1.5;
      color: var(--text-secondary); background: rgba(0,0,0,0.2);
      white-space: pre-wrap; word-break: break-all;
    }
    .proof-section-label {
      padding: 6px 12px; font-family: var(--font-sans); font-size: 11px;
      font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--text-muted); background: rgba(255,255,255,0.02);
      border-bottom: 1px solid var(--border); cursor: pointer; user-select: none;
      display: flex; align-items: center; gap: 6px;
    }
    .proof-section-label:hover { background: rgba(255,255,255,0.04); }
    .proof-section-label svg { width: 8px; height: 8px; color: var(--text-muted); transition: transform 0.1s; }
    .proof-section-label.collapsed svg { transform: rotate(-90deg); }

    /* ═══ STATUS BAR ═══ */
    .statusbar {
      grid-column: 1 / -1;
      background: var(--bg-statusbar);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 10px; font-size: 12px; color: rgba(255,255,255,0.85);
      font-family: var(--font-sans); z-index: 10;
    }
    .statusbar-left, .statusbar-right { display: flex; align-items: center; gap: 14px; }
    .status-item { display: flex; align-items: center; gap: 4px; cursor: default; }
    .status-item a { color: inherit; text-decoration: none; }
    .status-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #4ec9b0; box-shadow: 0 0 4px rgba(78, 201, 176, 0.5);
    }
    .status-dot.loading { background: var(--yellow); animation: pulse 1.2s ease-in-out infinite; }
    .status-dot.error { background: var(--red); }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* ═══ LINT / HOVER / AUTOCOMPLETE ═══ */
    .cm-diagnostic { font-family: var(--font-mono); font-size: 12px; padding: 4px 8px; }
    .cm-diagnostic-error { border-left: 3px solid var(--red); }
    .cm-diagnostic-warning { border-left: 3px solid var(--yellow); }
    .cm-lintRange-error { background: rgba(241, 76, 76, 0.1); text-decoration: wavy underline var(--red); text-underline-offset: 3px; text-decoration-thickness: 1px; }
    .cm-lintRange-warning { background: rgba(204, 167, 0, 0.08); text-decoration: wavy underline var(--yellow); text-underline-offset: 3px; text-decoration-thickness: 1px; }
    .cm-tooltip { background: #252526 !important; border: 1px solid #454545 !important; border-radius: 3px !important; box-shadow: 0 2px 8px rgba(0,0,0,0.36) !important; }
    .ach-hover-tooltip { padding: 8px 12px; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; color: var(--text-primary); max-width: 520px; }
    .ach-hover-code { background: #1a1a1a; border-radius: 3px; padding: 6px 10px; margin: 4px 0; font-size: 13px; color: var(--green); }
    .ach-hover-inline { background: rgba(168, 85, 247, 0.12); border-radius: 3px; padding: 1px 4px; font-size: 12px; color: var(--accent); }
    .cm-tooltip-autocomplete { background: #252526 !important; border: 1px solid #454545 !important; border-radius: 3px !important; }
    .cm-tooltip-autocomplete ul { font-family: var(--font-mono); }
    .cm-tooltip-autocomplete ul li { padding: 2px 8px !important; font-size: 13px; }
    .cm-tooltip-autocomplete ul li[aria-selected] { background: #062f4a !important; color: #fff; }
    .cm-completionIcon { display: none; }

    /* ═══ CONTEXT MENU ═══ */
    .context-menu {
      position: fixed; background: #252526; border: 1px solid #454545;
      border-radius: 4px; padding: 4px 0; z-index: 100;
      min-width: 160px; box-shadow: 0 2px 8px rgba(0,0,0,0.36);
    }
    .context-item {
      padding: 4px 24px; font-family: var(--font-sans); font-size: 13px;
      color: var(--text-primary); cursor: pointer;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .context-item:hover { background: #04395e; }
    .context-item.danger:hover { background: rgba(241, 76, 76, 0.15); color: var(--red); }
    .context-shortcut { font-size: 11px; color: var(--text-muted); font-family: var(--font-sans); }

    /* ═══ COMMAND PALETTE ═══ */
    .cmd-dialog { background: transparent; border: none; padding: 0; max-width: 100vw; max-height: 100vh; width: 100vw; height: 100vh; overflow: visible; }
    .cmd-dialog::backdrop { background: transparent; }
    .cmd-backdrop {
      position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5);
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
    .cmd-backdrop[data-closed] { opacity: 0; }
    .cmd-panel-wrapper {
      position: fixed; top: 0; left: 0; right: 0;
      display: flex; justify-content: center;
      padding-top: min(20vh, 140px);
      pointer-events: none;
    }
    .cmd-palette {
      pointer-events: auto;
      width: 560px; max-width: calc(100vw - 32px); max-height: min(70vh, 480px);
      background: #252526; border: 1px solid #454545; border-radius: 8px;
      box-shadow: 0 16px 70px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 0, 0, 0.1);
      display: flex; flex-direction: column; overflow: hidden;
      transition: opacity 0.12s ease, transform 0.12s ease;
    }
    .cmd-panel-wrapper[data-closed] .cmd-palette,
    .cmd-palette[data-closed] { opacity: 0; transform: scale(0.97) translateY(-8px); }
    .cmd-input-row {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 14px; border-bottom: 1px solid var(--border);
    }
    .cmd-search-icon { flex-shrink: 0; color: var(--text-muted); }
    .cmd-input {
      flex: 1; background: transparent; border: none; outline: none;
      font-family: var(--font-sans); font-size: 14px;
      color: var(--text-bright); caret-color: var(--accent);
    }
    .cmd-input::placeholder { color: var(--text-muted); }
    .cmd-list { flex: 1; overflow-y: auto; padding: 4px 0; }
    .cmd-group-label {
      padding: 8px 14px 4px;
      font-family: var(--font-sans); font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--text-muted); user-select: none;
    }
    .cmd-item {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%; padding: 6px 14px;
      font-family: var(--font-sans); font-size: 13px;
      color: var(--text-primary); background: none; border: none;
      cursor: pointer; text-align: left; gap: 12px; outline: none;
    }
    .cmd-item:hover, .cmd-item:focus { background: #062f4a; color: var(--text-bright); }
    .cmd-item[aria-selected="true"] {
      background: #062f4a; color: var(--text-bright);
      outline: 1px solid rgba(0, 127, 212, 0.4); outline-offset: -1px;
    }
    .cmd-item-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cmd-file-path { font-size: 11px; color: var(--text-muted); margin-left: 8px; }
    .cmd-kbd {
      font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);
      background: rgba(255, 255, 255, 0.06); border: 1px solid var(--border);
      border-radius: 3px; padding: 1px 6px; flex-shrink: 0; line-height: 1.4;
    }
    .cmd-no-results {
      padding: 24px 14px; text-align: center;
      font-family: var(--font-sans); font-size: 13px; color: var(--text-muted);
    }

    /* ═══ SCROLLBARS ═══ */
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(121, 121, 121, 0.3); border-radius: 10px; border: 2px solid transparent; background-clip: padding-box; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(121, 121, 121, 0.5); border: 2px solid transparent; background-clip: padding-box; }
    ::-webkit-scrollbar-corner { background: transparent; }

    /* ═══ SIDEBAR COLLAPSE ═══ */
    .shell.sidebar-collapsed { grid-template-columns: 48px 0px 1fr; }
    .shell.sidebar-collapsed .sidebar { border-right: none; overflow: hidden; opacity: 0; pointer-events: none; }
    .shell.sidebar-collapsed .sidebar-resize { display: none; }

    /* ═══ SIDEBAR RESIZE HANDLE ═══ */
    .sidebar-resize {
      position: absolute; right: -2px; top: 0; bottom: 0; width: 5px;
      cursor: col-resize; z-index: 5;
    }
    .sidebar-resize::after {
      content: ""; position: absolute; top: 0; bottom: 0; left: 2px;
      width: 1px; background: transparent; transition: background 0.15s;
    }
    .sidebar-resize:hover::after, .sidebar-resize.dragging::after {
      background: var(--accent);
    }

    /* ═══ WELCOME SCREEN ═══ */
    .group-welcome {
      flex: 1; display: flex; align-items: center; justify-content: center;
      background: var(--bg-editor); color: var(--text-secondary);
      font-family: var(--font-sans); user-select: none;
    }
    .welcome-content { max-width: 360px; padding: 40px; }
    .welcome-logo { font-size: 48px; color: var(--accent); margin-bottom: 8px; line-height: 1; }
    .welcome-content h2 { font-size: 22px; font-weight: 300; color: var(--text-primary); margin-bottom: 2px; letter-spacing: -0.02em; }
    .welcome-subtitle { font-size: 12px; color: var(--text-muted); margin-bottom: 28px; }
    .welcome-section { margin-bottom: 20px; }
    .welcome-section h3 {
      font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--text-muted); margin-bottom: 6px; font-weight: 600;
    }
    .welcome-item { font-size: 13px; color: var(--accent); cursor: pointer; padding: 2px 0; }
    .welcome-item:hover { color: var(--text-primary); text-decoration: underline; }
    .welcome-shortcut {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px; padding: 2px 0; color: var(--text-secondary);
    }
    .welcome-shortcut kbd {
      font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);
      background: var(--bg-input); border: 1px solid var(--border);
      border-radius: 3px; padding: 1px 6px;
    }
    .welcome-link { display: block; font-size: 13px; color: var(--accent); text-decoration: none; padding: 2px 0; }
    .welcome-link:hover { color: var(--text-primary); text-decoration: underline; }

    /* ═══ PANEL ACTIONS ═══ */
    .panel-actions {
      margin-left: auto; display: flex; align-items: center; gap: 2px;
    }
    .panel-action-btn {
      width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-muted); cursor: pointer; border-radius: 3px;
    }
    .panel-action-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }

    /* ═══ DOCS GROUP (in editor-groups-wrapper) ═══ */
    .docs-group {
      flex: 1; display: flex; flex-direction: column;
      overflow: hidden; min-width: 0; background: #13131a;
    }
    .docs-group-header {
      height: 35px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 4px 0 12px; border-bottom: 1px solid var(--border);
      flex-shrink: 0; background: var(--bg-tab-row);
      cursor: grab;
    }
    .docs-group-header:active { cursor: grabbing; }
    .docs-nav-btn {
      display: flex; align-items: center; gap: 6px;
      font-family: var(--font-sans); font-size: 13px; color: var(--text-primary);
      background: none; border: none; cursor: pointer; padding: 2px 8px;
      border-radius: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .docs-nav-btn:hover { background: rgba(255,255,255,0.08); }
    .docs-nav-btn svg { width: 10px; height: 10px; color: var(--text-muted); flex-shrink: 0; }
    .docs-group-actions { display: flex; gap: 2px; flex-shrink: 0; }
    .docs-nav-dropdown {
      position: fixed; z-index: 100;
      background: #252526; border: 1px solid var(--border);
      border-radius: 4px; overflow-y: auto;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      min-width: 240px; padding: 4px 0;
      display: none;
    }
    .docs-nav-dropdown.open { display: block; }
    .docs-nav-group-label {
      padding: 8px 12px 4px; font-family: var(--font-sans);
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.04em; color: var(--text-muted);
    }
    .docs-nav-item {
      padding: 3px 12px 3px 20px; font-family: var(--font-sans);
      font-size: 13px; color: var(--text-secondary); cursor: pointer;
    }
    .docs-nav-item:hover { background: #2a2d2e; color: var(--text-primary); }
    .docs-nav-item.active { color: var(--accent); }
    .docs-group-content { flex: 1; overflow: auto; }

    /* ═══ TAB DRAG & DROP ═══ */
    .tab[draggable="true"] { cursor: grab; }
    .tab[draggable="true"]:active { cursor: grabbing; opacity: 0.6; }
    .drag-over-center { outline: 2px solid var(--accent); outline-offset: -2px; }
    .drag-over-left { box-shadow: inset 4px 0 0 var(--accent); }
    .drag-over-right { box-shadow: inset -4px 0 0 var(--accent); }

    @media (max-width: 900px) {
      .shell { grid-template-columns: 1fr; }
      .activitybar, .sidebar { display: none; }
      .editor-output-split { flex-direction: column; }
      .output-panel { width: 100%; min-width: 0; }
      .resize-handle, .group-split-handle { display: none; }
      .editor-group:not(.active), .docs-group { display: none; }
    }
  </style>
</head>

<body>
  <div class="shell">
    <!-- TITLE BAR -->
    <div class="titlebar">
      <div class="titlebar-left">
        <div class="window-dots"><span class="dot-close"></span><span class="dot-min"></span><span class="dot-max"></span></div>
      </div>
      <div class="titlebar-center"><em>Achronyme</em> &mdash; Playground</div>
      <div class="titlebar-right">
        <a href="/docs/getting-started/introduction">Docs</a>
        <a href="https://github.com/achronyme/achronyme" target="_blank">GitHub</a>
        <a href="/">Home</a>
      </div>
    </div>

    <!-- ACTIVITY BAR -->
    <div class="activitybar">
      <div class="activity-icon active" title="Explorer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7v13h18V7M3 7l4-4h6l2 2h7v2"/><path d="M8 14h8M8 11h5"/></svg>
      </div>
      <div class="activity-icon" title="Run" id="activity-run">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 3l14 9-14 9V3z"/></svg>
      </div>
      <div class="activity-icon" title="Documentation" id="activity-docs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      </div>
      <div class="activity-spacer"></div>
      <div class="activity-icon" title="Settings" style="margin-bottom: 4px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v3M12 20v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M1 12h3M20 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-title">
        <span>Explorer</span>
        <div class="sidebar-actions">
          <button class="sidebar-btn" id="new-file-btn" title="New File">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M8 3v10M3 8h10"/></svg>
          </button>
          <button class="sidebar-btn" id="new-folder-btn" title="New Folder">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M1 4h5l1.5 1.5H15V13H1V4z"/><path d="M8 7.5v3M6.5 9h3"/></svg>
          </button>
        </div>
      </div>
      <div class="sidebar-section" id="section-files">
        <svg viewBox="0 0 10 10"><path d="M3 2L7 5L3 8" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>
        <span id="project-name">Project</span>
      </div>
      <div class="file-tree" id="file-tree"></div>
      <div class="sidebar-resize" id="sidebar-resize"></div>
      <div class="sidebar-footer">
        <select class="template-select" id="template-select">
          <option value="">ach init --template</option>
          <option value="circuit">circuit</option>
          <option value="vm">vm</option>
          <option value="prove">prove</option>
        </select>
        <div class="footer-actions">
          <button class="footer-btn" id="export-btn" title="Export project as JSON">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 10v3h10v-3"/><path d="M8 2v8M5 7l3 3 3-3"/></svg>
            Export
          </button>
          <button class="footer-btn" id="import-btn" title="Import project from JSON">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 10v3h10v-3"/><path d="M8 10V2M5 5l3-3 3 3"/></svg>
            Import
          </button>
          <input type="file" id="import-input" accept=".json" style="display:none" />
        </div>
      </div>
    </div>

    <!-- MAIN AREA -->
    <div class="main-area">
      <div class="layout-root" id="layout-root">
        <div class="editor-groups-wrapper" id="editor-groups-wrapper">
          <!-- Editor groups created dynamically -->
        </div>
        <div class="output-panel" id="output-panel">
          <div class="output-header" draggable="true" id="output-header">
            <div class="output-tabs">
              <span class="output-tab active" data-tab="terminal">Terminal</span>
              <span class="output-tab" data-tab="proof">Proof</span>
            </div>
            <div class="panel-actions">
              <button class="panel-action-btn" id="panel-position-btn" title="Toggle Panel Position">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="10" y1="1" x2="10" y2="15"/></svg>
              </button>
              <button class="panel-action-btn" id="clear-btn" title="Clear Terminal">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M2 2l12 12M14 2L2 14"/></svg>
              </button>
              <button class="panel-action-btn" id="panel-close-btn" title="Close Panel (Ctrl+`)">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>
              </button>
            </div>
          </div>
          <div class="output-scroll" id="output">
            <span class="output-cursor"></span>
          </div>
          <div class="output-scroll" id="proof-panel" style="display:none">
            <div class="proof-empty" id="proof-empty">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Run code with <code>prove {}</code> blocks to see proof artifacts</span>
            </div>
            <div id="proof-artifacts" style="display:none"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- STATUS BAR -->
    <div class="statusbar">
      <div class="statusbar-left">
        <span class="status-item" id="server-status">
          <span class="status-dot" id="server-dot"></span>
          <span id="server-label">Server</span>
        </span>
        <span class="status-item" id="lsp-status" style="opacity:0.5">LSP</span>
      </div>
      <div class="statusbar-right">
        <span class="status-item" id="status-line">Ln 1, Col 1</span>
        <span class="status-item">Achronyme</span>
        <span class="status-item">UTF-8</span>
      </div>
    </div>
  </div>

  <!-- ═══ COMMAND PALETTE ═══ -->
  <el-dialog id="cmd-palette-dialog">
    <dialog id="cmd-palette-native" class="cmd-dialog">
      <el-dialog-backdrop class="cmd-backdrop" />
      <el-dialog-panel class="cmd-panel-wrapper">
        <div class="cmd-palette" id="cmd-palette-shell">
          <el-command-palette id="cmd-palette">
            <div class="cmd-input-row">
              <svg class="cmd-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
              </svg>
              <input type="text" class="cmd-input" autofocus placeholder="Type a command or search..." autocomplete="off" spellcheck="false" />
            </div>
            <el-command-list class="cmd-list">
              <!-- Actions -->
              <el-command-group class="cmd-group">
                <div class="cmd-group-label">Actions</div>
                <button type="button" class="cmd-item" data-action="runCode" aria-label="Run Code">
                  <span class="cmd-item-label">Run Code</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+enter">Ctrl+Enter</kbd>
                </button>
                <button type="button" class="cmd-item" data-action="saveActiveFile" aria-label="Save File">
                  <span class="cmd-item-label">Save File</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+s">Ctrl+S</kbd>
                </button>
                <button type="button" class="cmd-item" data-action="clearOutput" aria-label="Clear Terminal">
                  <span class="cmd-item-label">Clear Terminal</span>
                </button>
              </el-command-group>

              <!-- Layout -->
              <el-command-group class="cmd-group">
                <div class="cmd-group-label">Layout</div>
                <button type="button" class="cmd-item" data-action="toggleSidebar" aria-label="Toggle Sidebar">
                  <span class="cmd-item-label">Toggle Sidebar</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+b">Ctrl+B</kbd>
                </button>
                <button type="button" class="cmd-item" data-action="togglePanel" aria-label="Toggle Output Panel">
                  <span class="cmd-item-label">Toggle Output Panel</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+`">Ctrl+`</kbd>
                </button>
                <button type="button" class="cmd-item" data-action="togglePanelPosition" aria-label="Cycle Panel Position">
                  <span class="cmd-item-label">Cycle Panel Position</span>
                </button>
                <button type="button" class="cmd-item" data-action="splitRight" aria-label="Split Editor Right">
                  <span class="cmd-item-label">Split Editor Right</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+\">Ctrl+\</kbd>
                </button>
                <button type="button" class="cmd-item" data-action="toggleDocs" aria-label="Toggle Documentation">
                  <span class="cmd-item-label">Toggle Documentation</span>
                  <kbd class="cmd-kbd" data-shortcut="ctrl+shift+d">Ctrl+Shift+D</kbd>
                </button>
              </el-command-group>

              <!-- File -->
              <el-command-group class="cmd-group">
                <div class="cmd-group-label">File</div>
                <button type="button" class="cmd-item" data-action="createNewFile" aria-label="New File">
                  <span class="cmd-item-label">New File</span>
                </button>
                <button type="button" class="cmd-item" data-action="createNewFolder" aria-label="New Folder">
                  <span class="cmd-item-label">New Folder</span>
                </button>
                <button type="button" class="cmd-item" data-action="exportProject" aria-label="Export Project">
                  <span class="cmd-item-label">Export Project</span>
                </button>
                <button type="button" class="cmd-item" data-action="importProject" aria-label="Import Project">
                  <span class="cmd-item-label">Import Project</span>
                </button>
              </el-command-group>

              <!-- Templates -->
              <el-command-group class="cmd-group">
                <div class="cmd-group-label">Templates</div>
                <button type="button" class="cmd-item" data-action="template:vm" aria-label="Template: VM">
                  <span class="cmd-item-label">Template: VM</span>
                </button>
                <button type="button" class="cmd-item" data-action="template:circuit" aria-label="Template: Circuit">
                  <span class="cmd-item-label">Template: Circuit</span>
                </button>
                <button type="button" class="cmd-item" data-action="template:prove" aria-label="Template: Prove">
                  <span class="cmd-item-label">Template: Prove</span>
                </button>
              </el-command-group>

              <!-- Go to File (dynamic) -->
              <el-command-group class="cmd-group" id="cmd-files-group" hidden>
                <div class="cmd-group-label">Go to File</div>
              </el-command-group>

              <!-- Documentation (populated at init) -->
              <el-command-group class="cmd-group" id="cmd-docs-group">
                <div class="cmd-group-label">Documentation</div>
              </el-command-group>
            </el-command-list>

            <el-no-results class="cmd-no-results" hidden>No results found.</el-no-results>
          </el-command-palette>
        </div>
      </el-dialog-panel>
    </dialog>
  </el-dialog>

  <script>
    import '@tailwindplus/elements';
    import { EditorState } from "@codemirror/state";
    import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
    import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
    import { syntaxHighlighting, defaultHighlightStyle, bracketMatching, indentOnInput } from "@codemirror/language";
    import { oneDark } from "@codemirror/theme-one-dark";
    import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";
    import { highlightSelectionMatches } from "@codemirror/search";
    import { achronymeLanguage } from "../lib/achronyme-lang.js";
    import { initLspWasm, achLinter, achAutocompletion, achHover } from "../lib/achronyme-lsp.js";
    import { renderFileTree, startInlineCreate, startInlineCreateDir, setupRootDrop } from "../lib/playground-filetree.js";
    import { TabManager } from "../lib/playground-tabs.js";
    import * as session from "../lib/playground-session.js";
    import { sidebarConfig, getLabel } from "../data/docs-sidebar";

    // ═══ DOM ═══
    const output = document.getElementById("output");
    const clearBtn = document.getElementById("clear-btn");
    const fileTree = document.getElementById("file-tree");
    const templateSelect = document.getElementById("template-select");
    const newFileBtn = document.getElementById("new-file-btn");
    const statusLine = document.getElementById("status-line");
    const serverDot = document.getElementById("server-dot");
    const serverLabel = document.getElementById("server-label");
    const outputPanel = document.getElementById("output-panel");
    const outputHeader = document.getElementById("output-header");
    const groupsWrapper = document.getElementById("editor-groups-wrapper");
    const layoutRoot = document.getElementById("layout-root");

    // ═══ EDITOR GROUPS ═══
    let groups = [];
    let activeGroupIdx = 0;
    let groupIdCounter = 0;
    function ag() { return groups[activeGroupIdx]; }

    // ═══ LAYOUT STATE ═══
    let panelVisible = localStorage.getItem("ach-panel-visible") !== "false";
    let sidebarCollapsed = localStorage.getItem("ach-sidebar-collapsed") === "true";
    let sidebarWidth = parseInt(localStorage.getItem("ach-sidebar-width")) || 240;
    let panelPositions = {
      terminal: localStorage.getItem("ach-pos-terminal") || "bottom",
      docs: localStorage.getItem("ach-pos-docs") || "right",
    };

    const shell = document.querySelector(".shell");
    const sidebar = document.querySelector(".sidebar");
    const sidebarResize = document.getElementById("sidebar-resize");
    const explorerIcon = document.querySelector(".activity-icon[title='Explorer']");
    const panelPositionBtn = document.getElementById("panel-position-btn");
    const panelCloseBtn = document.getElementById("panel-close-btn");

    function applySidebarLayout() {
      shell.classList.toggle("sidebar-collapsed", sidebarCollapsed);
      explorerIcon.classList.toggle("active", !sidebarCollapsed);
      shell.style.gridTemplateColumns = sidebarCollapsed ? "" : `48px ${sidebarWidth}px 1fr`;
      localStorage.setItem("ach-sidebar-collapsed", sidebarCollapsed);
      localStorage.setItem("ach-sidebar-width", sidebarWidth);
    }

    function createLayoutHandle(dir) {
      const h = document.createElement("div");
      h.className = `layout-handle-${dir}`;
      h.addEventListener("mousedown", (e) => {
        e.preventDefault();
        const prev = h.previousElementSibling, next = h.nextElementSibling;
        if (!prev || !next) return;
        const isH = dir === "h";
        const startPos = isH ? e.clientX : e.clientY;
        const prevSize = isH ? prev.offsetWidth : prev.offsetHeight;
        const nextSize = isH ? next.offsetWidth : next.offsetHeight;
        h.classList.add("dragging");
        document.body.classList.add("resizing");
        document.body.style.cursor = isH ? "col-resize" : "row-resize";
        document.body.style.userSelect = "none";
        const onMove = (e) => {
          const delta = (isH ? e.clientX : e.clientY) - startPos;
          const total = prevSize + nextSize;
          let np = Math.max(isH ? 150 : 60, prevSize + delta);
          let nn = total - np;
          if (nn < (isH ? 150 : 60)) { nn = isH ? 150 : 60; np = total - nn; }
          if (isH) { prev.style.width = np+"px"; prev.style.flex = "none"; next.style.width = nn+"px"; next.style.flex = "none"; }
          else { prev.style.flex = "1"; next.style.height = nn+"px"; next.style.flex = "none"; }
        };
        const onUp = () => {
          h.classList.remove("dragging"); document.body.classList.remove("resizing");
          document.body.style.cursor = ""; document.body.style.userSelect = "";
          document.removeEventListener("mousemove", onMove);
          document.removeEventListener("mouseup", onUp);
        };
        document.addEventListener("mousemove", onMove);
        document.addEventListener("mouseup", onUp);
      });
      return h;
    }

    function buildMainLayout() {
      // Detach panels (preserves event listeners)
      if (groupsWrapper.parentElement) groupsWrapper.remove();
      if (outputPanel.parentElement) outputPanel.remove();
      if (docsGroup?.el.parentElement) docsGroup.el.remove();
      // Clear layout root
      layoutRoot.innerHTML = "";

      const leftPanels = [];
      const rightPanels = [];
      const bottomPanels = [];

      if (panelVisible) {
        if (panelPositions.terminal === "left") leftPanels.push(outputPanel);
        else if (panelPositions.terminal === "right") rightPanels.push(outputPanel);
        else bottomPanels.push(outputPanel);
      }
      if (docsGroup) {
        if (panelPositions.docs === "left") leftPanels.push(docsGroup.el);
        else if (panelPositions.docs === "right") rightPanels.push(docsGroup.el);
        else bottomPanels.push(docsGroup.el);
      }

      // Set sizing on panels
      const setH = (el) => { el.style.width = ""; el.style.height = "35%"; el.style.minHeight = "60px"; el.style.minWidth = ""; el.style.flex = ""; };
      const setV = (el) => { el.style.height = ""; el.style.width = "35%"; el.style.minWidth = "150px"; el.style.minHeight = ""; el.style.flex = ""; };
      leftPanels.forEach(setV);
      rightPanels.forEach(setV);
      bottomPanels.forEach(setH);

      // Build: [left panels] [center column] [right panels]
      for (const p of leftPanels) {
        layoutRoot.appendChild(p);
        layoutRoot.appendChild(createLayoutHandle("h"));
      }

      const center = document.createElement("div");
      center.className = "layout-center";
      center.appendChild(groupsWrapper);
      for (const p of bottomPanels) {
        center.appendChild(createLayoutHandle("v"));
        center.appendChild(p);
      }
      layoutRoot.appendChild(center);

      for (const p of rightPanels) {
        layoutRoot.appendChild(createLayoutHandle("h"));
        layoutRoot.appendChild(p);
      }

      // Drop zones overlay
      let dz = layoutRoot.querySelector(".drop-zones");
      if (!dz) {
        dz = document.createElement("div");
        dz.className = "drop-zones";
        dz.innerHTML = '<div class="drop-zone left" data-pos="left">Left</div><div class="drop-zone right" data-pos="right">Right</div><div class="drop-zone bottom" data-pos="bottom">Bottom</div>';
        layoutRoot.appendChild(dz);
      }

      localStorage.setItem("ach-panel-visible", panelVisible);
      localStorage.setItem("ach-pos-terminal", panelPositions.terminal);
      localStorage.setItem("ach-pos-docs", panelPositions.docs);
    }

    function setPanelPosition(panel, newPos) {
      const other = panel === "terminal" ? "docs" : "terminal";
      if (panelPositions[other] === newPos) panelPositions[other] = panelPositions[panel];
      panelPositions[panel] = newPos;
      buildMainLayout();
    }

    function toggleSidebar() { sidebarCollapsed = !sidebarCollapsed; applySidebarLayout(); }
    function togglePanel() { panelVisible = !panelVisible; buildMainLayout(); if (panelVisible && ag()) ag().view.focus(); }
    function togglePanelPosition() {
      outputPanel.style.height = ""; outputPanel.style.width = "";
      const cycle = { bottom: "right", right: "left", left: "bottom" };
      setPanelPosition("terminal", cycle[panelPositions.terminal] || "bottom");
    }

    explorerIcon.addEventListener("click", toggleSidebar);
    panelPositionBtn.addEventListener("click", togglePanelPosition);
    panelCloseBtn.addEventListener("click", togglePanel);

    // ═══ PANEL DRAG & DROP ═══
    let dragPanel = null;

    function setupPanelDrag(header, panelKey) {
      header.addEventListener("dragstart", (e) => {
        dragPanel = panelKey;
        e.dataTransfer.setData("text/x-ach-panel", panelKey);
        e.dataTransfer.effectAllowed = "move";
        setTimeout(() => layoutRoot.querySelector(".drop-zones")?.classList.add("active"), 0);
      });
      header.addEventListener("dragend", () => {
        dragPanel = null;
        const dz = layoutRoot.querySelector(".drop-zones");
        if (dz) { dz.classList.remove("active"); dz.querySelectorAll(".drop-zone").forEach(z => z.classList.remove("hover")); }
      });
    }

    setupPanelDrag(outputHeader, "terminal");

    layoutRoot.addEventListener("dragover", (e) => {
      if (!dragPanel) return;
      e.preventDefault();
      e.dataTransfer.dropEffect = "move";
      const zone = e.target.closest(".drop-zone");
      layoutRoot.querySelectorAll(".drop-zone").forEach(z => z.classList.remove("hover"));
      if (zone) zone.classList.add("hover");
    });

    layoutRoot.addEventListener("drop", (e) => {
      if (!dragPanel) return;
      e.preventDefault();
      const zone = e.target.closest(".drop-zone");
      const dz = layoutRoot.querySelector(".drop-zones");
      if (dz) { dz.classList.remove("active"); dz.querySelectorAll(".drop-zone").forEach(z => z.classList.remove("hover")); }
      if (zone) {
        const newPos = zone.dataset.pos;
        setPanelPosition(dragPanel, newPos);
      }
      dragPanel = null;
    });

    // ═══ SIDEBAR RESIZE ═══
    let sidebarResizing = false;
    sidebarResize.addEventListener("mousedown", (e) => {
      e.preventDefault(); sidebarResizing = true;
      sidebarResize.classList.add("dragging");
      document.body.classList.add("resizing");
      document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!sidebarResizing) return;
      sidebarWidth = Math.max(150, Math.min(500, e.clientX - 48));
      shell.style.gridTemplateColumns = `48px ${sidebarWidth}px 1fr`;
    });
    document.addEventListener("mouseup", () => {
      if (!sidebarResizing) return;
      sidebarResizing = false; sidebarResize.classList.remove("dragging");
      document.body.classList.remove("resizing");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
      localStorage.setItem("ach-sidebar-width", sidebarWidth);
    });

    // Panel resize is now handled by createLayoutHandle() in buildMainLayout

    // ═══ GROUP SPLIT RESIZE ═══
    let groupResizing = false, grHandle = null, grStartX = 0, grLeft = null, grRight = null, grStartW = [0, 0];

    function setupGroupSplitHandle(handle) {
      handle.addEventListener("mousedown", (e) => {
        e.preventDefault();
        groupResizing = true; grHandle = handle; grStartX = e.clientX;
        const children = Array.from(handle.parentElement.children);
        const idx = children.indexOf(handle);
        grLeft = children[idx - 1]; grRight = children[idx + 1];
        grStartW = [grLeft.offsetWidth, grRight.offsetWidth];
        handle.classList.add("dragging");
        document.body.classList.add("resizing");
        document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none";
      });
    }

    document.addEventListener("mousemove", (e) => {
      if (!groupResizing) return;
      const dx = e.clientX - grStartX;
      const total = grStartW[0] + grStartW[1];
      let lw = Math.max(100, grStartW[0] + dx);
      let rw = total - lw;
      if (rw < 100) { rw = 100; lw = total - rw; }
      const lp = (lw / total) * 100;
      grLeft.style.flex = `${lp} 1 0%`;
      grRight.style.flex = `${100 - lp} 1 0%`;
      grLeft.style.width = ""; grRight.style.width = "";
    });
    document.addEventListener("mouseup", () => {
      if (!groupResizing) return;
      groupResizing = false;
      if (grHandle) grHandle.classList.remove("dragging");
      document.body.classList.remove("resizing");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
    });

    // ═══ EDITOR THEME ═══
    const editorTheme = EditorView.theme({
      "&": { backgroundColor: "var(--bg-editor)" },
      ".cm-content": { caretColor: "var(--text-bright)", fontFamily: "var(--font-mono)", padding: "4px 0" },
      ".cm-gutters": { backgroundColor: "var(--bg-editor)", borderRight: "none", color: "var(--text-muted)" },
      ".cm-activeLineGutter": { color: "var(--text-secondary)", backgroundColor: "transparent" },
      ".cm-activeLine": { backgroundColor: "rgba(255,255,255,0.02)" },
      "&.cm-focused .cm-cursor": { borderLeftColor: "var(--text-bright)", borderLeftWidth: "2px" },
      "&.cm-focused .cm-selectionBackground, .cm-selectionBackground": { backgroundColor: "rgba(168, 85, 247, 0.25) !important" },
      ".cm-foldGutter": { width: "12px" },
    }, { dark: true });

    // ═══ RUN KEYMAP ═══
    const runKeymap = keymap.of([
      { key: "Ctrl-Enter", mac: "Cmd-Enter", run: () => { runCode(); return true; } },
      { key: "Ctrl-s", mac: "Cmd-s", run: () => { saveActiveFile(); return true; } },
      { key: "Ctrl-b", mac: "Cmd-b", run: () => { toggleSidebar(); return true; } },
      { key: "Ctrl-`", mac: "Cmd-`", run: () => { togglePanel(); return true; } },
      { key: "Ctrl-j", mac: "Cmd-j", run: () => { togglePanel(); return true; } },
      { key: "Ctrl-\\", mac: "Cmd-\\", run: () => { splitRight(); return true; } },
      { key: "Ctrl-k", mac: "Cmd-k", run: () => { openCommandPalette(); return true; } },
      { key: "Ctrl-Shift-p", mac: "Cmd-Shift-p", run: () => { openCommandPalette(); return true; } },
    ]);

    // ═══ EDITOR EXTENSIONS (per group) ═══
    function editorExtensions(group) {
      const autoSave = EditorView.updateListener.of((update) => {
        if (update.docChanged && session.isProjectMode()) {
          const idx = group.tabs.getActiveIndex();
          const content = update.state.doc.toString();
          group.tabs.setModified(idx, group.tabs.isModified(idx, content));
          renderGroupTabs(group);
          clearTimeout(group.saveTimeout);
          group.saveTimeout = setTimeout(() => saveGroupFile(group), 1000);
        }
      });

      const cursorTrack = EditorView.updateListener.of((update) => {
        if ((update.selectionSet || update.docChanged) && groups[activeGroupIdx] === group) {
          const pos = update.state.selection.main.head;
          const line = update.state.doc.lineAt(pos);
          statusLine.textContent = `Ln ${line.number}, Col ${pos - line.from + 1}`;
        }
      });

      const focusTracker = EditorView.domEventHandlers({
        focus() {
          const idx = groups.indexOf(group);
          if (idx >= 0 && idx !== activeGroupIdx) setActiveGroup(idx);
        },
      });

      return [
        lineNumbers(), highlightActiveLine(), highlightActiveLineGutter(),
        history(), bracketMatching(), closeBrackets(), indentOnInput(),
        highlightSelectionMatches(), oneDark, editorTheme,
        syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
        achronymeLanguage, achLinter, achAutocompletion, achHover,
        keymap.of([indentWithTab, ...closeBracketsKeymap, ...defaultKeymap, ...historyKeymap]),
        runKeymap, cursorTrack, autoSave, focusTracker, EditorView.lineWrapping,
      ];
    }

    // ═══ GROUP MANAGEMENT ═══
    function createGroup() {
      const id = groupIdCounter++;
      const tm = new TabManager();

      const el = document.createElement("div");
      el.className = "editor-group" + (groups.length === 0 ? " active" : "");

      const tabBarEl = document.createElement("div");
      tabBarEl.className = "group-tabbar";

      const breadcrumbEl = document.createElement("div");
      breadcrumbEl.className = "group-breadcrumb";

      const welcomeEl = document.createElement("div");
      welcomeEl.className = "group-welcome";
      welcomeEl.innerHTML = `
        <div class="welcome-content">
          <div class="welcome-logo">◇</div>
          <h2>Achronyme</h2>
          <p class="welcome-subtitle">Zero-Knowledge Playground</p>
          <div class="welcome-section">
            <h3>Start</h3>
            <div class="welcome-item" data-action="explorer">Open a file from the Explorer</div>
            <div class="welcome-item" data-action="template">Select a template to begin</div>
          </div>
          <div class="welcome-section">
            <h3>Shortcuts</h3>
            <div class="welcome-shortcut"><span>Run</span><kbd>Ctrl+Enter</kbd></div>
            <div class="welcome-shortcut"><span>Save</span><kbd>Ctrl+S</kbd></div>
            <div class="welcome-shortcut"><span>Split Editor</span><kbd>Ctrl+\\</kbd></div>
            <div class="welcome-shortcut"><span>Toggle Sidebar</span><kbd>Ctrl+B</kbd></div>
            <div class="welcome-shortcut"><span>Toggle Terminal</span><kbd>Ctrl+\`</kbd></div>
            <div class="welcome-shortcut"><span>Command Palette</span><kbd>Ctrl+K</kbd></div>
          </div>
          <div class="welcome-section">
            <h3>Help</h3>
            <a href="/docs/getting-started/introduction" class="welcome-link">Documentation</a>
            <a href="https://github.com/achronyme/achronyme" target="_blank" class="welcome-link">GitHub Repository</a>
          </div>
        </div>`;
      welcomeEl.querySelector('[data-action="explorer"]').addEventListener("click", () => {
        if (sidebarCollapsed) toggleSidebar();
      });
      welcomeEl.querySelector('[data-action="template"]').addEventListener("click", () => {
        if (sidebarCollapsed) toggleSidebar();
        templateSelect.focus();
      });

      const editorEl = document.createElement("div");
      editorEl.className = "group-editor";

      el.append(tabBarEl, breadcrumbEl, welcomeEl, editorEl);

      if (groups.length > 0) {
        const handle = document.createElement("div");
        handle.className = "group-split-handle";
        setupGroupSplitHandle(handle);
        groupsWrapper.appendChild(handle);
      }
      groupsWrapper.appendChild(el);

      const group = { id, tabs: tm, view: null, el, tabBarEl, breadcrumbEl, welcomeEl, editorEl, saveTimeout: null };

      group.view = new EditorView({
        state: EditorState.create({ doc: "", extensions: editorExtensions(group) }),
        parent: editorEl,
      });

      groups.push(group);
      renderGroupTabs(group);
      return group;
    }

    function setActiveGroup(idx) {
      if (idx < 0 || idx >= groups.length) return;
      activeGroupIdx = idx;
      groups.forEach((g, i) => g.el.classList.toggle("active", i === idx));
      const tab = ag().tabs.getActiveTab();
      if (tab && ag().view) {
        const pos = ag().view.state.selection.main.head;
        const line = ag().view.state.doc.lineAt(pos);
        statusLine.textContent = `Ln ${line.number}, Col ${pos - line.from + 1}`;
      }
    }

    function removeGroup(group) {
      const idx = groups.indexOf(group);
      if (idx < 0 || groups.length <= 1) return;

      const prev = group.el.previousElementSibling;
      const next = group.el.nextElementSibling;
      if (prev && prev.classList.contains("group-split-handle")) prev.remove();
      else if (next && next.classList.contains("group-split-handle")) next.remove();

      group.view.destroy();
      group.el.remove();
      groups.splice(idx, 1);
      groups.forEach(g => { g.el.style.flex = ""; });

      if (activeGroupIdx >= groups.length) activeGroupIdx = groups.length - 1;
      setActiveGroup(activeGroupIdx);
    }

    function splitRight() {
      const src = ag();
      const srcTab = src.tabs.getActiveTab();

      const newGroup = createGroup();

      if (srcTab) {
        // Move the active file to the new panel
        src.tabs.saveEditorState(src.view.state);
        const content = src.view.state.doc.toString();
        const path = srcTab.path;
        const savedContent = srcTab.savedContent;
        const modified = srcTab.modified;

        // Remove from source
        src.tabs.closeTab(src.tabs.getActiveIndex());
        const remaining = src.tabs.getActiveTab();
        if (remaining) src.view.setState(remaining.editorState);

        // Add to new group
        newGroup.tabs.openTab(path, content, editorExtensions(newGroup));
        if (modified) {
          const ni = newGroup.tabs.getActiveIndex();
          newGroup.tabs.setModified(ni, true);
          newGroup.tabs.getTabs()[ni].savedContent = savedContent;
        }
        newGroup.view.setState(newGroup.tabs.getActiveTab().editorState);
      }

      activeGroupIdx = groups.indexOf(newGroup);
      groups.forEach((g, i) => g.el.classList.toggle("active", i === activeGroupIdx));
      renderAllGroups();
    }

    // ═══ OUTPUT ═══
    const proofPanel = document.getElementById("proof-panel");
    const proofEmpty = document.getElementById("proof-empty");
    const proofArtifacts = document.getElementById("proof-artifacts");
    let activeOutputTab = "terminal";

    // Output tab switching
    document.querySelectorAll(".output-tab[data-tab]").forEach(tab => {
      tab.addEventListener("click", () => {
        document.querySelectorAll(".output-tab[data-tab]").forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        activeOutputTab = tab.dataset.tab;
        output.style.display = activeOutputTab === "terminal" ? "" : "none";
        proofPanel.style.display = activeOutputTab === "proof" ? "" : "none";
      });
    });

    function clearOutput() { output.innerHTML = '<span class="output-cursor"></span>'; }
    function appendOutput(text, cls = "stdout") {
      const cursor = output.querySelector(".output-cursor");
      const line = document.createElement("div");
      line.className = `output-line ${cls}`;
      line.textContent = text;
      output.insertBefore(line, cursor);
      output.scrollTop = output.scrollHeight;
    }

    // ═══ PROOF ARTIFACTS ═══
    function downloadBlob(data, filename, mime) {
      const blob = new Blob([data], { type: mime });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url; a.download = filename; a.click();
      URL.revokeObjectURL(url);
    }

    function downloadBase64(b64, filename, mime) {
      const bytes = atob(b64);
      const arr = new Uint8Array(bytes.length);
      for (let i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);
      downloadBlob(arr, filename, mime);
    }

    function dlBtn(label, onClick) {
      const btn = document.createElement("button");
      btn.className = "proof-dl-btn";
      btn.innerHTML = `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 10v3h10v-3"/><path d="M8 2v8M5 7l3 3 3-3"/></svg> ${label}`;
      btn.addEventListener("click", onClick);
      return btn;
    }

    function collapsibleSection(label, content) {
      const lbl = document.createElement("div");
      lbl.className = "proof-section-label";
      lbl.innerHTML = `<svg viewBox="0 0 10 10"><path d="M3 2L7 5L3 8" fill="none" stroke="currentColor" stroke-width="1.3"/></svg> ${label}`;
      const body = document.createElement("div");
      body.className = "proof-json-preview";
      body.textContent = typeof content === "string" ? content : JSON.stringify(content, null, 2);
      lbl.addEventListener("click", () => {
        lbl.classList.toggle("collapsed");
        body.style.display = lbl.classList.contains("collapsed") ? "none" : "";
      });
      return { lbl, body };
    }

    function renderProofArtifacts(proofs) {
      proofArtifacts.innerHTML = "";
      if (!proofs || proofs.length === 0) {
        proofEmpty.style.display = "";
        proofArtifacts.style.display = "none";
        return;
      }
      proofEmpty.style.display = "none";
      proofArtifacts.style.display = "";

      for (const p of proofs) {
        const card = document.createElement("div");
        card.className = "proof-artifact";

        // Header with stats
        const header = document.createElement("div");
        header.className = "proof-artifact-header";
        header.innerHTML = `
          <div class="proof-artifact-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z"/><circle cx="12" cy="12" r="3"/></svg>
            ${p.name || "Proof"}
            <span class="proof-badge">${p.backend || "r1cs"}</span>
          </div>
          <div class="proof-stats">
            <span><span class="proof-stat-val">${p.constraints}</span> constraints</span>
          </div>`;
        card.appendChild(header);

        // Downloads
        const downloads = document.createElement("div");
        downloads.className = "proof-downloads";
        if (p.proof_json) downloads.appendChild(dlBtn("proof.json", () => downloadBlob(p.proof_json, "proof.json", "application/json")));
        if (p.public_json) downloads.appendChild(dlBtn("public.json", () => downloadBlob(p.public_json, "public.json", "application/json")));
        if (p.vkey_json) downloads.appendChild(dlBtn("vkey.json", () => downloadBlob(p.vkey_json, "vkey.json", "application/json")));
        if (p.r1cs) downloads.appendChild(dlBtn("circuit.r1cs", () => downloadBase64(p.r1cs, "circuit.r1cs", "application/octet-stream")));
        if (p.solidity) downloads.appendChild(dlBtn("Verifier.sol", () => downloadBlob(p.solidity, "Verifier.sol", "text/plain")));
        card.appendChild(downloads);

        // Collapsible JSON previews
        if (p.proof_json) {
          try {
            const { lbl, body } = collapsibleSection("Proof", JSON.parse(p.proof_json));
            lbl.classList.add("collapsed"); body.style.display = "none";
            card.append(lbl, body);
          } catch { const { lbl, body } = collapsibleSection("Proof", p.proof_json); card.append(lbl, body); }
        }
        if (p.public_json) {
          const { lbl, body } = collapsibleSection("Public Inputs", p.public_json);
          card.append(lbl, body);
        }
        if (p.vkey_json) {
          try {
            const { lbl, body } = collapsibleSection("Verifying Key", JSON.parse(p.vkey_json));
            lbl.classList.add("collapsed"); body.style.display = "none";
            card.append(lbl, body);
          } catch { const { lbl, body } = collapsibleSection("Verifying Key", p.vkey_json); card.append(lbl, body); }
        }
        if (p.solidity) {
          const { lbl, body } = collapsibleSection("Solidity Verifier", p.solidity);
          lbl.classList.add("collapsed"); body.style.display = "none";
          card.append(lbl, body);
        }

        proofArtifacts.appendChild(card);
      }

      // Auto-switch to proof tab
      document.querySelectorAll(".output-tab[data-tab]").forEach(t => t.classList.remove("active"));
      document.querySelector('.output-tab[data-tab="proof"]').classList.add("active");
      activeOutputTab = "proof";
      output.style.display = "none";
      proofPanel.style.display = "";
    }

    // ═══ TAB ICONS ═══
    function fileTabIcon(path) {
      if (path.endsWith(".toml")) {
        return `<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L2 4.5v7l6 3 6-3v-7L8 1.5z" stroke="#8b8b9a" stroke-width="1.2"/><circle cx="8" cy="8" r="1.5" fill="#8b8b9a"/></svg>`;
      }
      return `<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2L13 8L8 14L3 8L8 2Z" fill="none" stroke="#a855f7" stroke-width="1.2"/></svg>`;
    }

    // ═══ TAB RENDERING (per group) ═══
    function renderGroupTabs(group) {
      const bar = group.tabBarEl;
      bar.innerHTML = "";

      for (let i = 0; i < group.tabs.getTabs().length; i++) {
        const t = group.tabs.getTabs()[i];
        const tab = document.createElement("div");
        tab.className = "tab" + (i === group.tabs.getActiveIndex() ? " active" : "") + (t.modified ? " modified" : "");

        const icon = document.createElement("span");
        icon.className = "tab-icon";
        icon.innerHTML = fileTabIcon(t.path);

        const label = document.createElement("span");
        label.className = "tab-label";
        label.textContent = t.path.split("/").pop();
        label.title = t.path;

        const dot = document.createElement("span");
        dot.className = "tab-dot";

        const close = document.createElement("button");
        close.className = "tab-close";
        close.innerHTML = `<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>`;
        close.addEventListener("click", (e) => { e.stopPropagation(); closeTabInGroup(group, i); });

        tab.appendChild(icon); tab.appendChild(label); tab.appendChild(dot); tab.appendChild(close);
        tab.draggable = true;
        tab.addEventListener("dragstart", (e) => {
          e.dataTransfer.setData("text/x-ach-tab", JSON.stringify({ groupId: group.id, tabIdx: i, path: t.path }));
          e.dataTransfer.effectAllowed = "move";
        });
        tab.addEventListener("click", () => { setActiveGroup(groups.indexOf(group)); switchTabInGroup(group, i); });
        tab.addEventListener("mousedown", (e) => { if (e.button === 1) { e.preventDefault(); closeTabInGroup(group, i); } });
        bar.appendChild(tab);
      }

      const actions = document.createElement("div");
      actions.className = "tab-actions";

      const splitBtn = document.createElement("button");
      splitBtn.className = "tab-action-btn";
      splitBtn.title = "Split Editor (Ctrl+\\)";
      splitBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="8" y1="1" x2="8" y2="15"/></svg>`;
      splitBtn.addEventListener("click", () => { setActiveGroup(groups.indexOf(group)); splitRight(); });

      const runBtn = document.createElement("button");
      runBtn.className = "run-btn";
      runBtn.innerHTML = `<svg viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg> Run`;
      runBtn.addEventListener("click", runCode);

      actions.appendChild(splitBtn);
      actions.appendChild(runBtn);
      bar.appendChild(actions);

      // Toggle welcome / editor
      const hasTabs = group.tabs.getTabs().length > 0;
      group.welcomeEl.style.display = hasTabs ? "none" : "";
      group.editorEl.style.display = hasTabs ? "" : "none";
      group.breadcrumbEl.style.display = hasTabs ? "" : "none";
      updateGroupBreadcrumb(group);
    }

    function renderAllGroups() { for (const g of groups) renderGroupTabs(g); }

    function updateGroupBreadcrumb(group) {
      const tab = group.tabs.getActiveTab();
      const path = tab?.path || "";
      if (!path) { group.breadcrumbEl.innerHTML = ""; return; }
      const parts = path.split("/");
      group.breadcrumbEl.innerHTML = parts.map((p, i) =>
        (i > 0 ? '<span class="breadcrumb-sep">&rsaquo;</span>' : "") +
        `<span class="breadcrumb-item">${p}</span>`
      ).join("");
    }

    // ═══ FILE OPERATIONS ═══
    async function openFile(path) {
      // If already open in any group, switch to that group
      for (let i = 0; i < groups.length; i++) {
        const idx = groups[i].tabs.findTab(path);
        if (idx >= 0) {
          setActiveGroup(i);
          switchTabInGroup(groups[i], idx);
          return;
        }
      }
      return openFileInGroup(ag(), path);
    }

    async function openFileInGroup(group, path) {
      const existing = group.tabs.findTab(path);
      if (existing >= 0) { switchTabInGroup(group, existing); return; }
      try {
        const content = await session.readFile(path);
        group.tabs.saveEditorState(group.view.state);
        group.tabs.openTab(path, content, editorExtensions(group));
        group.view.setState(group.tabs.getActiveTab().editorState);
        renderGroupTabs(group);
        refreshFileTree();
      } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
    }

    function switchTabInGroup(group, index) {
      if (index === group.tabs.getActiveIndex()) return;
      group.tabs.saveEditorState(group.view.state);
      group.tabs.switchTab(index);
      const tab = group.tabs.getActiveTab();
      if (tab) group.view.setState(tab.editorState);
      renderGroupTabs(group);
      refreshFileTree();
    }

    function closeTabInGroup(group, index) {
      group.tabs.saveEditorState(group.view.state);
      group.tabs.closeTab(index);
      const tab = group.tabs.getActiveTab();
      if (tab) {
        group.view.setState(tab.editorState);
      } else if (groups.length > 1) {
        removeGroup(group);
        return;
      } else {
        group.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(group) }));
      }
      renderGroupTabs(group);
    }

    async function saveGroupFile(group) {
      const tab = group.tabs.getActiveTab();
      if (!tab || !session.isProjectMode()) return;
      group.tabs.saveEditorState(group.view.state);
      const content = group.view.state.doc.toString();
      try {
        await session.writeFile(tab.path, content);
        group.tabs.markSaved(group.tabs.getActiveIndex(), content);
        renderGroupTabs(group);
      } catch (e) { appendOutput(`Save error: ${e.message}`, "error"); }
    }

    async function saveActiveFile() { return saveGroupFile(ag()); }

    async function refreshFileTree() {
      if (!session.isProjectMode()) return;
      try {
        const files = await session.listFiles();
        const activeTab = ag().tabs.getActiveTab();
        renderFileTree(fileTree, files, activeTab?.path || "", {
          onFileClick: openFile,
          onFileDelete: async (path) => {
            if (!confirm(`Delete ${path}?`)) return;
            await session.deleteFile(path);
            for (const g of [...groups]) {
              g.tabs.removeTabByPath(path);
              const tab = g.tabs.getActiveTab();
              if (tab) g.view.setState(tab.editorState);
              else if (groups.length > 1) { removeGroup(g); continue; }
              else g.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(g) }));
            }
            renderAllGroups(); refreshFileTree();
          },
          onFileRename: async (oldPath, newPath) => {
            if (!newPath || newPath === oldPath) return;
            try {
              await session.renameFile(oldPath, newPath);
              for (const g of groups) g.tabs.updateTabPath(oldPath, newPath);
              renderAllGroups(); refreshFileTree();
            } catch (e) { appendOutput(`Rename error: ${e.message}`, "error"); }
          },
          onFileMove: async (oldPath, newPath) => {
            if (!newPath || newPath === oldPath) return;
            try {
              await session.renameFile(oldPath, newPath);
              for (const g of groups) g.tabs.updateTabPath(oldPath, newPath);
              renderAllGroups(); refreshFileTree();
            } catch (e) { appendOutput(`Move error: ${e.message}`, "error"); }
          },
          onDirRename: async (oldDir, newDir) => {
            if (!newDir || newDir === oldDir) return;
            try {
              // Rename all files with the old dir prefix
              const files = await session.listFiles();
              const prefix = oldDir + "/";
              for (const f of files) {
                if (f.path.startsWith(prefix) && f.type !== "dir") {
                  const newPath = newDir + "/" + f.path.substring(prefix.length);
                  await session.renameFile(f.path, newPath);
                  for (const g of groups) g.tabs.updateTabPath(f.path, newPath);
                }
              }
              // Also rename empty dir itself if applicable
              try { await session.mkdir(newDir); } catch {}
              try { await session.deleteFile(oldDir); } catch {}
              renderAllGroups(); refreshFileTree();
            } catch (e) { appendOutput(`Rename dir error: ${e.message}`, "error"); }
          },
          onDirDelete: async (dirPath) => {
            if (!confirm(`Delete folder "${dirPath}" and all its contents?`)) return;
            try {
              // Delete all files in this directory
              const files = await session.listFiles();
              const prefix = dirPath + "/";
              for (const f of files) {
                if (f.path.startsWith(prefix) && f.type !== "dir") {
                  await session.deleteFile(f.path);
                  for (const g of [...groups]) {
                    g.tabs.removeTabByPath(f.path);
                    const tab = g.tabs.getActiveTab();
                    if (tab) g.view.setState(tab.editorState);
                    else if (groups.length > 1) { removeGroup(g); continue; }
                    else g.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(g) }));
                  }
                }
              }
              // Delete the directory itself
              await session.deleteFile(dirPath);
              renderAllGroups(); refreshFileTree();
            } catch (e) { appendOutput(`Delete dir error: ${e.message}`, "error"); }
          },
          onNewFileInDir: (dirPath) => {
            startInlineCreate(fileTree, {
              async onCreate(fullPath) {
                try {
                  await session.writeFile(fullPath, `// ${fullPath.split("/").pop()}\n`);
                  await refreshFileTree();
                  await openFile(fullPath);
                } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
              },
            }, dirPath);
          },
          onNewDirInDir: (dirPath) => {
            startInlineCreateDir(fileTree, {
              async onCreateDir(fullPath) {
                try {
                  await session.mkdir(fullPath);
                  await refreshFileTree();
                } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
              },
            }, dirPath);
          },
        });
      } catch (e) { console.warn("file tree refresh:", e); }
    }

    // ═══ RUN ═══
    let running = false;
    async function runCode() {
      if (running) return;
      if (!panelVisible) { panelVisible = true; buildMainLayout(); }
      if (session.isProjectMode()) await saveActiveFile();
      clearOutput();
      running = true;
      document.querySelectorAll(".run-btn").forEach(b => b.disabled = true);
      serverDot.classList.add("loading"); serverLabel.textContent = "Running...";
      try {
        const source = session.isProjectMode() ? null : ag().view.state.doc.toString();
        if (!session.isProjectMode() && (!source || !source.trim())) { appendOutput("// Nothing to run", "info"); return; }
        const data = await session.runProject(source);
        if (data.output) { for (const line of data.output.split("\n")) { if (line) appendOutput(line, "stdout"); } }
        if (!data.success) { if (data.output) appendOutput("", "stdout"); appendOutput(data.error, "error"); }
        appendOutput("", "stdout");
        appendOutput(`[${data.time_ms}ms]`, "timing");
        // Render proof artifacts if present
        if (data.proofs && data.proofs.length > 0) {
          renderProofArtifacts(data.proofs);
        }
      } catch (e) {
        appendOutput(e.message, "error");
        serverDot.classList.add("error"); serverLabel.textContent = "Offline"; return;
      } finally {
        running = false;
        document.querySelectorAll(".run-btn").forEach(b => b.disabled = false);
        serverDot.classList.remove("loading"); serverLabel.textContent = "Server";
      }
    }

    // ═══ TEMPLATE ═══
    async function loadTemplate(name) {
      if (!name) return;
      try {
        clearOutput();
        appendOutput("$ ach init " + name + " --template " + name, "info");
        if (session.isProjectMode()) await session.deleteSession();
        while (groups.length > 1) removeGroup(groups[groups.length - 1]);
        ag().tabs.resetTabs();
        const data = await session.createSession(name);
        document.getElementById("project-name").textContent = name.toUpperCase();
        appendOutput(`Created project \`${name}\` with template \`${name}\``, "info");
        appendOutput("", "info");
        await refreshFileTree();
        const entry = data.files.find(f => f.path.endsWith("main.ach")) || data.files[0];
        if (entry) await openFile(entry.path);
        templateSelect.value = "";
      } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
    }

    // ═══ NEW FILE / FOLDER ═══
    function createNewFile() {
      if (!session.isProjectMode()) { appendOutput("Select a template first", "info"); return; }
      startInlineCreate(fileTree, {
        async onCreate(name) {
          try {
            await session.writeFile(name, `// ${name.split("/").pop()}\n`);
            await refreshFileTree();
            await openFile(name);
          } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
        },
      });
    }

    function createNewFolder() {
      if (!session.isProjectMode()) { appendOutput("Select a template first", "info"); return; }
      startInlineCreateDir(fileTree, {
        async onCreateDir(name) {
          try {
            await session.mkdir(name);
            await refreshFileTree();
          } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
        },
      });
    }

    // ═══ EVENTS ═══
    clearBtn.addEventListener("click", clearOutput);
    templateSelect.addEventListener("change", (e) => loadTemplate(e.target.value));
    newFileBtn.addEventListener("click", createNewFile);
    document.getElementById("new-folder-btn").addEventListener("click", createNewFolder);
    document.getElementById("activity-run").addEventListener("click", runCode);

    document.getElementById("export-btn").addEventListener("click", async () => {
      try { await session.exportProject(); }
      catch (e) { appendOutput(`Export error: ${e.message}`, "error"); }
    });

    const importInput = document.getElementById("import-input");
    document.getElementById("import-btn").addEventListener("click", () => importInput.click());
    importInput.addEventListener("change", async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      try {
        const text = await file.text();
        while (groups.length > 1) removeGroup(groups[groups.length - 1]);
        ag().tabs.resetTabs();
        clearOutput();
        appendOutput("Importing project...", "info");
        const files = await session.importProject(text);
        appendOutput(`Imported ${files.length} files`, "info");
        await refreshFileTree();
        const entry = files.find(f => f.path.endsWith("main.ach")) || files[0];
        if (entry) await openFile(entry.path);
      } catch (err) { appendOutput(`Import error: ${err.message}`, "error"); }
      importInput.value = "";
    });

    // ═══ DOCS GROUP ═══
    const docsIcon = document.getElementById("activity-docs");
    let docsGroup = null;
    let currentDocSlug = localStorage.getItem("ach-docs-slug") || "getting-started/introduction";

    function toggleDocs() {
      if (docsGroup) closeDocs(); else openDocs();
    }

    function openDocs() {
      if (docsGroup) return;

      const el = document.createElement("div");
      el.className = "docs-group";

      // Header
      const header = document.createElement("div");
      header.className = "docs-group-header";

      const navBtn = document.createElement("button");
      navBtn.className = "docs-nav-btn";
      navBtn.type = "button";
      navBtn.innerHTML = `<svg viewBox="0 0 10 10"><path d="M3 2L7 5L3 8" fill="none" stroke="currentColor" stroke-width="1.3"/></svg> <span>Docs</span>`;

      const actions = document.createElement("div");
      actions.className = "docs-group-actions";

      const extBtn = document.createElement("button");
      extBtn.className = "panel-action-btn";
      extBtn.title = "Open in new tab";
      extBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M7 3H3v10h10V9"/><path d="M9 3h4v4M13 3L7 9"/></svg>`;
      extBtn.addEventListener("click", () => window.open(`/docs/${currentDocSlug}`, "_blank"));

      const closeBtn = document.createElement("button");
      closeBtn.className = "panel-action-btn";
      closeBtn.title = "Close Documentation";
      closeBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>`;
      closeBtn.addEventListener("click", closeDocs);

      actions.append(extBtn, closeBtn);
      header.append(navBtn, actions);

      // Navigation dropdown (auto-positioned)
      const dropdown = document.createElement("div");
      dropdown.className = "docs-nav-dropdown";
      buildDocsNav(dropdown);

      navBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const opening = !dropdown.classList.contains("open");
        if (opening) {
          const rect = navBtn.getBoundingClientRect();
          const spaceBelow = window.innerHeight - rect.bottom;
          const spaceAbove = rect.top;
          dropdown.style.left = rect.left + "px";
          if (spaceBelow < 300 && spaceAbove > spaceBelow) {
            dropdown.style.top = "auto";
            dropdown.style.bottom = (window.innerHeight - rect.top + 2) + "px";
            dropdown.style.maxHeight = (spaceAbove - 20) + "px";
          } else {
            dropdown.style.top = (rect.bottom + 2) + "px";
            dropdown.style.bottom = "auto";
            dropdown.style.maxHeight = (spaceBelow - 20) + "px";
          }
        }
        dropdown.classList.toggle("open", opening);
      });
      const closeDropdown = (e) => {
        if (!dropdown.contains(e.target) && !navBtn.contains(e.target)) dropdown.classList.remove("open");
      };
      document.addEventListener("click", closeDropdown);

      // Content area (shadow DOM host)
      const content = document.createElement("div");
      content.className = "docs-group-content";

      // Make header draggable
      header.draggable = true;
      setupPanelDrag(header, "docs");

      el.append(header, content);
      document.body.appendChild(dropdown);

      docsGroup = { el, navBtn, dropdown, content, closeDropdown };
      docsIcon.classList.add("active");
      localStorage.setItem("ach-docs-open", "true");

      buildMainLayout();
      loadDocsPage(currentDocSlug);
    }

    function closeDocs() {
      if (!docsGroup) return;
      document.removeEventListener("click", docsGroup.closeDropdown);
      docsGroup.dropdown.remove();
      docsGroup = null;
      docsIcon.classList.remove("active");
      localStorage.setItem("ach-docs-open", "false");
      buildMainLayout();
    }

    function buildDocsNav(dropdown) {
      dropdown.innerHTML = "";
      for (const group of sidebarConfig) {
        const lbl = document.createElement("div");
        lbl.className = "docs-nav-group-label";
        lbl.textContent = getLabel(group, "en");
        dropdown.appendChild(lbl);
        for (const item of group.items) {
          const el = document.createElement("div");
          el.className = "docs-nav-item" + (item.slug === currentDocSlug ? " active" : "");
          el.textContent = getLabel(item, "en");
          el.addEventListener("click", () => { dropdown.classList.remove("open"); loadDocsPage(item.slug); });
          dropdown.appendChild(el);
        }
      }
    }

    async function loadDocsPage(slug) {
      currentDocSlug = slug;
      localStorage.setItem("ach-docs-slug", slug);
      if (!docsGroup) return;

      // Update header title
      const flat = sidebarConfig.flatMap(g => g.items);
      const item = flat.find(i => i.slug === slug);
      docsGroup.navBtn.querySelector("span").textContent = item ? getLabel(item, "en") : slug;

      // Update active state in dropdown
      docsGroup.dropdown.querySelectorAll(".docs-nav-item").forEach((el, i) => {
        el.classList.toggle("active", flat[i]?.slug === slug);
      });

      try {
        const res = await fetch(`/docs/${slug}`);
        const html = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");

        const styleLinks = doc.querySelectorAll('link[rel="stylesheet"]');
        const article = doc.querySelector("article");
        const pagination = doc.querySelector("nav.flex.justify-between");

        const container = docsGroup.content;
        let shadow = container.shadowRoot;
        if (!shadow) {
          shadow = container.attachShadow({ mode: "open" });
          // Intercept doc links once
          shadow.addEventListener("click", (e) => {
            const a = e.target.closest('a[href^="/docs/"]');
            if (a) { e.preventDefault(); loadDocsPage(a.getAttribute("href").replace(/^\/docs\//, "").replace(/\/$/, "")); }
          });
        }
        shadow.innerHTML = "";

        for (const link of styleLinks) {
          const l = document.createElement("link");
          l.rel = "stylesheet"; l.href = link.href;
          shadow.appendChild(l);
        }

        const overrides = document.createElement("style");
        overrides.textContent = `
          :host { display: block; height: 100%; overflow-y: auto; background: #13131a; }
          article { padding: 1.5rem !important; max-width: none !important; }
          nav.flex.justify-between { padding: 1rem 1.5rem !important; }
          header, footer, #mobile-nav-toggle, #mobile-nav-dialog { display: none !important; }
          .sticky.top-0 { display: none !important; }
          nav.hidden { display: none !important; }
          aside { display: none !important; }
          .mx-auto { border: none !important; }
        `;
        shadow.appendChild(overrides);

        if (article) shadow.appendChild(article.cloneNode(true));
        if (pagination) shadow.appendChild(pagination.cloneNode(true));
      } catch {
        const container = docsGroup.content;
        const shadow = container.shadowRoot || container.attachShadow({ mode: "open" });
        shadow.innerHTML = `<div style="padding:2rem;color:#969696;font-family:sans-serif;">Failed to load documentation.</div>`;
      }
    }

    docsIcon.addEventListener("click", toggleDocs);

    // Restore docs panel if was open
    if (localStorage.getItem("ach-docs-open") === "true") openDocs();

    // ═══ TAB DRAG & DROP ═══
    function clearDropIndicators() {
      document.querySelectorAll(".drag-over-center,.drag-over-left,.drag-over-right").forEach(
        el => el.classList.remove("drag-over-center", "drag-over-left", "drag-over-right")
      );
    }

    groupsWrapper.addEventListener("dragover", (e) => {
      if (!e.dataTransfer.types.includes("text/x-ach-tab")) return;
      e.preventDefault();
      e.dataTransfer.dropEffect = "move";
      clearDropIndicators();
      const target = e.target.closest(".editor-group, .docs-group");
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      if (ratio < 0.2) target.classList.add("drag-over-left");
      else if (ratio > 0.8) target.classList.add("drag-over-right");
      else if (target.classList.contains("editor-group")) target.classList.add("drag-over-center");
    });

    groupsWrapper.addEventListener("dragleave", (e) => {
      if (!groupsWrapper.contains(e.relatedTarget)) clearDropIndicators();
    });

    groupsWrapper.addEventListener("drop", (e) => {
      if (!e.dataTransfer.types.includes("text/x-ach-tab")) return;
      e.preventDefault();
      clearDropIndicators();
      const data = JSON.parse(e.dataTransfer.getData("text/x-ach-tab"));
      const srcGroup = groups.find(g => g.id === data.groupId);
      if (!srcGroup) return;

      const target = e.target.closest(".editor-group, .docs-group");
      if (!target) return;
      const rect = target.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      const targetIdx = groups.findIndex(g => g.el === target);
      const isDocsTarget = target.classList.contains("docs-group");

      if (ratio < 0.2) {
        const insertAt = isDocsTarget ? groups.length : Math.max(0, targetIdx);
        moveTabToNewGroupAt(srcGroup, data.tabIdx, insertAt);
      } else if (ratio > 0.8) {
        const insertAt = isDocsTarget ? groups.length : targetIdx + 1;
        moveTabToNewGroupAt(srcGroup, data.tabIdx, insertAt);
      } else if (targetIdx >= 0 && srcGroup !== groups[targetIdx]) {
        moveTabBetweenGroups(srcGroup, data.tabIdx, groups[targetIdx]);
      }
    });

    function moveTabBetweenGroups(src, tabIdx, dst) {
      src.tabs.saveEditorState(src.view.state);
      const t = src.tabs.getTabs()[tabIdx];
      const path = t.path, content = t.editorState.doc.toString();
      const savedContent = t.savedContent, modified = t.modified;

      src.tabs.closeTab(tabIdx);
      const rem = src.tabs.getActiveTab();
      if (rem) src.view.setState(rem.editorState);
      else if (groups.length > 1) { removeGroup(src); }
      else src.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(src) }));

      dst.tabs.saveEditorState(dst.view.state);
      dst.tabs.openTab(path, content, editorExtensions(dst));
      if (modified) {
        const ni = dst.tabs.getActiveIndex();
        dst.tabs.setModified(ni, true);
        dst.tabs.getTabs()[ni].savedContent = savedContent;
      }
      dst.view.setState(dst.tabs.getActiveTab().editorState);
      setActiveGroup(groups.indexOf(dst));
      renderAllGroups();
    }

    function moveTabToNewGroupAt(src, tabIdx, insertAt) {
      src.tabs.saveEditorState(src.view.state);
      const t = src.tabs.getTabs()[tabIdx];
      const path = t.path, content = t.editorState.doc.toString();
      const savedContent = t.savedContent, modified = t.modified;

      src.tabs.closeTab(tabIdx);
      const rem = src.tabs.getActiveTab();
      if (rem) src.view.setState(rem.editorState);
      else if (groups.length > 1) {
        const srcIdx = groups.indexOf(src);
        removeGroup(src);
        if (insertAt > srcIdx) insertAt--;
      } else {
        src.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(src) }));
      }

      const newGroup = createGroup();
      // Move to correct position if needed
      const curIdx = groups.indexOf(newGroup);
      if (insertAt < curIdx) {
        groups.splice(curIdx, 1);
        groups.splice(insertAt, 0, newGroup);
        rebuildGroupsDOM();
      }

      newGroup.tabs.openTab(path, content, editorExtensions(newGroup));
      if (modified) {
        const ni = newGroup.tabs.getActiveIndex();
        newGroup.tabs.setModified(ni, true);
        newGroup.tabs.getTabs()[ni].savedContent = savedContent;
      }
      newGroup.view.setState(newGroup.tabs.getActiveTab().editorState);
      setActiveGroup(groups.indexOf(newGroup));
      renderAllGroups();
    }

    function rebuildGroupsDOM() {
      groupsWrapper.querySelectorAll(".group-split-handle").forEach(h => h.remove());
      groups.forEach((g, i) => {
        if (i > 0) {
          const h = document.createElement("div");
          h.className = "group-split-handle";
          setupGroupSplitHandle(h);
          groupsWrapper.appendChild(h);
        }
        groupsWrapper.appendChild(g.el);
      });
      if (docsGroup) {
        const h = document.createElement("div");
        h.className = "group-split-handle";
        setupGroupSplitHandle(h);
        groupsWrapper.append(h, docsGroup.el);
        docsGroup.handle = h;
      }
    }

    // ═══ GLOBAL KEYBOARD SHORTCUTS ═══
    document.addEventListener("keydown", (e) => {
      // Skip when command palette dialog is open (let it handle its own keys)
      const dialogOpen = document.getElementById("cmd-palette-native")?.open;
      if (dialogOpen && e.key !== "Escape") return;

      const mod = e.ctrlKey || e.metaKey;
      if (!mod) return;
      if (e.key === "Enter") { e.preventDefault(); runCode(); }
      if (e.key === "s") { e.preventDefault(); saveActiveFile(); }
      if (e.key === "b") { e.preventDefault(); toggleSidebar(); }
      if (e.key === "`") { e.preventDefault(); togglePanel(); }
      if (e.key === "j") { e.preventDefault(); togglePanel(); }
      if (e.key === "\\") { e.preventDefault(); splitRight(); }
      if (e.shiftKey && e.key === "D") { e.preventDefault(); toggleDocs(); }
      if (e.key === "k") { e.preventDefault(); openCommandPalette(); }
      if (e.shiftKey && e.key === "P") { e.preventDefault(); openCommandPalette(); }
    });

    // ═══ COMMAND PALETTE ═══
    const cmdDialog = document.getElementById("cmd-palette-dialog");
    const cmdPalette = document.getElementById("cmd-palette");
    const cmdFilesGroup = document.getElementById("cmd-files-group");
    const cmdDocsGroup = document.getElementById("cmd-docs-group");

    const cmdActions = {
      runCode:             () => runCode(),
      saveActiveFile:      () => saveActiveFile(),
      clearOutput:         () => clearOutput(),
      toggleSidebar:       () => toggleSidebar(),
      togglePanel:         () => togglePanel(),
      togglePanelPosition: () => togglePanelPosition(),
      splitRight:          () => splitRight(),
      toggleDocs:          () => toggleDocs(),
      createNewFile:       () => createNewFile(),
      createNewFolder:     () => createNewFolder(),
      exportProject:       () => session.exportProject().catch(e => appendOutput(`Export error: ${e.message}`, "error")),
      importProject:       () => document.getElementById("import-input").click(),
    };

    function openCommandPalette() {
      refreshCommandPaletteFiles();
      cmdDialog.show();
      cmdPalette.reset();
      const input = cmdPalette.querySelector("input");
      if (input) { input.value = ""; input.focus(); }
    }

    function closeCommandPalette() {
      cmdDialog.hide();
    }

    cmdDialog.addEventListener("close", () => {
      const group = ag();
      if (group?.view) setTimeout(() => group.view.focus(), 0);
    });

    // Dynamic file list
    async function refreshCommandPaletteFiles() {
      const label = cmdFilesGroup.querySelector(".cmd-group-label");
      cmdFilesGroup.replaceChildren(label);

      if (!session.isProjectMode()) {
        cmdFilesGroup.setAttribute("hidden", "");
        return;
      }
      try {
        const files = await session.listFiles();
        const fileEntries = files.filter(f => f.type !== "dir");
        if (fileEntries.length === 0) { cmdFilesGroup.setAttribute("hidden", ""); return; }
        cmdFilesGroup.removeAttribute("hidden");
        for (const f of fileEntries) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "cmd-item";
          btn.dataset.action = `file:${f.path}`;
          btn.setAttribute("aria-label", f.path);
          const name = f.path.split("/").pop();
          const dir = f.path.includes("/") ? f.path.substring(0, f.path.lastIndexOf("/")) : "";
          btn.innerHTML = `<span class="cmd-item-label">${name}${dir ? `<span class="cmd-file-path">${dir}</span>` : ""}</span>`;
          cmdFilesGroup.appendChild(btn);
        }
      } catch { cmdFilesGroup.setAttribute("hidden", ""); }
    }

    // Documentation commands (populated once)
    function populateDocsCommands() {
      const label = cmdDocsGroup.querySelector(".cmd-group-label");
      cmdDocsGroup.replaceChildren(label);
      for (const group of sidebarConfig) {
        for (const item of group.items) {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "cmd-item";
          btn.dataset.action = `doc:${item.slug}`;
          btn.setAttribute("aria-label", `Docs: ${item.label}`);
          btn.innerHTML = `<span class="cmd-item-label">${item.label}</span>`;
          cmdDocsGroup.appendChild(btn);
        }
      }
    }
    populateDocsCommands();

    // Click dispatch
    cmdPalette.addEventListener("click", (e) => {
      const btn = e.target.closest(".cmd-item");
      if (!btn) return;
      const action = btn.dataset.action;
      if (!action) return;
      closeCommandPalette();
      if (action.startsWith("file:")) {
        openFile(action.substring(5));
      } else if (action.startsWith("doc:")) {
        if (!docsGroup) openDocs();
        loadDocsPage(action.substring(4));
      } else if (action.startsWith("template:")) {
        loadTemplate(action.substring(9));
      } else if (cmdActions[action]) {
        cmdActions[action]();
      }
    });

    // Custom filter: multi-word fuzzy
    if (cmdPalette.setFilterCallback) {
      cmdPalette.setFilterCallback(({ query, content }) => {
        const q = query.toLowerCase().trim();
        if (!q) return true;
        const text = (content || "").toLowerCase();
        return q.split(/\s+/).every(w => text.includes(w));
      });
    }

    // Mac shortcut labels
    if (navigator.platform?.includes("Mac") || navigator.userAgent?.includes("Mac")) {
      document.querySelectorAll(".cmd-kbd[data-shortcut]").forEach(kbd => {
        kbd.textContent = kbd.textContent
          .replace(/Ctrl\+/g, "⌘")
          .replace(/Shift\+/g, "⇧")
          .replace(/Alt\+/g, "⌥");
      });
    }

    // ═══ INIT ═══
    createGroup();
    applySidebarLayout();
    buildMainLayout();
    setupRootDrop(fileTree, {
      onFileMove: async (oldPath, newPath) => {
        if (!newPath || newPath === oldPath) return;
        try {
          await session.renameFile(oldPath, newPath);
          for (const g of groups) g.tabs.updateTabPath(oldPath, newPath);
          renderAllGroups(); refreshFileTree();
        } catch (e) { appendOutput(`Move error: ${e.message}`, "error"); }
      },
    });

    session.healthCheck().then(ok => {
      if (ok) { serverDot.classList.remove("loading", "error"); serverLabel.textContent = "Server"; }
    }).catch(() => { serverDot.classList.add("error"); serverLabel.textContent = "Offline"; });

    initLspWasm().then(() => {
      const el = document.getElementById("lsp-status");
      if (el) { el.textContent = "LSP"; el.style.opacity = "0.85"; }
    });

    (async () => {
      const restored = await session.restoreSession();
      if (restored) {
        appendOutput("Session restored", "info");
        await refreshFileTree();
        const files = await session.listFiles();
        const entry = files.find(f => f.path.endsWith("main.ach")) || files[0];
        if (entry) await openFile(entry.path);
      } else {
        loadTemplate("vm");
      }
    })();
  </script>
</body>
</html>
