---
// Standalone playground page — mini-IDE with file system
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Achronyme Playground — Write and run ZK programs in your browser" />
  <title>Playground — Achronyme</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-titlebar: #17171c;
      --bg-sidebar: #1c1c22;
      --bg-editor: #121217;
      --bg-terminal: #0e0e12;
      --bg-statusbar: #7c3aed;
      --bg-active-tab: #121217;
      --bg-inactive-tab: #19191e;
      --border: #2a2a32;
      --text-primary: #f5f5fa;
      --text-secondary: #b0b0c4;
      --text-muted: #606070;
      --accent: #a855f7;
      --accent-dim: #7c3aed;
      --green: #34d399;
      --green-dim: #059669;
      --red: #f87171;
      --yellow: #fbbf24;
      --font-mono: "JetBrains Mono", "Fira Code", "Consolas", ui-monospace, monospace;
      --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; background: var(--bg-editor); color: var(--text-primary); font-family: var(--font-mono); -webkit-font-smoothing: antialiased; }
    ::selection { background: rgba(168, 85, 247, 0.3); color: var(--text-primary); }

    .shell {
      display: grid;
      grid-template-rows: 38px 36px 1fr 24px;
      grid-template-columns: 220px 1fr;
      height: 100vh; width: 100vw;
    }

    /* ═══ TITLE BAR ═══ */
    .titlebar { grid-column: 1 / -1; background: var(--bg-titlebar); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 16px; }
    .titlebar-left { display: flex; align-items: center; gap: 14px; }
    .window-dots { display: flex; gap: 8px; }
    .window-dots span { width: 12px; height: 12px; border-radius: 50%; }
    .dot-close { background: #ff5f57; } .dot-min { background: #ffbd2e; } .dot-max { background: #28c840; }
    .titlebar-title { font-family: var(--font-sans); font-size: 12px; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.02em; }
    .titlebar-title em { font-style: normal; color: var(--accent); }
    .titlebar-links { display: flex; align-items: center; gap: 16px; }
    .titlebar-links a { font-size: 11px; color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
    .titlebar-links a:hover { color: var(--text-primary); }

    /* ═══ SIDEBAR ═══ */
    .sidebar { grid-row: 2 / 4; background: var(--bg-sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }
    .sidebar-header { display: flex; align-items: center; justify-content: space-between; padding: 0 12px; height: 36px; border-bottom: 1px solid var(--border); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-family: var(--font-sans); font-weight: 600; }
    .sidebar-btn { background: none; border: none; color: var(--text-muted); font-size: 16px; cursor: pointer; padding: 2px 4px; border-radius: 3px; }
    .sidebar-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
    .file-tree { flex: 1; overflow-y: auto; padding: 4px 0; }
    .file-row { display: flex; align-items: center; gap: 8px; padding: 4px 12px; font-size: 12px; color: var(--text-secondary); cursor: pointer; user-select: none; }
    .file-row:hover { background: rgba(255,255,255,0.04); }
    .file-row.active { background: rgba(168, 85, 247, 0.12); color: var(--text-primary); }
    .file-icon { font-size: 11px; flex-shrink: 0; width: 14px; text-align: center; }
    .file-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-footer { padding: 8px; border-top: 1px solid var(--border); }
    .template-select { width: 100%; font-family: var(--font-mono); font-size: 10px; background: var(--bg-editor); color: var(--text-secondary); border: 1px solid var(--border); border-radius: 4px; padding: 5px 6px; cursor: pointer; outline: none; }
    .template-select:hover, .template-select:focus { border-color: var(--accent-dim); }

    /* ═══ TAB BAR ═══ */
    .tabbar { background: var(--bg-inactive-tab); border-bottom: 1px solid var(--border); display: flex; align-items: stretch; overflow-x: auto; }
    .tab { display: flex; align-items: center; gap: 6px; padding: 0 14px; font-size: 12px; color: var(--text-muted); background: var(--bg-inactive-tab); border-right: 1px solid var(--border); cursor: pointer; white-space: nowrap; user-select: none; min-width: 0; }
    .tab.active { background: var(--bg-active-tab); color: var(--text-primary); border-bottom: 2px solid var(--accent); margin-bottom: -1px; }
    .tab-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted); flex-shrink: 0; display: none; }
    .tab.modified .tab-dot { display: block; background: var(--accent); }
    .tab-close { font-size: 14px; opacity: 0; margin-left: 4px; padding: 0 2px; border: none; background: none; color: var(--text-muted); cursor: pointer; }
    .tab:hover .tab-close, .tab.active .tab-close { opacity: 0.6; }
    .tab-close:hover { opacity: 1 !important; color: var(--red); }
    .tab-actions { margin-left: auto; display: flex; align-items: center; gap: 8px; padding: 0 12px; flex-shrink: 0; }
    .run-btn { font-family: var(--font-sans); font-size: 11px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; background: linear-gradient(135deg, var(--green-dim), var(--green)); border: none; border-radius: 4px; padding: 5px 16px; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: all 0.2s; box-shadow: 0 0 12px rgba(52, 211, 153, 0.15); }
    .run-btn:hover { transform: translateY(-1px); box-shadow: 0 2px 20px rgba(52, 211, 153, 0.3); }
    .run-btn:active { transform: translateY(0); }
    .run-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
    .run-btn svg { width: 10px; height: 12px; fill: #fff; }

    /* ═══ MAIN AREA ═══ */
    .main-area { display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }

    /* ═══ EDITOR ═══ */
    .editor-panel { display: flex; flex-direction: column; overflow: hidden; border-right: 1px solid var(--border); }
    #editor-container { flex: 1; overflow: hidden; }
    #editor-container .cm-editor { height: 100%; font-family: var(--font-mono); font-size: 13px; }
    #editor-container .cm-editor .cm-scroller { font-family: var(--font-mono) !important; }
    #editor-container .cm-editor.cm-focused { outline: none; }
    #editor-container .cm-gutters { background: #16161b; border-right: 1px solid var(--border); color: #4a4a58; }
    #editor-container .cm-activeLineGutter { color: var(--text-secondary); }
    #editor-container .cm-cursor { border-left-color: var(--accent); }
    #editor-container .cm-selectionBackground { background: rgba(168, 85, 247, 0.25) !important; }

    /* ═══ OUTPUT ═══ */
    .output-panel { display: flex; flex-direction: column; overflow: hidden; }
    .output-header { display: flex; align-items: center; gap: 16px; padding: 0 16px; height: 32px; background: var(--bg-sidebar); border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .output-tab { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); cursor: default; padding-bottom: 1px; }
    .output-tab.active { color: var(--text-primary); border-bottom: 1px solid var(--accent); }
    .output-clear { margin-left: auto; font-size: 10px; color: var(--text-muted); background: none; border: 1px solid var(--border); border-radius: 3px; padding: 2px 8px; cursor: pointer; font-family: var(--font-mono); }
    .output-clear:hover { color: var(--text-secondary); border-color: var(--text-muted); }
    .output-scroll { flex: 1; overflow: auto; background: var(--bg-terminal); padding: 12px 16px; }
    .output-line { font-size: 12px; line-height: 20px; white-space: pre-wrap; word-break: break-all; }
    .output-line.stdout { color: var(--green); }
    .output-line.error { color: var(--red); }
    .output-line.info { color: var(--text-muted); font-style: italic; }
    .output-line.timing { color: var(--yellow); }
    .output-cursor { display: inline-block; width: 7px; height: 14px; background: var(--green); animation: blink 1s step-end infinite; vertical-align: text-bottom; margin-left: 2px; }
    @keyframes blink { 50% { opacity: 0; } }

    /* ═══ STATUS BAR ═══ */
    .statusbar { grid-column: 1 / -1; background: var(--bg-statusbar); display: flex; align-items: center; justify-content: space-between; padding: 0 12px; font-size: 11px; color: #fff; font-family: var(--font-sans); }
    .statusbar-left, .statusbar-right { display: flex; align-items: center; gap: 16px; }
    .status-item { display: flex; align-items: center; gap: 5px; opacity: 0.85; }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px rgba(52, 211, 153, 0.5); }
    .status-dot.loading { background: var(--yellow); box-shadow: 0 0 6px rgba(251, 191, 36, 0.5); animation: pulse 1.2s ease-in-out infinite; }
    .status-dot.error { background: var(--red); box-shadow: 0 0 6px rgba(248, 113, 113, 0.5); }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* ═══ LINT / HOVER / AUTOCOMPLETE ═══ */
    .cm-diagnostic { font-family: var(--font-mono); font-size: 12px; padding: 4px 8px; }
    .cm-diagnostic-error { border-left: 3px solid var(--red); }
    .cm-diagnostic-warning { border-left: 3px solid var(--yellow); }
    .cm-lintRange-error { background: none; text-decoration: wavy underline var(--red); text-underline-offset: 3px; }
    .cm-lintRange-warning { background: none; text-decoration: wavy underline var(--yellow); text-underline-offset: 3px; }
    .cm-tooltip { background: #1e1e28 !important; border: 1px solid var(--border) !important; border-radius: 6px !important; }
    .ach-hover-tooltip { padding: 10px 14px; font-family: var(--font-mono); font-size: 12px; line-height: 1.5; color: var(--text-primary); max-width: 480px; }
    .ach-hover-code { background: #13131a; border-radius: 4px; padding: 8px 10px; margin: 6px 0; font-size: 12px; color: var(--green); overflow-x: auto; }
    .ach-hover-inline { background: rgba(168, 85, 247, 0.15); border-radius: 3px; padding: 1px 5px; font-size: 11px; color: var(--accent); }
    .cm-tooltip-autocomplete { background: #1e1e28 !important; border: 1px solid var(--border) !important; border-radius: 6px !important; }
    .cm-tooltip-autocomplete ul li { font-family: var(--font-mono); font-size: 12px; }
    .cm-tooltip-autocomplete ul li[aria-selected] { background: rgba(168, 85, 247, 0.2) !important; }

    /* ═══ CONTEXT MENU ═══ */
    .context-menu { position: fixed; background: var(--bg-sidebar); border: 1px solid var(--border); border-radius: 6px; padding: 4px 0; z-index: 100; min-width: 120px; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
    .context-item { padding: 6px 14px; font-size: 12px; color: var(--text-secondary); cursor: pointer; font-family: var(--font-sans); }
    .context-item:hover { background: rgba(168, 85, 247, 0.15); color: var(--text-primary); }
    .context-item.danger:hover { background: rgba(248, 113, 113, 0.15); color: var(--red); }

    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #4a4a58; }

    @media (max-width: 768px) {
      .shell { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .main-area { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
    }
  </style>
</head>

<body>
  <div class="shell">
    <div class="titlebar">
      <div class="titlebar-left">
        <div class="window-dots"><span class="dot-close"></span><span class="dot-min"></span><span class="dot-max"></span></div>
        <div class="titlebar-title"><em>ach</em>&ensp;playground</div>
      </div>
      <div class="titlebar-links">
        <a href="https://docs.achrony.me" target="_blank">docs</a>
        <a href="https://github.com/achronyme/achronyme" target="_blank">github</a>
        <a href="/">home</a>
      </div>
    </div>

    <div class="sidebar">
      <div class="sidebar-header">
        <span>Explorer</span>
        <button class="sidebar-btn" id="new-file-btn" title="New File">+</button>
      </div>
      <div class="file-tree" id="file-tree"></div>
      <div class="sidebar-footer">
        <select class="template-select" id="template-select">
          <option value="">Load Template...</option>
          <option value="hello-world">Hello World (multi-file)</option>
          <option value="merkle-proof">Merkle Proof (ZK)</option>
          <option value="voting-circuit">Voting Circuit (ZK)</option>
        </select>
      </div>
    </div>

    <div class="tabbar" id="tabbar">
      <div class="tab-actions">
        <button class="run-btn" id="run-btn">
          <svg viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg>
          Run
        </button>
      </div>
    </div>

    <div class="main-area">
      <div class="editor-panel">
        <div id="editor-container"></div>
      </div>
      <div class="output-panel">
        <div class="output-header">
          <span class="output-tab active">output</span>
          <button class="output-clear" id="clear-btn">clear</button>
        </div>
        <div class="output-scroll" id="output">
          <div class="output-line info">// Select a template to get started</div>
          <span class="output-cursor"></span>
        </div>
      </div>
    </div>

    <div class="statusbar">
      <div class="statusbar-left">
        <span class="status-item">achronyme playground</span>
        <span class="status-item" id="status-line">Ln 1, Col 1</span>
      </div>
      <div class="statusbar-right">
        <span class="status-item" id="lsp-status" style="opacity:0.4">LSP...</span>
        <span class="status-item">v0.1.0-beta.17</span>
        <span class="status-item" id="server-status">
          <span class="status-dot" id="server-dot"></span>
          <span id="server-label">Server</span>
        </span>
      </div>
    </div>
  </div>

  <script>
    import { EditorState } from "@codemirror/state";
    import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
    import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
    import { syntaxHighlighting, defaultHighlightStyle, bracketMatching, indentOnInput } from "@codemirror/language";
    import { oneDark } from "@codemirror/theme-one-dark";
    import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";
    import { highlightSelectionMatches } from "@codemirror/search";
    import { achronymeLanguage } from "../lib/achronyme-lang.js";
    import { initLspWasm, achLinter, achAutocompletion, achHover } from "../lib/achronyme-lsp.js";
    import { renderFileTree, promptNewFile } from "../lib/playground-filetree.js";
    import * as tabs from "../lib/playground-tabs.js";
    import * as session from "../lib/playground-session.js";

    // ═══ DOM ═══
    const output = document.getElementById("output");
    const runBtn = document.getElementById("run-btn");
    const clearBtn = document.getElementById("clear-btn");
    const tabbar = document.getElementById("tabbar");
    const fileTree = document.getElementById("file-tree");
    const templateSelect = document.getElementById("template-select");
    const newFileBtn = document.getElementById("new-file-btn");
    const statusLine = document.getElementById("status-line");
    const serverDot = document.getElementById("server-dot");
    const serverLabel = document.getElementById("server-label");

    // ═══ EDITOR EXTENSIONS ═══
    function editorExtensions() {
      return [
        lineNumbers(),
        highlightActiveLine(),
        highlightActiveLineGutter(),
        history(),
        bracketMatching(),
        closeBrackets(),
        indentOnInput(),
        highlightSelectionMatches(),
        oneDark,
        editorTheme,
        syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
        achronymeLanguage,
        achLinter,
        achAutocompletion,
        achHover,
        keymap.of([
          indentWithTab,
          ...closeBracketsKeymap,
          ...defaultKeymap,
          ...historyKeymap,
        ]),
        runKeymap,
        cursorTracker,
        autoSaveListener,
        EditorView.lineWrapping,
      ];
    }

    const runKeymap = keymap.of([{
      key: "Ctrl-Enter", mac: "Cmd-Enter",
      run: () => { runCode(); return true; },
    }, {
      key: "Ctrl-s", mac: "Cmd-s",
      run: () => { saveActiveFile(); return true; },
    }]);

    const cursorTracker = EditorView.updateListener.of((update) => {
      if (update.selectionSet || update.docChanged) {
        const pos = update.state.selection.main.head;
        const line = update.state.doc.lineAt(pos);
        statusLine.textContent = `Ln ${line.number}, Col ${pos - line.from + 1}`;
      }
    });

    let saveTimeout = null;
    const autoSaveListener = EditorView.updateListener.of((update) => {
      if (update.docChanged && session.isProjectMode()) {
        const tab = tabs.getActiveTab();
        if (tab) {
          const content = update.state.doc.toString();
          const idx = tabs.getActiveIndex();
          tabs.setModified(idx, tabs.isModified(idx, content));
          renderTabs();
        }
        clearTimeout(saveTimeout);
        saveTimeout = setTimeout(() => saveActiveFile(), 1000);
      }
    });

    const editorTheme = EditorView.theme({
      "&": { backgroundColor: "var(--bg-editor)" },
      ".cm-content": { caretColor: "var(--accent)", fontFamily: "var(--font-mono)" },
      ".cm-gutters": { backgroundColor: "#16161b", borderRight: "1px solid var(--border)", color: "#4a4a58" },
      ".cm-activeLineGutter": { color: "var(--text-secondary)", backgroundColor: "transparent" },
      ".cm-activeLine": { backgroundColor: "rgba(168, 85, 247, 0.04)" },
      "&.cm-focused .cm-cursor": { borderLeftColor: "var(--accent)" },
      "&.cm-focused .cm-selectionBackground, .cm-selectionBackground": { backgroundColor: "rgba(168, 85, 247, 0.25) !important" },
    }, { dark: true });

    // ═══ EDITOR INSTANCE ═══
    let view = new EditorView({
      state: EditorState.create({
        doc: "// Select a template from the sidebar to get started\n",
        extensions: editorExtensions(),
      }),
      parent: document.getElementById("editor-container"),
    });

    // ═══ OUTPUT ═══
    function clearOutput() { output.innerHTML = '<span class="output-cursor"></span>'; }
    function appendOutput(text, cls = "stdout") {
      const cursor = output.querySelector(".output-cursor");
      const line = document.createElement("div");
      line.className = `output-line ${cls}`;
      line.textContent = text;
      output.insertBefore(line, cursor);
      output.scrollTop = output.scrollHeight;
    }

    // ═══ TAB RENDERING ═══
    function renderTabs() {
      const actions = tabbar.querySelector(".tab-actions");
      tabbar.innerHTML = "";

      for (let i = 0; i < tabs.getTabs().length; i++) {
        const t = tabs.getTabs()[i];
        const tab = document.createElement("div");
        tab.className = "tab" + (i === tabs.getActiveIndex() ? " active" : "") + (t.modified ? " modified" : "");

        const dot = document.createElement("span");
        dot.className = "tab-dot";

        const name = document.createElement("span");
        name.textContent = t.path.split("/").pop();
        name.title = t.path;

        const close = document.createElement("button");
        close.className = "tab-close";
        close.textContent = "\u00D7";
        close.addEventListener("click", (e) => {
          e.stopPropagation();
          closeTabAt(i);
        });

        tab.appendChild(dot);
        tab.appendChild(name);
        tab.appendChild(close);
        tab.addEventListener("click", () => switchToTab(i));
        tabbar.appendChild(tab);
      }

      tabbar.appendChild(actions);
    }

    // ═══ FILE OPERATIONS ═══
    async function openFile(path) {
      const existing = tabs.findTab(path);
      if (existing >= 0) {
        switchToTab(existing);
        return;
      }

      try {
        const content = await session.readFile(path);
        tabs.saveEditorState(view.state);
        tabs.openTab(path, content, editorExtensions());

        const tab = tabs.getActiveTab();
        view.setState(tab.editorState);
        renderTabs();
        refreshFileTree();
      } catch (e) {
        appendOutput(`Error: ${e.message}`, "error");
      }
    }

    function switchToTab(index) {
      if (index === tabs.getActiveIndex()) return;
      tabs.saveEditorState(view.state);
      tabs.switchTab(index);
      const tab = tabs.getActiveTab();
      if (tab) view.setState(tab.editorState);
      renderTabs();
      refreshFileTree();
    }

    function closeTabAt(index) {
      tabs.saveEditorState(view.state);
      const newIdx = tabs.closeTab(index);
      const tab = tabs.getActiveTab();
      if (tab) {
        view.setState(tab.editorState);
      } else {
        view.setState(EditorState.create({ doc: "", extensions: editorExtensions() }));
      }
      renderTabs();
    }

    async function saveActiveFile() {
      const tab = tabs.getActiveTab();
      if (!tab || !session.isProjectMode()) return;
      tabs.saveEditorState(view.state);
      const content = view.state.doc.toString();
      try {
        await session.writeFile(tab.path, content);
        tabs.markSaved(tabs.getActiveIndex(), content);
        renderTabs();
      } catch (e) {
        appendOutput(`Save error: ${e.message}`, "error");
      }
    }

    async function refreshFileTree() {
      if (!session.isProjectMode()) return;
      try {
        const files = await session.listFiles();
        const activeTab = tabs.getActiveTab();
        renderFileTree(fileTree, files, activeTab?.path || "", {
          onFileClick: openFile,
          onFileDelete: async (path) => {
            if (!confirm(`Delete ${path}?`)) return;
            await session.deleteFile(path);
            tabs.removeTabByPath(path);
            const tab = tabs.getActiveTab();
            if (tab) view.setState(tab.editorState);
            renderTabs();
            refreshFileTree();
          },
          onFileRename: async (path) => {
            const newName = prompt("New name:", path);
            if (!newName || newName === path) return;
            await session.renameFile(path, newName);
            tabs.updateTabPath(path, newName);
            renderTabs();
            refreshFileTree();
          },
        });
      } catch (e) {
        console.warn("file tree refresh failed:", e);
      }
    }

    // ═══ RUN ═══
    let running = false;
    async function runCode() {
      if (running) return;

      // Auto-save all modified files first
      if (session.isProjectMode()) {
        await saveActiveFile();
      }

      clearOutput();
      running = true;
      runBtn.disabled = true;
      serverDot.classList.add("loading");
      serverLabel.textContent = "Running...";

      try {
        const source = session.isProjectMode() ? null : view.state.doc.toString();
        if (!session.isProjectMode() && (!source || !source.trim())) {
          appendOutput("// Nothing to run", "info");
          return;
        }
        const data = await session.runProject(source);

        if (data.output) {
          for (const line of data.output.split("\n")) {
            if (line) appendOutput(line, "stdout");
          }
        }
        if (!data.success) {
          if (data.output) appendOutput("", "stdout");
          appendOutput(data.error, "error");
        }
        appendOutput("", "stdout");
        appendOutput(`[${data.time_ms}ms server]`, "timing");
      } catch (e) {
        appendOutput(e.message, "error");
        serverDot.classList.add("error");
        serverLabel.textContent = "Offline";
        return;
      } finally {
        running = false;
        runBtn.disabled = false;
        serverDot.classList.remove("loading");
        serverLabel.textContent = "Server";
      }
    }

    // ═══ TEMPLATE LOADING ═══
    async function loadTemplate(name) {
      if (!name) return;
      try {
        clearOutput();
        appendOutput("// Creating project...", "info");

        // Delete old session if any
        if (session.isProjectMode()) {
          await session.deleteSession();
        }
        tabs.resetTabs();

        const data = await session.createSession(name);
        appendOutput(`// Project created (${data.files.length} files)`, "info");

        await refreshFileTree();

        // Open the entry file
        const entry = data.files.find(f => f.path.endsWith("main.ach")) || data.files[0];
        if (entry) await openFile(entry.path);

        templateSelect.value = "";
      } catch (e) {
        appendOutput(`Template error: ${e.message}`, "error");
      }
    }

    // ═══ NEW FILE ═══
    async function createNewFile() {
      if (!session.isProjectMode()) {
        appendOutput("// Create a project first (select a template)", "info");
        return;
      }
      const name = promptNewFile();
      if (!name) return;
      try {
        await session.writeFile(name, `// ${name.split("/").pop()}\n`);
        await refreshFileTree();
        await openFile(name);
      } catch (e) {
        appendOutput(`Error: ${e.message}`, "error");
      }
    }

    // ═══ EVENTS ═══
    runBtn.addEventListener("click", runCode);
    clearBtn.addEventListener("click", clearOutput);
    templateSelect.addEventListener("change", (e) => loadTemplate(e.target.value));
    newFileBtn.addEventListener("click", createNewFile);

    // ═══ INIT ═══
    session.healthCheck().then(ok => {
      if (ok) { serverDot.classList.remove("loading", "error"); serverLabel.textContent = "Server"; }
    }).catch(() => { serverDot.classList.add("error"); serverLabel.textContent = "Offline"; });

    initLspWasm().then(() => {
      const el = document.getElementById("lsp-status");
      if (el) { el.textContent = "LSP"; el.style.opacity = "0.85"; }
    });

    // Auto-load hello-world template on first visit
    loadTemplate("hello-world");
  </script>
</body>
</html>
