---
// Standalone playground page — mini-IDE with file system
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Achronyme Playground — Write and run ZK programs in your browser" />
  <title>Playground — Achronyme</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style is:global>
    :root {
      --bg-titlebar: #1e1e1e;
      --bg-activitybar: #181818;
      --bg-sidebar: #1e1e1e;
      --bg-editor: #1e1e1e;
      --bg-terminal: #181818;
      --bg-statusbar: #7c3aed;
      --bg-active-tab: #1e1e1e;
      --bg-inactive-tab: #2d2d2d;
      --bg-tab-row: #181818;
      --bg-breadcrumb: #1e1e1e;
      --bg-input: #313131;
      --border: #2b2b2b;
      --border-active: #414141;
      --text-primary: #cccccc;
      --text-secondary: #969696;
      --text-muted: #5a5a5a;
      --text-bright: #e8e8e8;
      --accent: #a855f7;
      --accent-dim: #7c3aed;
      --focus: rgba(168, 85, 247, 0.4);
      --green: #4ec9b0;
      --green-bright: #73d0b5;
      --red: #f14c4c;
      --yellow: #cca700;
      --blue: #569cd6;
      --orange: #ce9178;
      --font-mono: "JetBrains Mono Variable", "JetBrains Mono", "Cascadia Code", "Fira Code", "Consolas", monospace;
      --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; background: var(--bg-editor); color: var(--text-primary); font-family: var(--font-mono); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    ::selection { background: rgba(168, 85, 247, 0.35); }

    /* ═══ SHELL GRID ═══ */
    .shell {
      display: grid;
      grid-template-rows: 30px 1fr 22px;
      grid-template-columns: 48px 240px 1fr;
      height: 100vh; width: 100vw;
    }

    /* ═══ TITLE BAR ═══ */
    .titlebar {
      grid-column: 1 / -1;
      background: var(--bg-titlebar);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      position: relative;
      -webkit-app-region: drag;
    }
    .titlebar-left { position: absolute; left: 12px; display: flex; align-items: center; gap: 8px; -webkit-app-region: no-drag; }
    .window-dots { display: flex; gap: 8px; }
    .window-dots span { width: 12px; height: 12px; border-radius: 50%; }
    .dot-close { background: #ff5f57; } .dot-min { background: #ffbd2e; } .dot-max { background: #28c840; }
    .titlebar-center { font-family: var(--font-sans); font-size: 11px; color: var(--text-secondary); letter-spacing: 0.01em; }
    .titlebar-center em { font-style: normal; color: var(--text-primary); font-weight: 500; }
    .titlebar-right { position: absolute; right: 12px; display: flex; gap: 14px; -webkit-app-region: no-drag; }
    .titlebar-right a { font-family: var(--font-sans); font-size: 11px; color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
    .titlebar-right a:hover { color: var(--text-primary); }

    /* ═══ ACTIVITY BAR ═══ */
    .activitybar {
      grid-row: 2 / 3;
      background: var(--bg-activitybar);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; align-items: center;
      padding-top: 4px; gap: 2px;
    }
    .activity-icon {
      width: 48px; height: 40px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; border-left: 2px solid transparent;
      color: var(--text-muted); transition: color 0.15s;
    }
    .activity-icon:hover { color: var(--text-primary); }
    .activity-icon.active { color: var(--text-primary); border-left-color: var(--text-primary); }
    .activity-icon svg { width: 22px; height: 22px; }
    .activity-spacer { flex: 1; }

    /* ═══ SIDEBAR ═══ */
    .sidebar {
      grid-row: 2 / 3;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; overflow: hidden;
      position: relative; transition: width 0.15s, border 0.15s, opacity 0.15s;
    }
    .sidebar-title {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 8px 0 20px; height: 35px;
      font-family: var(--font-sans); font-size: 11px; font-weight: 400;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-secondary);
    }
    .sidebar-actions { display: flex; gap: 2px; opacity: 0; transition: opacity 0.15s; }
    .sidebar:hover .sidebar-actions { opacity: 1; }
    .sidebar-btn {
      width: 22px; height: 22px;
      display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-secondary);
      cursor: pointer; border-radius: 3px;
    }
    .sidebar-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }
    .sidebar-section {
      display: flex; align-items: center; gap: 2px;
      padding: 0 8px; height: 22px;
      font-family: var(--font-sans); font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-primary);
      cursor: pointer; user-select: none;
      background: #252526;
    }
    .sidebar-section:hover { background: #2a2d2e; }
    .sidebar-section svg { width: 9px; height: 9px; color: var(--text-secondary); transition: transform 0.1s; }
    .sidebar-section.collapsed svg { transform: rotate(-90deg); }
    .file-tree { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 0; }
    .file-row {
      display: flex; align-items: center; gap: 6px;
      padding: 0 8px; height: 22px;
      font-size: 13px; color: var(--text-primary);
      cursor: pointer; user-select: none;
      outline: 1px solid transparent; outline-offset: -1px;
    }
    .file-row:hover { background: #2a2d2e; }
    .file-row.active { background: #04395e; color: #fff; outline-color: #007fd4; }
    .file-row.focused { background: #04395e; outline-color: #007fd4; color: #fff; }
    .file-row.dir-row { color: var(--text-primary); font-weight: 400; }
    .file-icon { display: flex; align-items: center; flex-shrink: 0; width: 16px; height: 16px; }
    .file-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; line-height: 22px; }
    .tree-chevron {
      width: 16px; height: 16px; display: flex; align-items: center; justify-content: center;
      color: var(--text-secondary); transition: transform 0.1s; flex-shrink: 0;
    }
    .tree-chevron.expanded { transform: rotate(90deg); }
    .tree-children { }
    /* Inline rename input */
    .file-row .rename-input {
      flex: 1; min-width: 0; height: 18px;
      font-family: var(--font-mono); font-size: 13px;
      background: var(--bg-input); color: var(--text-primary);
      border: 1px solid var(--accent); border-radius: 2px;
      padding: 0 4px; outline: none;
    }

    .sidebar-footer {
      padding: 8px; border-top: 1px solid var(--border);
      display: flex; flex-direction: column; gap: 6px;
    }
    .footer-actions {
      display: flex; gap: 4px;
    }
    .footer-btn {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: 4px;
      font-family: var(--font-sans); font-size: 11px;
      background: var(--bg-input); color: var(--text-secondary);
      border: 1px solid var(--border); border-radius: 3px;
      padding: 3px 6px; cursor: pointer;
    }
    .footer-btn:hover { color: var(--text-primary); border-color: var(--text-muted); }
    .template-select {
      width: 100%; font-family: var(--font-sans); font-size: 11px;
      background: var(--bg-input); color: var(--text-primary);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 4px 8px; cursor: pointer; outline: none;
    }
    .template-select:hover, .template-select:focus { border-color: var(--accent); }
    .template-select option { background: var(--bg-input); }

    /* ═══ EDITOR GROUPS ═══ */
    .editor-groups-wrapper { flex: 1; display: flex; overflow: hidden; min-height: 100px; min-width: 0; }
    .editor-group { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
    .editor-group.active .group-tabbar { border-top: 1px solid var(--accent); }
    .group-split-handle { width: 4px; cursor: col-resize; flex-shrink: 0; position: relative; }
    .group-split-handle::after { content: ""; position: absolute; top: 0; bottom: 0; left: 1px; width: 2px; background: var(--border); }
    .group-split-handle:hover::after, .group-split-handle.dragging::after { background: var(--accent); }

    /* ═══ TAB BAR (per group) ═══ */
    .group-tabbar {
      background: var(--bg-tab-row);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: stretch; overflow-x: auto;
      flex-shrink: 0; height: 35px; border-top: 1px solid transparent;
    }
    .group-tabbar::-webkit-scrollbar { height: 0; }
    .tab {
      display: flex; align-items: center; gap: 4px;
      padding: 0 3px 0 10px; height: 35px;
      font-size: 13px;
      color: var(--text-muted); background: var(--bg-inactive-tab);
      border-right: 1px solid #1b1b1b;
      cursor: pointer; white-space: nowrap; user-select: none;
      position: relative; min-width: 0; max-width: 160px;
    }
    .tab.active {
      color: var(--text-bright); background: var(--bg-active-tab);
    }
    .tab.active::after {
      content: ""; position: absolute; top: 0; left: 0; right: 0;
      height: 1px; background: var(--accent);
    }
    .tab.active::before {
      content: ""; position: absolute; bottom: 0; left: 0; right: 0;
      height: 1px; background: var(--bg-active-tab);
    }
    .tab:hover:not(.active) { background: #2a2a2a; }
    .tab-icon { display: flex; align-items: center; flex-shrink: 0; }
    .tab-icon svg { width: 14px; height: 14px; }
    .tab-label { font-size: 13px; overflow: hidden; text-overflow: ellipsis; }
    .tab-dot {
      width: 9px; height: 9px; min-width: 9px; border-radius: 50%;
      flex-shrink: 0; display: none;
    }
    .tab.modified .tab-dot { display: flex; background: var(--text-primary); }
    .tab.modified .tab-close { display: none; }
    .tab.modified:hover .tab-dot { display: none; }
    .tab.modified:hover .tab-close { display: flex; }
    .tab-close {
      width: 20px; height: 20px; min-width: 20px;
      display: flex; align-items: center; justify-content: center;
      border: none; background: none; color: var(--text-muted);
      cursor: pointer; border-radius: 3px;
      opacity: 0; flex-shrink: 0;
    }
    .tab:hover .tab-close, .tab.active .tab-close { opacity: 1; }
    .tab-close:hover { background: rgba(255,255,255,0.1); color: var(--text-primary); }
    .tab-actions {
      margin-left: auto; display: flex; align-items: center; gap: 8px;
      padding: 0 10px; flex-shrink: 0;
    }
    .run-btn {
      font-family: var(--font-sans); font-size: 11px; font-weight: 600;
      letter-spacing: 0.02em;
      color: #fff; background: var(--accent-dim);
      border: none; border-radius: 3px; padding: 4px 14px;
      cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: background 0.15s;
    }
    .run-btn:hover { background: var(--accent); }
    .run-btn:active { background: #6d28d9; }
    .run-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .run-btn svg { width: 10px; height: 10px; fill: #fff; }
    .tab-action-btn {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-muted); cursor: pointer; border-radius: 3px; flex-shrink: 0;
    }
    .tab-action-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }

    /* ═══ MAIN AREA ═══ */
    .main-area { display: flex; flex-direction: column; overflow: hidden; }

    /* ═══ BREADCRUMB (per group) ═══ */
    .group-breadcrumb {
      height: 22px; padding: 0 12px;
      display: flex; align-items: center;
      font-family: var(--font-sans); font-size: 11px; color: var(--text-muted);
      background: var(--bg-breadcrumb); border-bottom: 1px solid var(--border);
      gap: 4px; flex-shrink: 0;
    }
    .breadcrumb-sep { color: var(--text-muted); font-size: 10px; }
    .breadcrumb-item { color: var(--text-secondary); }
    .breadcrumb-item:last-child { color: var(--text-primary); }

    /* ═══ EDITOR + OUTPUT SPLIT ═══ */
    .editor-output-split { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
    .editor-output-split.layout-right { flex-direction: row; }
    .group-editor { flex: 1; overflow: hidden; }
    .group-editor .cm-editor { height: 100%; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; }
    .group-editor .cm-editor .cm-scroller { font-family: var(--font-mono) !important; }
    .group-editor .cm-editor.cm-focused { outline: none; }
    .group-editor .cm-gutters { background: var(--bg-editor); border-right: none; color: var(--text-muted); min-width: 48px; padding-right: 8px; }
    .group-editor .cm-lineNumbers .cm-gutterElement { font-size: 12px; padding: 0; text-align: right; min-width: 32px; }
    .group-editor .cm-activeLineGutter { color: var(--text-secondary); }
    .group-editor .cm-cursor { border-left: 2px solid var(--text-bright); }
    .group-editor .cm-selectionBackground { background: rgba(168, 85, 247, 0.25) !important; }
    .group-editor .cm-activeLine { background: rgba(255,255,255,0.02); }
    .group-editor .cm-matchingBracket { color: var(--text-bright) !important; outline: 1px solid var(--text-muted); background: rgba(255,255,255,0.06); }

    /* ═══ RESIZE HANDLE (panel split) ═══ */
    .resize-handle {
      background: transparent; flex-shrink: 0; position: relative;
      transition: background 0.15s;
      /* Default: bottom layout → horizontal handle */
      height: 4px; cursor: row-resize;
    }
    .resize-handle::after {
      content: ""; position: absolute;
      left: 0; right: 0; top: 1px; height: 2px;
      background: var(--border);
    }
    .resize-handle:hover::after, .resize-handle.dragging::after {
      background: var(--accent);
    }
    /* Right layout → vertical handle */
    .layout-right > .resize-handle {
      width: 4px; height: auto; cursor: col-resize;
    }
    .layout-right > .resize-handle::after {
      top: 0; bottom: 0; left: 1px; right: auto;
      width: 2px; height: auto;
    }

    /* ═══ OUTPUT ═══ */
    .output-panel {
      display: flex; flex-direction: column; overflow: hidden;
      /* Default: bottom layout */
      height: 35%; min-height: 80px;
    }
    .layout-right > .output-panel {
      height: auto; width: 40%; min-width: 200px; min-height: 0;
    }
    .output-panel.panel-hidden { display: none; }
    .resize-handle.panel-hidden { display: none; }
    .output-header {
      display: flex; align-items: center;
      padding: 0 12px; height: 35px;
      background: var(--bg-terminal);
      border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    .output-tabs { display: flex; gap: 0; }
    .output-tab {
      font-family: var(--font-sans); font-size: 12px;
      text-transform: uppercase; letter-spacing: 0.04em;
      color: var(--text-muted); cursor: pointer;
      padding: 8px 12px; border-bottom: 1px solid transparent;
    }
    .output-tab.active { color: var(--text-primary); border-bottom-color: var(--accent); }
    .output-scroll { flex: 1; overflow: auto; background: var(--bg-terminal); padding: 8px 16px; }
    .output-line { font-size: 13px; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
    .output-line.stdout { color: var(--text-primary); }
    .output-line.error { color: var(--red); }
    .output-line.info { color: var(--text-muted); }
    .output-line.timing { color: var(--yellow); font-size: 12px; }
    .output-cursor {
      display: inline-block; width: 7px; height: 14px;
      background: var(--text-primary); animation: blink 1s step-end infinite;
      vertical-align: text-bottom; margin-left: 2px; opacity: 0.7;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* ═══ STATUS BAR ═══ */
    .statusbar {
      grid-column: 1 / -1;
      background: var(--bg-statusbar);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 10px; font-size: 12px; color: rgba(255,255,255,0.85);
      font-family: var(--font-sans); z-index: 10;
    }
    .statusbar-left, .statusbar-right { display: flex; align-items: center; gap: 14px; }
    .status-item { display: flex; align-items: center; gap: 4px; cursor: default; }
    .status-item a { color: inherit; text-decoration: none; }
    .status-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #4ec9b0; box-shadow: 0 0 4px rgba(78, 201, 176, 0.5);
    }
    .status-dot.loading { background: var(--yellow); animation: pulse 1.2s ease-in-out infinite; }
    .status-dot.error { background: var(--red); }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* ═══ LINT / HOVER / AUTOCOMPLETE ═══ */
    .cm-diagnostic { font-family: var(--font-mono); font-size: 12px; padding: 4px 8px; }
    .cm-diagnostic-error { border-left: 3px solid var(--red); }
    .cm-diagnostic-warning { border-left: 3px solid var(--yellow); }
    .cm-lintRange-error { background: rgba(241, 76, 76, 0.1); text-decoration: wavy underline var(--red); text-underline-offset: 3px; text-decoration-thickness: 1px; }
    .cm-lintRange-warning { background: rgba(204, 167, 0, 0.08); text-decoration: wavy underline var(--yellow); text-underline-offset: 3px; text-decoration-thickness: 1px; }
    .cm-tooltip { background: #252526 !important; border: 1px solid #454545 !important; border-radius: 3px !important; box-shadow: 0 2px 8px rgba(0,0,0,0.36) !important; }
    .ach-hover-tooltip { padding: 8px 12px; font-family: var(--font-mono); font-size: 13px; line-height: 1.5; color: var(--text-primary); max-width: 520px; }
    .ach-hover-code { background: #1a1a1a; border-radius: 3px; padding: 6px 10px; margin: 4px 0; font-size: 13px; color: var(--green); }
    .ach-hover-inline { background: rgba(168, 85, 247, 0.12); border-radius: 3px; padding: 1px 4px; font-size: 12px; color: var(--accent); }
    .cm-tooltip-autocomplete { background: #252526 !important; border: 1px solid #454545 !important; border-radius: 3px !important; }
    .cm-tooltip-autocomplete ul { font-family: var(--font-mono); }
    .cm-tooltip-autocomplete ul li { padding: 2px 8px !important; font-size: 13px; }
    .cm-tooltip-autocomplete ul li[aria-selected] { background: #062f4a !important; color: #fff; }
    .cm-completionIcon { display: none; }

    /* ═══ CONTEXT MENU ═══ */
    .context-menu {
      position: fixed; background: #252526; border: 1px solid #454545;
      border-radius: 4px; padding: 4px 0; z-index: 100;
      min-width: 160px; box-shadow: 0 2px 8px rgba(0,0,0,0.36);
    }
    .context-item {
      padding: 4px 24px; font-family: var(--font-sans); font-size: 13px;
      color: var(--text-primary); cursor: pointer;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .context-item:hover { background: #04395e; }
    .context-item.danger:hover { background: rgba(241, 76, 76, 0.15); color: var(--red); }
    .context-shortcut { font-size: 11px; color: var(--text-muted); font-family: var(--font-sans); }

    /* ═══ SCROLLBARS ═══ */
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(121, 121, 121, 0.3); border-radius: 10px; border: 2px solid transparent; background-clip: padding-box; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(121, 121, 121, 0.5); border: 2px solid transparent; background-clip: padding-box; }
    ::-webkit-scrollbar-corner { background: transparent; }

    /* ═══ SIDEBAR COLLAPSE ═══ */
    .shell.sidebar-collapsed { grid-template-columns: 48px 0px 1fr; }
    .shell.sidebar-collapsed .sidebar { border-right: none; overflow: hidden; opacity: 0; pointer-events: none; }
    .shell.sidebar-collapsed .sidebar-resize { display: none; }

    /* ═══ SIDEBAR RESIZE HANDLE ═══ */
    .sidebar-resize {
      position: absolute; right: -2px; top: 0; bottom: 0; width: 5px;
      cursor: col-resize; z-index: 5;
    }
    .sidebar-resize::after {
      content: ""; position: absolute; top: 0; bottom: 0; left: 2px;
      width: 1px; background: transparent; transition: background 0.15s;
    }
    .sidebar-resize:hover::after, .sidebar-resize.dragging::after {
      background: var(--accent);
    }

    /* ═══ WELCOME SCREEN ═══ */
    .group-welcome {
      flex: 1; display: flex; align-items: center; justify-content: center;
      background: var(--bg-editor); color: var(--text-secondary);
      font-family: var(--font-sans); user-select: none;
    }
    .welcome-content { max-width: 360px; padding: 40px; }
    .welcome-logo { font-size: 48px; color: var(--accent); margin-bottom: 8px; line-height: 1; }
    .welcome-content h2 { font-size: 22px; font-weight: 300; color: var(--text-primary); margin-bottom: 2px; letter-spacing: -0.02em; }
    .welcome-subtitle { font-size: 12px; color: var(--text-muted); margin-bottom: 28px; }
    .welcome-section { margin-bottom: 20px; }
    .welcome-section h3 {
      font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--text-muted); margin-bottom: 6px; font-weight: 600;
    }
    .welcome-item { font-size: 13px; color: var(--accent); cursor: pointer; padding: 2px 0; }
    .welcome-item:hover { color: var(--text-primary); text-decoration: underline; }
    .welcome-shortcut {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 12px; padding: 2px 0; color: var(--text-secondary);
    }
    .welcome-shortcut kbd {
      font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);
      background: var(--bg-input); border: 1px solid var(--border);
      border-radius: 3px; padding: 1px 6px;
    }
    .welcome-link { display: block; font-size: 13px; color: var(--accent); text-decoration: none; padding: 2px 0; }
    .welcome-link:hover { color: var(--text-primary); text-decoration: underline; }

    /* ═══ PANEL ACTIONS ═══ */
    .panel-actions {
      margin-left: auto; display: flex; align-items: center; gap: 2px;
    }
    .panel-action-btn {
      width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
      background: none; border: none; color: var(--text-muted); cursor: pointer; border-radius: 3px;
    }
    .panel-action-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.08); }

    /* ═══ DOCS PANEL ═══ */
    .docs-panel {
      position: fixed; top: 30px; bottom: 22px; right: 0;
      width: 480px; background: #13131a;
      border-left: 1px solid var(--border);
      transform: translateX(100%); transition: transform 0.2s ease;
      z-index: 20; display: flex; flex-direction: column;
    }
    .docs-panel.open { transform: translateX(0); }
    .docs-panel-header {
      height: 35px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 12px; font-family: var(--font-sans); font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary);
      border-bottom: 1px solid var(--border); flex-shrink: 0; background: var(--bg-titlebar);
    }
    .docs-panel-actions { display: flex; gap: 2px; }
    .docs-panel iframe { flex: 1; border: none; width: 100%; background: #13131a; }
    .docs-panel-resize {
      position: absolute; left: -3px; top: 0; bottom: 0; width: 6px;
      cursor: col-resize; z-index: 5;
    }
    .docs-panel-resize::after {
      content: ""; position: absolute; top: 0; bottom: 0; left: 3px;
      width: 1px; background: transparent; transition: background 0.15s;
    }
    .docs-panel-resize:hover::after, .docs-panel-resize.dragging::after { background: var(--accent); }

    @media (max-width: 900px) {
      .shell { grid-template-columns: 1fr; }
      .activitybar, .sidebar { display: none; }
      .editor-output-split { flex-direction: column; }
      .output-panel { width: 100%; min-width: 0; }
      .resize-handle, .group-split-handle { display: none; }
      .editor-group:not(.active) { display: none; }
    }
  </style>
</head>

<body>
  <div class="shell">
    <!-- TITLE BAR -->
    <div class="titlebar">
      <div class="titlebar-left">
        <div class="window-dots"><span class="dot-close"></span><span class="dot-min"></span><span class="dot-max"></span></div>
      </div>
      <div class="titlebar-center"><em>Achronyme</em> &mdash; Playground</div>
      <div class="titlebar-right">
        <a href="/docs/getting-started/introduction">Docs</a>
        <a href="https://github.com/achronyme/achronyme" target="_blank">GitHub</a>
        <a href="/">Home</a>
      </div>
    </div>

    <!-- ACTIVITY BAR -->
    <div class="activitybar">
      <div class="activity-icon active" title="Explorer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7v13h18V7M3 7l4-4h6l2 2h7v2"/><path d="M8 14h8M8 11h5"/></svg>
      </div>
      <div class="activity-icon" title="Run" id="activity-run">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 3l14 9-14 9V3z"/></svg>
      </div>
      <div class="activity-icon" title="Documentation" id="activity-docs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      </div>
      <div class="activity-spacer"></div>
      <div class="activity-icon" title="Settings" style="margin-bottom: 4px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v3M12 20v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M1 12h3M20 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sidebar-title">
        <span>Explorer</span>
        <div class="sidebar-actions">
          <button class="sidebar-btn" id="new-file-btn" title="New File">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M8 3v10M3 8h10"/></svg>
          </button>
        </div>
      </div>
      <div class="sidebar-section" id="section-files">
        <svg viewBox="0 0 10 10"><path d="M3 2L7 5L3 8" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>
        <span id="project-name">Project</span>
      </div>
      <div class="file-tree" id="file-tree"></div>
      <div class="sidebar-resize" id="sidebar-resize"></div>
      <div class="sidebar-footer">
        <select class="template-select" id="template-select">
          <option value="">ach init --template</option>
          <option value="circuit">circuit</option>
          <option value="vm">vm</option>
          <option value="prove">prove</option>
        </select>
        <div class="footer-actions">
          <button class="footer-btn" id="export-btn" title="Export project as JSON">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 10v3h10v-3"/><path d="M8 2v8M5 7l3 3 3-3"/></svg>
            Export
          </button>
          <button class="footer-btn" id="import-btn" title="Import project from JSON">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M3 10v3h10v-3"/><path d="M8 10V2M5 5l3-3 3 3"/></svg>
            Import
          </button>
          <input type="file" id="import-input" accept=".json" style="display:none" />
        </div>
      </div>
    </div>

    <!-- MAIN AREA -->
    <div class="main-area">
      <div class="editor-output-split">
        <div class="editor-groups-wrapper" id="editor-groups-wrapper">
          <!-- Editor groups created dynamically -->
        </div>
        <div class="resize-handle" id="resize-handle"></div>
        <div class="output-panel" id="output-panel">
          <div class="output-header">
            <div class="output-tabs">
              <span class="output-tab active">Terminal</span>
              <span class="output-tab">Problems</span>
            </div>
            <div class="panel-actions">
              <button class="panel-action-btn" id="panel-position-btn" title="Toggle Panel Position (Bottom/Right)">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="10" y1="1" x2="10" y2="15"/></svg>
              </button>
              <button class="panel-action-btn" id="clear-btn" title="Clear Terminal">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M2 2l12 12M14 2L2 14"/></svg>
              </button>
              <button class="panel-action-btn" id="panel-close-btn" title="Close Panel (Ctrl+`)">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>
              </button>
            </div>
          </div>
          <div class="output-scroll" id="output">
            <span class="output-cursor"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- DOCS PANEL -->
    <div class="docs-panel" id="docs-panel">
      <div class="docs-panel-header">
        <span>Documentation</span>
        <div class="docs-panel-actions">
          <button class="panel-action-btn" id="docs-external-btn" title="Open in new tab">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M7 3H3v10h10V9"/><path d="M9 3h4v4M13 3L7 9"/></svg>
          </button>
          <button class="panel-action-btn" id="docs-close-btn" title="Close">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>
          </button>
        </div>
      </div>
      <div class="docs-panel-resize" id="docs-panel-resize"></div>
      <iframe id="docs-iframe" loading="lazy"></iframe>
    </div>

    <!-- STATUS BAR -->
    <div class="statusbar">
      <div class="statusbar-left">
        <span class="status-item" id="server-status">
          <span class="status-dot" id="server-dot"></span>
          <span id="server-label">Server</span>
        </span>
        <span class="status-item" id="lsp-status" style="opacity:0.5">LSP</span>
      </div>
      <div class="statusbar-right">
        <span class="status-item" id="status-line">Ln 1, Col 1</span>
        <span class="status-item">Achronyme</span>
        <span class="status-item">UTF-8</span>
      </div>
    </div>
  </div>

  <script>
    import { EditorState } from "@codemirror/state";
    import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
    import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
    import { syntaxHighlighting, defaultHighlightStyle, bracketMatching, indentOnInput } from "@codemirror/language";
    import { oneDark } from "@codemirror/theme-one-dark";
    import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";
    import { highlightSelectionMatches } from "@codemirror/search";
    import { achronymeLanguage } from "../lib/achronyme-lang.js";
    import { initLspWasm, achLinter, achAutocompletion, achHover } from "../lib/achronyme-lsp.js";
    import { renderFileTree, startInlineCreate } from "../lib/playground-filetree.js";
    import { TabManager } from "../lib/playground-tabs.js";
    import * as session from "../lib/playground-session.js";

    // ═══ DOM ═══
    const output = document.getElementById("output");
    const clearBtn = document.getElementById("clear-btn");
    const fileTree = document.getElementById("file-tree");
    const templateSelect = document.getElementById("template-select");
    const newFileBtn = document.getElementById("new-file-btn");
    const statusLine = document.getElementById("status-line");
    const serverDot = document.getElementById("server-dot");
    const serverLabel = document.getElementById("server-label");
    const resizeHandle = document.getElementById("resize-handle");
    const outputPanel = document.getElementById("output-panel");
    const groupsWrapper = document.getElementById("editor-groups-wrapper");

    // ═══ EDITOR GROUPS ═══
    let groups = [];
    let activeGroupIdx = 0;
    let groupIdCounter = 0;
    function ag() { return groups[activeGroupIdx]; }

    // ═══ LAYOUT STATE ═══
    let panelLayout = localStorage.getItem("ach-panel-layout") || "bottom";
    let panelVisible = localStorage.getItem("ach-panel-visible") !== "false";
    let sidebarCollapsed = localStorage.getItem("ach-sidebar-collapsed") === "true";
    let sidebarWidth = parseInt(localStorage.getItem("ach-sidebar-width")) || 240;

    const shell = document.querySelector(".shell");
    const sidebar = document.querySelector(".sidebar");
    const sidebarResize = document.getElementById("sidebar-resize");
    const editorOutputSplit = document.querySelector(".editor-output-split");
    const explorerIcon = document.querySelector(".activity-icon[title='Explorer']");
    const panelPositionBtn = document.getElementById("panel-position-btn");
    const panelCloseBtn = document.getElementById("panel-close-btn");

    function applyLayout() {
      shell.classList.toggle("sidebar-collapsed", sidebarCollapsed);
      explorerIcon.classList.toggle("active", !sidebarCollapsed);
      shell.style.gridTemplateColumns = sidebarCollapsed ? "" : `48px ${sidebarWidth}px 1fr`;

      editorOutputSplit.classList.toggle("layout-right", panelLayout === "right");
      outputPanel.classList.toggle("panel-hidden", !panelVisible);
      resizeHandle.classList.toggle("panel-hidden", !panelVisible);

      if (panelLayout === "right") {
        panelPositionBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="1" y1="10" x2="15" y2="10"/></svg>`;
        panelPositionBtn.title = "Move Panel to Bottom";
      } else {
        panelPositionBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="10" y1="1" x2="10" y2="15"/></svg>`;
        panelPositionBtn.title = "Move Panel to Right";
      }

      localStorage.setItem("ach-panel-layout", panelLayout);
      localStorage.setItem("ach-panel-visible", panelVisible);
      localStorage.setItem("ach-sidebar-collapsed", sidebarCollapsed);
      localStorage.setItem("ach-sidebar-width", sidebarWidth);
    }

    function toggleSidebar() { sidebarCollapsed = !sidebarCollapsed; applyLayout(); }
    function togglePanel() { panelVisible = !panelVisible; applyLayout(); if (panelVisible && ag()) ag().view.focus(); }
    function togglePanelPosition() {
      outputPanel.style.height = ""; outputPanel.style.width = "";
      panelLayout = panelLayout === "bottom" ? "right" : "bottom"; applyLayout();
    }

    explorerIcon.addEventListener("click", toggleSidebar);
    panelPositionBtn.addEventListener("click", togglePanelPosition);
    panelCloseBtn.addEventListener("click", togglePanel);

    // ═══ SIDEBAR RESIZE ═══
    let sidebarResizing = false;
    sidebarResize.addEventListener("mousedown", (e) => {
      e.preventDefault(); sidebarResizing = true;
      sidebarResize.classList.add("dragging");
      document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!sidebarResizing) return;
      sidebarWidth = Math.max(150, Math.min(500, e.clientX - 48));
      shell.style.gridTemplateColumns = `48px ${sidebarWidth}px 1fr`;
    });
    document.addEventListener("mouseup", () => {
      if (!sidebarResizing) return;
      sidebarResizing = false; sidebarResize.classList.remove("dragging");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
      localStorage.setItem("ach-sidebar-width", sidebarWidth);
    });

    // ═══ PANEL RESIZE HANDLE ═══
    let resizing = false;
    resizeHandle.addEventListener("mousedown", (e) => {
      e.preventDefault(); resizing = true;
      resizeHandle.classList.add("dragging");
      document.body.style.cursor = panelLayout === "right" ? "col-resize" : "row-resize";
      document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!resizing) return;
      const split = resizeHandle.parentElement;
      const rect = split.getBoundingClientRect();
      if (panelLayout === "right") {
        const clamped = Math.max(20, Math.min(80, ((e.clientX - rect.left) / rect.width) * 100));
        outputPanel.style.width = (100 - clamped) + "%";
      } else {
        const clamped = Math.max(20, Math.min(80, ((e.clientY - rect.top) / rect.height) * 100));
        outputPanel.style.height = (100 - clamped) + "%";
      }
    });
    document.addEventListener("mouseup", () => {
      if (!resizing) return;
      resizing = false; resizeHandle.classList.remove("dragging");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
    });

    // ═══ GROUP SPLIT RESIZE ═══
    let groupResizing = false, grHandle = null, grStartX = 0, grLeft = null, grRight = null, grStartW = [0, 0];

    function setupGroupSplitHandle(handle) {
      handle.addEventListener("mousedown", (e) => {
        e.preventDefault();
        groupResizing = true; grHandle = handle; grStartX = e.clientX;
        const children = Array.from(handle.parentElement.children);
        const idx = children.indexOf(handle);
        grLeft = children[idx - 1]; grRight = children[idx + 1];
        grStartW = [grLeft.offsetWidth, grRight.offsetWidth];
        handle.classList.add("dragging");
        document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none";
      });
    }

    document.addEventListener("mousemove", (e) => {
      if (!groupResizing) return;
      const dx = e.clientX - grStartX;
      const total = grStartW[0] + grStartW[1];
      let lw = Math.max(100, grStartW[0] + dx);
      let rw = total - lw;
      if (rw < 100) { rw = 100; lw = total - rw; }
      const lp = (lw / total) * 100;
      grLeft.style.flex = `${lp} 1 0%`;
      grRight.style.flex = `${100 - lp} 1 0%`;
      grLeft.style.width = ""; grRight.style.width = "";
    });
    document.addEventListener("mouseup", () => {
      if (!groupResizing) return;
      groupResizing = false;
      if (grHandle) grHandle.classList.remove("dragging");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
    });

    // ═══ EDITOR THEME ═══
    const editorTheme = EditorView.theme({
      "&": { backgroundColor: "var(--bg-editor)" },
      ".cm-content": { caretColor: "var(--text-bright)", fontFamily: "var(--font-mono)", padding: "4px 0" },
      ".cm-gutters": { backgroundColor: "var(--bg-editor)", borderRight: "none", color: "var(--text-muted)" },
      ".cm-activeLineGutter": { color: "var(--text-secondary)", backgroundColor: "transparent" },
      ".cm-activeLine": { backgroundColor: "rgba(255,255,255,0.02)" },
      "&.cm-focused .cm-cursor": { borderLeftColor: "var(--text-bright)", borderLeftWidth: "2px" },
      "&.cm-focused .cm-selectionBackground, .cm-selectionBackground": { backgroundColor: "rgba(168, 85, 247, 0.25) !important" },
      ".cm-foldGutter": { width: "12px" },
    }, { dark: true });

    // ═══ RUN KEYMAP ═══
    const runKeymap = keymap.of([
      { key: "Ctrl-Enter", mac: "Cmd-Enter", run: () => { runCode(); return true; } },
      { key: "Ctrl-s", mac: "Cmd-s", run: () => { saveActiveFile(); return true; } },
      { key: "Ctrl-b", mac: "Cmd-b", run: () => { toggleSidebar(); return true; } },
      { key: "Ctrl-`", mac: "Cmd-`", run: () => { togglePanel(); return true; } },
      { key: "Ctrl-j", mac: "Cmd-j", run: () => { togglePanel(); return true; } },
      { key: "Ctrl-\\", mac: "Cmd-\\", run: () => { splitRight(); return true; } },
    ]);

    // ═══ EDITOR EXTENSIONS (per group) ═══
    function editorExtensions(group) {
      const autoSave = EditorView.updateListener.of((update) => {
        if (update.docChanged && session.isProjectMode()) {
          const idx = group.tabs.getActiveIndex();
          const content = update.state.doc.toString();
          group.tabs.setModified(idx, group.tabs.isModified(idx, content));
          renderGroupTabs(group);
          clearTimeout(group.saveTimeout);
          group.saveTimeout = setTimeout(() => saveGroupFile(group), 1000);
        }
      });

      const cursorTrack = EditorView.updateListener.of((update) => {
        if ((update.selectionSet || update.docChanged) && groups[activeGroupIdx] === group) {
          const pos = update.state.selection.main.head;
          const line = update.state.doc.lineAt(pos);
          statusLine.textContent = `Ln ${line.number}, Col ${pos - line.from + 1}`;
        }
      });

      const focusTracker = EditorView.domEventHandlers({
        focus() {
          const idx = groups.indexOf(group);
          if (idx >= 0 && idx !== activeGroupIdx) setActiveGroup(idx);
        },
      });

      return [
        lineNumbers(), highlightActiveLine(), highlightActiveLineGutter(),
        history(), bracketMatching(), closeBrackets(), indentOnInput(),
        highlightSelectionMatches(), oneDark, editorTheme,
        syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
        achronymeLanguage, achLinter, achAutocompletion, achHover,
        keymap.of([indentWithTab, ...closeBracketsKeymap, ...defaultKeymap, ...historyKeymap]),
        runKeymap, cursorTrack, autoSave, focusTracker, EditorView.lineWrapping,
      ];
    }

    // ═══ GROUP MANAGEMENT ═══
    function createGroup() {
      const id = groupIdCounter++;
      const tm = new TabManager();

      const el = document.createElement("div");
      el.className = "editor-group" + (groups.length === 0 ? " active" : "");

      const tabBarEl = document.createElement("div");
      tabBarEl.className = "group-tabbar";

      const breadcrumbEl = document.createElement("div");
      breadcrumbEl.className = "group-breadcrumb";

      const welcomeEl = document.createElement("div");
      welcomeEl.className = "group-welcome";
      welcomeEl.innerHTML = `
        <div class="welcome-content">
          <div class="welcome-logo">◇</div>
          <h2>Achronyme</h2>
          <p class="welcome-subtitle">Zero-Knowledge Playground</p>
          <div class="welcome-section">
            <h3>Start</h3>
            <div class="welcome-item" data-action="explorer">Open a file from the Explorer</div>
            <div class="welcome-item" data-action="template">Select a template to begin</div>
          </div>
          <div class="welcome-section">
            <h3>Shortcuts</h3>
            <div class="welcome-shortcut"><span>Run</span><kbd>Ctrl+Enter</kbd></div>
            <div class="welcome-shortcut"><span>Save</span><kbd>Ctrl+S</kbd></div>
            <div class="welcome-shortcut"><span>Split Editor</span><kbd>Ctrl+\\</kbd></div>
            <div class="welcome-shortcut"><span>Toggle Sidebar</span><kbd>Ctrl+B</kbd></div>
            <div class="welcome-shortcut"><span>Toggle Terminal</span><kbd>Ctrl+\`</kbd></div>
          </div>
          <div class="welcome-section">
            <h3>Help</h3>
            <a href="/docs/getting-started/introduction" class="welcome-link">Documentation</a>
            <a href="https://github.com/achronyme/achronyme" target="_blank" class="welcome-link">GitHub Repository</a>
          </div>
        </div>`;
      welcomeEl.querySelector('[data-action="explorer"]').addEventListener("click", () => {
        if (sidebarCollapsed) toggleSidebar();
      });
      welcomeEl.querySelector('[data-action="template"]').addEventListener("click", () => {
        if (sidebarCollapsed) toggleSidebar();
        templateSelect.focus();
      });

      const editorEl = document.createElement("div");
      editorEl.className = "group-editor";

      el.append(tabBarEl, breadcrumbEl, welcomeEl, editorEl);

      if (groups.length > 0) {
        const handle = document.createElement("div");
        handle.className = "group-split-handle";
        setupGroupSplitHandle(handle);
        groupsWrapper.appendChild(handle);
      }
      groupsWrapper.appendChild(el);

      const group = { id, tabs: tm, view: null, el, tabBarEl, breadcrumbEl, welcomeEl, editorEl, saveTimeout: null };

      group.view = new EditorView({
        state: EditorState.create({ doc: "", extensions: editorExtensions(group) }),
        parent: editorEl,
      });

      groups.push(group);
      renderGroupTabs(group);
      return group;
    }

    function setActiveGroup(idx) {
      if (idx < 0 || idx >= groups.length) return;
      activeGroupIdx = idx;
      groups.forEach((g, i) => g.el.classList.toggle("active", i === idx));
      const tab = ag().tabs.getActiveTab();
      if (tab && ag().view) {
        const pos = ag().view.state.selection.main.head;
        const line = ag().view.state.doc.lineAt(pos);
        statusLine.textContent = `Ln ${line.number}, Col ${pos - line.from + 1}`;
      }
    }

    function removeGroup(group) {
      const idx = groups.indexOf(group);
      if (idx < 0 || groups.length <= 1) return;

      const prev = group.el.previousElementSibling;
      const next = group.el.nextElementSibling;
      if (prev && prev.classList.contains("group-split-handle")) prev.remove();
      else if (next && next.classList.contains("group-split-handle")) next.remove();

      group.view.destroy();
      group.el.remove();
      groups.splice(idx, 1);
      groups.forEach(g => { g.el.style.flex = ""; });

      if (activeGroupIdx >= groups.length) activeGroupIdx = groups.length - 1;
      setActiveGroup(activeGroupIdx);
    }

    function splitRight() {
      const src = ag();
      const srcTab = src.tabs.getActiveTab();

      const newGroup = createGroup();

      if (srcTab) {
        // Move the active file to the new panel
        src.tabs.saveEditorState(src.view.state);
        const content = src.view.state.doc.toString();
        const path = srcTab.path;
        const savedContent = srcTab.savedContent;
        const modified = srcTab.modified;

        // Remove from source
        src.tabs.closeTab(src.tabs.getActiveIndex());
        const remaining = src.tabs.getActiveTab();
        if (remaining) src.view.setState(remaining.editorState);

        // Add to new group
        newGroup.tabs.openTab(path, content, editorExtensions(newGroup));
        if (modified) {
          const ni = newGroup.tabs.getActiveIndex();
          newGroup.tabs.setModified(ni, true);
          newGroup.tabs.getTabs()[ni].savedContent = savedContent;
        }
        newGroup.view.setState(newGroup.tabs.getActiveTab().editorState);
      }

      activeGroupIdx = groups.indexOf(newGroup);
      groups.forEach((g, i) => g.el.classList.toggle("active", i === activeGroupIdx));
      renderAllGroups();
    }

    // ═══ OUTPUT ═══
    function clearOutput() { output.innerHTML = '<span class="output-cursor"></span>'; }
    function appendOutput(text, cls = "stdout") {
      const cursor = output.querySelector(".output-cursor");
      const line = document.createElement("div");
      line.className = `output-line ${cls}`;
      line.textContent = text;
      output.insertBefore(line, cursor);
      output.scrollTop = output.scrollHeight;
    }

    // ═══ TAB ICONS ═══
    function fileTabIcon(path) {
      if (path.endsWith(".toml")) {
        return `<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1.5L2 4.5v7l6 3 6-3v-7L8 1.5z" stroke="#8b8b9a" stroke-width="1.2"/><circle cx="8" cy="8" r="1.5" fill="#8b8b9a"/></svg>`;
      }
      return `<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2L13 8L8 14L3 8L8 2Z" fill="none" stroke="#a855f7" stroke-width="1.2"/></svg>`;
    }

    // ═══ TAB RENDERING (per group) ═══
    function renderGroupTabs(group) {
      const bar = group.tabBarEl;
      bar.innerHTML = "";

      for (let i = 0; i < group.tabs.getTabs().length; i++) {
        const t = group.tabs.getTabs()[i];
        const tab = document.createElement("div");
        tab.className = "tab" + (i === group.tabs.getActiveIndex() ? " active" : "") + (t.modified ? " modified" : "");

        const icon = document.createElement("span");
        icon.className = "tab-icon";
        icon.innerHTML = fileTabIcon(t.path);

        const label = document.createElement("span");
        label.className = "tab-label";
        label.textContent = t.path.split("/").pop();
        label.title = t.path;

        const dot = document.createElement("span");
        dot.className = "tab-dot";

        const close = document.createElement("button");
        close.className = "tab-close";
        close.innerHTML = `<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l8 8M12 4l-8 8"/></svg>`;
        close.addEventListener("click", (e) => { e.stopPropagation(); closeTabInGroup(group, i); });

        tab.appendChild(icon); tab.appendChild(label); tab.appendChild(dot); tab.appendChild(close);
        tab.addEventListener("click", () => { setActiveGroup(groups.indexOf(group)); switchTabInGroup(group, i); });
        tab.addEventListener("mousedown", (e) => { if (e.button === 1) { e.preventDefault(); closeTabInGroup(group, i); } });
        bar.appendChild(tab);
      }

      const actions = document.createElement("div");
      actions.className = "tab-actions";

      const splitBtn = document.createElement("button");
      splitBtn.className = "tab-action-btn";
      splitBtn.title = "Split Editor (Ctrl+\\)";
      splitBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="1" width="14" height="14" rx="1"/><line x1="8" y1="1" x2="8" y2="15"/></svg>`;
      splitBtn.addEventListener("click", () => { setActiveGroup(groups.indexOf(group)); splitRight(); });

      const runBtn = document.createElement("button");
      runBtn.className = "run-btn";
      runBtn.innerHTML = `<svg viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg> Run`;
      runBtn.addEventListener("click", runCode);

      actions.appendChild(splitBtn);
      actions.appendChild(runBtn);
      bar.appendChild(actions);

      // Toggle welcome / editor
      const hasTabs = group.tabs.getTabs().length > 0;
      group.welcomeEl.style.display = hasTabs ? "none" : "";
      group.editorEl.style.display = hasTabs ? "" : "none";
      group.breadcrumbEl.style.display = hasTabs ? "" : "none";
      updateGroupBreadcrumb(group);
    }

    function renderAllGroups() { for (const g of groups) renderGroupTabs(g); }

    function updateGroupBreadcrumb(group) {
      const tab = group.tabs.getActiveTab();
      const path = tab?.path || "";
      if (!path) { group.breadcrumbEl.innerHTML = ""; return; }
      const parts = path.split("/");
      group.breadcrumbEl.innerHTML = parts.map((p, i) =>
        (i > 0 ? '<span class="breadcrumb-sep">&rsaquo;</span>' : "") +
        `<span class="breadcrumb-item">${p}</span>`
      ).join("");
    }

    // ═══ FILE OPERATIONS ═══
    async function openFile(path) {
      // If already open in any group, switch to that group
      for (let i = 0; i < groups.length; i++) {
        const idx = groups[i].tabs.findTab(path);
        if (idx >= 0) {
          setActiveGroup(i);
          switchTabInGroup(groups[i], idx);
          return;
        }
      }
      return openFileInGroup(ag(), path);
    }

    async function openFileInGroup(group, path) {
      const existing = group.tabs.findTab(path);
      if (existing >= 0) { switchTabInGroup(group, existing); return; }
      try {
        const content = await session.readFile(path);
        group.tabs.saveEditorState(group.view.state);
        group.tabs.openTab(path, content, editorExtensions(group));
        group.view.setState(group.tabs.getActiveTab().editorState);
        renderGroupTabs(group);
        refreshFileTree();
      } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
    }

    function switchTabInGroup(group, index) {
      if (index === group.tabs.getActiveIndex()) return;
      group.tabs.saveEditorState(group.view.state);
      group.tabs.switchTab(index);
      const tab = group.tabs.getActiveTab();
      if (tab) group.view.setState(tab.editorState);
      renderGroupTabs(group);
      refreshFileTree();
    }

    function closeTabInGroup(group, index) {
      group.tabs.saveEditorState(group.view.state);
      group.tabs.closeTab(index);
      const tab = group.tabs.getActiveTab();
      if (tab) {
        group.view.setState(tab.editorState);
      } else if (groups.length > 1) {
        removeGroup(group);
        return;
      } else {
        group.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(group) }));
      }
      renderGroupTabs(group);
    }

    async function saveGroupFile(group) {
      const tab = group.tabs.getActiveTab();
      if (!tab || !session.isProjectMode()) return;
      group.tabs.saveEditorState(group.view.state);
      const content = group.view.state.doc.toString();
      try {
        await session.writeFile(tab.path, content);
        group.tabs.markSaved(group.tabs.getActiveIndex(), content);
        renderGroupTabs(group);
      } catch (e) { appendOutput(`Save error: ${e.message}`, "error"); }
    }

    async function saveActiveFile() { return saveGroupFile(ag()); }

    async function refreshFileTree() {
      if (!session.isProjectMode()) return;
      try {
        const files = await session.listFiles();
        const activeTab = ag().tabs.getActiveTab();
        renderFileTree(fileTree, files, activeTab?.path || "", {
          onFileClick: openFile,
          onFileDelete: async (path) => {
            if (!confirm(`Delete ${path}?`)) return;
            await session.deleteFile(path);
            for (const g of [...groups]) {
              g.tabs.removeTabByPath(path);
              const tab = g.tabs.getActiveTab();
              if (tab) g.view.setState(tab.editorState);
              else if (groups.length > 1) { removeGroup(g); continue; }
              else g.view.setState(EditorState.create({ doc: "", extensions: editorExtensions(g) }));
            }
            renderAllGroups(); refreshFileTree();
          },
          onFileRename: async (oldPath, newPath) => {
            if (!newPath || newPath === oldPath) return;
            try {
              await session.renameFile(oldPath, newPath);
              for (const g of groups) g.tabs.updateTabPath(oldPath, newPath);
              renderAllGroups(); refreshFileTree();
            } catch (e) { appendOutput(`Rename error: ${e.message}`, "error"); }
          },
        });
      } catch (e) { console.warn("file tree refresh:", e); }
    }

    // ═══ RUN ═══
    let running = false;
    async function runCode() {
      if (running) return;
      if (!panelVisible) { panelVisible = true; applyLayout(); }
      if (session.isProjectMode()) await saveActiveFile();
      clearOutput();
      running = true;
      document.querySelectorAll(".run-btn").forEach(b => b.disabled = true);
      serverDot.classList.add("loading"); serverLabel.textContent = "Running...";
      try {
        const source = session.isProjectMode() ? null : ag().view.state.doc.toString();
        if (!session.isProjectMode() && (!source || !source.trim())) { appendOutput("// Nothing to run", "info"); return; }
        const data = await session.runProject(source);
        if (data.output) { for (const line of data.output.split("\n")) { if (line) appendOutput(line, "stdout"); } }
        if (!data.success) { if (data.output) appendOutput("", "stdout"); appendOutput(data.error, "error"); }
        appendOutput("", "stdout");
        appendOutput(`[${data.time_ms}ms]`, "timing");
      } catch (e) {
        appendOutput(e.message, "error");
        serverDot.classList.add("error"); serverLabel.textContent = "Offline"; return;
      } finally {
        running = false;
        document.querySelectorAll(".run-btn").forEach(b => b.disabled = false);
        serverDot.classList.remove("loading"); serverLabel.textContent = "Server";
      }
    }

    // ═══ TEMPLATE ═══
    async function loadTemplate(name) {
      if (!name) return;
      try {
        clearOutput();
        appendOutput("$ ach init " + name + " --template " + name, "info");
        if (session.isProjectMode()) await session.deleteSession();
        while (groups.length > 1) removeGroup(groups[groups.length - 1]);
        ag().tabs.resetTabs();
        const data = await session.createSession(name);
        document.getElementById("project-name").textContent = name.toUpperCase();
        appendOutput(`Created project \`${name}\` with template \`${name}\``, "info");
        appendOutput("", "info");
        await refreshFileTree();
        const entry = data.files.find(f => f.path.endsWith("main.ach")) || data.files[0];
        if (entry) await openFile(entry.path);
        templateSelect.value = "";
      } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
    }

    // ═══ NEW FILE ═══
    function createNewFile() {
      if (!session.isProjectMode()) { appendOutput("Select a template first", "info"); return; }
      startInlineCreate(fileTree, {
        async onCreate(name) {
          try {
            await session.writeFile(name, `// ${name.split("/").pop()}\n`);
            await refreshFileTree();
            await openFile(name);
          } catch (e) { appendOutput(`Error: ${e.message}`, "error"); }
        },
      });
    }

    // ═══ EVENTS ═══
    clearBtn.addEventListener("click", clearOutput);
    templateSelect.addEventListener("change", (e) => loadTemplate(e.target.value));
    newFileBtn.addEventListener("click", createNewFile);
    document.getElementById("activity-run").addEventListener("click", runCode);

    document.getElementById("export-btn").addEventListener("click", async () => {
      try { await session.exportProject(); }
      catch (e) { appendOutput(`Export error: ${e.message}`, "error"); }
    });

    const importInput = document.getElementById("import-input");
    document.getElementById("import-btn").addEventListener("click", () => importInput.click());
    importInput.addEventListener("change", async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      try {
        const text = await file.text();
        while (groups.length > 1) removeGroup(groups[groups.length - 1]);
        ag().tabs.resetTabs();
        clearOutput();
        appendOutput("Importing project...", "info");
        const files = await session.importProject(text);
        appendOutput(`Imported ${files.length} files`, "info");
        await refreshFileTree();
        const entry = files.find(f => f.path.endsWith("main.ach")) || files[0];
        if (entry) await openFile(entry.path);
      } catch (err) { appendOutput(`Import error: ${err.message}`, "error"); }
      importInput.value = "";
    });

    // ═══ DOCS PANEL ═══
    const docsPanel = document.getElementById("docs-panel");
    const docsIframe = document.getElementById("docs-iframe");
    const docsIcon = document.getElementById("activity-docs");
    let docsOpen = localStorage.getItem("ach-docs-open") === "true";
    let docsWidth = parseInt(localStorage.getItem("ach-docs-width")) || 480;
    let docsUrl = localStorage.getItem("ach-docs-url") || "/docs/getting-started/introduction?embed";

    function toggleDocs() {
      docsOpen = !docsOpen;
      docsPanel.classList.toggle("open", docsOpen);
      docsIcon.classList.toggle("active", docsOpen);
      if (docsOpen && !docsIframe.src) docsIframe.src = docsUrl;
      localStorage.setItem("ach-docs-open", docsOpen);
    }

    docsIcon.addEventListener("click", toggleDocs);
    document.getElementById("docs-close-btn").addEventListener("click", () => {
      docsOpen = false;
      docsPanel.classList.remove("open");
      docsIcon.classList.remove("active");
      localStorage.setItem("ach-docs-open", "false");
    });
    document.getElementById("docs-external-btn").addEventListener("click", () => {
      try {
        const url = new URL(docsIframe.contentWindow.location.href);
        url.searchParams.delete("embed");
        window.open(url.toString(), "_blank");
      } catch { window.open(docsUrl.replace("?embed", ""), "_blank"); }
    });

    docsIframe.addEventListener("load", () => {
      try {
        const loc = docsIframe.contentWindow.location;
        docsUrl = loc.pathname + (loc.search.includes("embed") ? loc.search : "?embed");
        localStorage.setItem("ach-docs-url", docsUrl);
      } catch { /* cross-origin */ }
    });

    // Docs panel resize
    let docsResizing = false;
    const docsResize = document.getElementById("docs-panel-resize");
    docsResize.addEventListener("mousedown", (e) => {
      e.preventDefault(); docsResizing = true;
      docsResize.classList.add("dragging");
      document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!docsResizing) return;
      docsWidth = Math.max(300, Math.min(900, window.innerWidth - e.clientX));
      docsPanel.style.width = docsWidth + "px";
    });
    document.addEventListener("mouseup", () => {
      if (!docsResizing) return;
      docsResizing = false; docsResize.classList.remove("dragging");
      document.body.style.cursor = ""; document.body.style.userSelect = "";
      localStorage.setItem("ach-docs-width", docsWidth);
    });

    docsPanel.style.width = docsWidth + "px";
    if (docsOpen) {
      docsPanel.classList.add("open");
      docsIcon.classList.add("active");
      docsIframe.src = docsUrl;
    }

    // ═══ GLOBAL KEYBOARD SHORTCUTS ═══
    document.addEventListener("keydown", (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "b") { e.preventDefault(); toggleSidebar(); }
      if ((e.ctrlKey || e.metaKey) && e.key === "`") { e.preventDefault(); togglePanel(); }
      if ((e.ctrlKey || e.metaKey) && e.key === "j") { e.preventDefault(); togglePanel(); }
      if ((e.ctrlKey || e.metaKey) && e.key === "\\") { e.preventDefault(); splitRight(); }
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === "D") { e.preventDefault(); toggleDocs(); }
    });

    // ═══ INIT ═══
    createGroup();
    applyLayout();

    session.healthCheck().then(ok => {
      if (ok) { serverDot.classList.remove("loading", "error"); serverLabel.textContent = "Server"; }
    }).catch(() => { serverDot.classList.add("error"); serverLabel.textContent = "Offline"; });

    initLspWasm().then(() => {
      const el = document.getElementById("lsp-status");
      if (el) { el.textContent = "LSP"; el.style.opacity = "0.85"; }
    });

    (async () => {
      const restored = await session.restoreSession();
      if (restored) {
        appendOutput("Session restored", "info");
        await refreshFileTree();
        const files = await session.listFiles();
        const entry = files.find(f => f.path.endsWith("main.ach")) || files[0];
        if (entry) await openFile(entry.path);
      } else {
        loadTemplate("vm");
      }
    })();
  </script>
</body>
</html>
