---
// Standalone playground page — self-contained, no layout import
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Achronyme Playground — Write and run ZK programs in your browser" />
  <title>Playground — Achronyme</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-titlebar: #17171c;
      --bg-sidebar: #1c1c22;
      --bg-editor: #121217;
      --bg-terminal: #0e0e12;
      --bg-statusbar: #7c3aed;
      --bg-active-tab: #121217;
      --bg-inactive-tab: #19191e;
      --border: #2a2a32;
      --text-primary: #f5f5fa;
      --text-secondary: #b0b0c4;
      --text-muted: #606070;
      --accent: #a855f7;
      --accent-dim: #7c3aed;
      --green: #34d399;
      --green-dim: #059669;
      --red: #f87171;
      --yellow: #fbbf24;
      --font-mono: "JetBrains Mono", "Fira Code", "Consolas", ui-monospace, monospace;
      --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--bg-editor);
      color: var(--text-primary);
      font-family: var(--font-mono);
      -webkit-font-smoothing: antialiased;
    }

    ::selection {
      background: rgba(168, 85, 247, 0.3);
      color: var(--text-primary);
    }

    .shell {
      display: grid;
      grid-template-rows: 38px 36px 1fr 24px;
      height: 100vh;
      width: 100vw;
    }

    /* ═══ TITLE BAR ═══ */
    .titlebar {
      background: var(--bg-titlebar);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
    }
    .titlebar-left { display: flex; align-items: center; gap: 14px; }
    .window-dots { display: flex; gap: 8px; }
    .window-dots span { width: 12px; height: 12px; border-radius: 50%; }
    .dot-close { background: #ff5f57; }
    .dot-min { background: #ffbd2e; }
    .dot-max { background: #28c840; }
    .titlebar-title { font-family: var(--font-sans); font-size: 12px; font-weight: 600; color: var(--text-secondary); letter-spacing: 0.02em; }
    .titlebar-title em { font-style: normal; color: var(--accent); }
    .titlebar-links { display: flex; align-items: center; gap: 16px; }
    .titlebar-links a { font-size: 11px; color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
    .titlebar-links a:hover { color: var(--text-primary); }

    /* ═══ TAB BAR ═══ */
    .tabbar {
      background: var(--bg-inactive-tab);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: stretch;
    }
    .tab {
      display: flex; align-items: center; gap: 8px;
      padding: 0 16px; font-size: 12px; color: var(--text-muted);
      background: var(--bg-inactive-tab); border-right: 1px solid var(--border);
      cursor: pointer; white-space: nowrap; user-select: none;
    }
    .tab.active {
      background: var(--bg-active-tab); color: var(--text-primary);
      border-bottom: 2px solid var(--accent); margin-bottom: -1px;
    }
    .tab-icon { width: 14px; height: 14px; fill: var(--accent); flex-shrink: 0; }
    .tab-actions {
      margin-left: auto; display: flex; align-items: center; gap: 8px; padding: 0 12px;
    }
    .example-select {
      font-family: var(--font-mono); font-size: 11px;
      background: var(--bg-editor); color: var(--text-secondary);
      border: 1px solid var(--border); border-radius: 4px;
      padding: 4px 8px; cursor: pointer; outline: none;
    }
    .example-select:hover, .example-select:focus { border-color: var(--accent-dim); }
    .example-select option { background: var(--bg-editor); }
    .run-btn {
      font-family: var(--font-sans); font-size: 11px; font-weight: 600;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: #fff; background: linear-gradient(135deg, var(--green-dim), var(--green));
      border: none; border-radius: 4px; padding: 5px 16px;
      cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: all 0.2s; box-shadow: 0 0 12px rgba(52, 211, 153, 0.15);
    }
    .run-btn:hover { transform: translateY(-1px); box-shadow: 0 2px 20px rgba(52, 211, 153, 0.3); }
    .run-btn:active { transform: translateY(0); }
    .run-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
    .run-btn svg { width: 10px; height: 12px; fill: #fff; }

    /* ═══ PANELS ═══ */
    .panels {
      display: grid;
      grid-template-columns: 1fr 1fr;
      overflow: hidden;
    }
    @media (max-width: 768px) {
      .panels { grid-template-columns: 1fr; grid-template-rows: 1fr 1fr; }
    }

    /* ═══ EDITOR ═══ */
    .editor-panel {
      display: flex; flex-direction: column; overflow: hidden;
      border-right: 1px solid var(--border);
    }
    #editor-container {
      flex: 1;
      overflow: hidden;
    }
    /* CodeMirror overrides */
    #editor-container .cm-editor {
      height: 100%;
      font-family: var(--font-mono);
      font-size: 13px;
    }
    #editor-container .cm-editor .cm-scroller {
      font-family: var(--font-mono) !important;
    }
    #editor-container .cm-editor.cm-focused { outline: none; }
    #editor-container .cm-gutters {
      background: #16161b;
      border-right: 1px solid var(--border);
      color: #4a4a58;
    }
    #editor-container .cm-activeLineGutter { color: var(--text-secondary); }
    #editor-container .cm-cursor { border-left-color: var(--accent); }
    #editor-container .cm-selectionBackground { background: rgba(168, 85, 247, 0.25) !important; }

    /* ═══ OUTPUT ═══ */
    .output-panel { display: flex; flex-direction: column; overflow: hidden; }
    .output-header {
      display: flex; align-items: center; gap: 16px;
      padding: 0 16px; height: 32px;
      background: var(--bg-sidebar); border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    .output-tab {
      font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--text-muted); cursor: default; padding-bottom: 1px;
    }
    .output-tab.active { color: var(--text-primary); border-bottom: 1px solid var(--accent); }
    .output-clear {
      margin-left: auto; font-size: 10px; color: var(--text-muted);
      background: none; border: 1px solid var(--border); border-radius: 3px;
      padding: 2px 8px; cursor: pointer; font-family: var(--font-mono);
    }
    .output-clear:hover { color: var(--text-secondary); border-color: var(--text-muted); }
    .output-scroll {
      flex: 1; overflow: auto; background: var(--bg-terminal); padding: 12px 16px;
    }
    .output-line { font-size: 12px; line-height: 20px; white-space: pre-wrap; word-break: break-all; }
    .output-line.stdout { color: var(--green); }
    .output-line.error { color: var(--red); }
    .output-line.info { color: var(--text-muted); font-style: italic; }
    .output-line.timing { color: var(--yellow); }
    .output-cursor {
      display: inline-block; width: 7px; height: 14px;
      background: var(--green); animation: blink 1s step-end infinite;
      vertical-align: text-bottom; margin-left: 2px;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* ═══ STATUS BAR ═══ */
    .statusbar {
      background: var(--bg-statusbar);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 12px; font-size: 11px; color: #fff; font-family: var(--font-sans);
    }
    .statusbar-left, .statusbar-right { display: flex; align-items: center; gap: 16px; }
    .status-item { display: flex; align-items: center; gap: 5px; opacity: 0.85; }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px rgba(52, 211, 153, 0.5); }
    .status-dot.loading { background: var(--yellow); box-shadow: 0 0 6px rgba(251, 191, 36, 0.5); animation: pulse 1.2s ease-in-out infinite; }
    .status-dot.error { background: var(--red); box-shadow: 0 0 6px rgba(248, 113, 113, 0.5); }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #4a4a58; }
  </style>
</head>

<body>
  <div class="shell">
    <div class="titlebar">
      <div class="titlebar-left">
        <div class="window-dots">
          <span class="dot-close"></span>
          <span class="dot-min"></span>
          <span class="dot-max"></span>
        </div>
        <div class="titlebar-title"><em>ach</em>&ensp;playground</div>
      </div>
      <div class="titlebar-links">
        <a href="https://docs.achrony.me" target="_blank">docs</a>
        <a href="https://github.com/achronyme/achronyme" target="_blank">github</a>
        <a href="/">home</a>
      </div>
    </div>

    <div class="tabbar">
      <div class="tab active">
        <svg class="tab-icon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span id="tab-name">hello.ach</span>
      </div>
      <div class="tab-actions">
        <select class="example-select" id="examples">
          <option value="hello">Hello World</option>
          <option value="fibonacci">Fibonacci & Recursion</option>
          <option value="field">Field Arithmetic</option>
          <option value="prove">Prove Block (ZK)</option>
        </select>
        <button class="run-btn" id="run-btn">
          <svg viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg>
          Run
        </button>
      </div>
    </div>

    <div class="panels">
      <div class="editor-panel">
        <div id="editor-container"></div>
      </div>
      <div class="output-panel">
        <div class="output-header">
          <span class="output-tab active">output</span>
          <button class="output-clear" id="clear-btn">clear</button>
        </div>
        <div class="output-scroll" id="output">
          <div class="output-line info">// Press Run or Ctrl+Enter to execute</div>
          <span class="output-cursor"></span>
        </div>
      </div>
    </div>

    <div class="statusbar">
      <div class="statusbar-left">
        <span class="status-item">achronyme playground</span>
        <span class="status-item" id="status-line">Ln 1, Col 1</span>
      </div>
      <div class="statusbar-right">
        <span class="status-item">v0.1.0-beta.17</span>
        <span class="status-item" id="server-status">
          <span class="status-dot" id="server-dot"></span>
          <span id="server-label">Server</span>
        </span>
      </div>
    </div>
  </div>

  <script>
    import { EditorState } from "@codemirror/state";
    import { EditorView, keymap, lineNumbers, highlightActiveLine, highlightActiveLineGutter } from "@codemirror/view";
    import { defaultKeymap, history, historyKeymap, indentWithTab } from "@codemirror/commands";
    import { syntaxHighlighting, defaultHighlightStyle, bracketMatching, indentOnInput } from "@codemirror/language";
    import { oneDark } from "@codemirror/theme-one-dark";
    import { closeBrackets, closeBracketsKeymap } from "@codemirror/autocomplete";
    import { highlightSelectionMatches } from "@codemirror/search";
    import { achronymeLanguage } from "../lib/achronyme-lang.js";

    // ═══════════════════════════════════════════════════════════════
    // EXAMPLES (from actual Achronyme test files)
    // ═══════════════════════════════════════════════════════════════
    const EXAMPLES = {
      hello: {
        name: "hello.ach",
        code: `// Hello World — Achronyme basics

let name = "Achronyme"
print("Hello from " + name + "!")

// Arithmetic
let x = 6
let y = 7
let product = x * y
print("The answer is: " + product.to_string())

// Arrays
let primes = [2, 3, 5, 7, 11]
mut sum = 0
for p in primes {
    sum = sum + p
}
print("Sum of first 5 primes: " + sum.to_string())

// Maps
let user = { name: "alice", age: 30 }
print("User: " + user.name + ", age " + user.age.to_string())
`
      },
      fibonacci: {
        name: "fibonacci.ach",
        code: `// Recursion: fibonacci, factorial, GCD

fn fib(n) {
    if n < 2 { return n }
    return fib(n - 1) + fib(n - 2)
}

print("Fibonacci sequence:")
for i in 0..10 {
    print("  fib(" + i.to_string() + ") = " + fib(i).to_string())
}

// Factorial
fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}
print("")
print("factorial(10) = " + factorial(10).to_string())

// GCD (Euclidean algorithm)
fn gcd(a, b) {
    if b == 0 { return a }
    return gcd(b, a % b)
}
print("gcd(12, 8) = " + gcd(12, 8).to_string())
print("gcd(100, 75) = " + gcd(100, 75).to_string())

// Recursive power
fn power(base, exp) {
    if exp == 0 { return 1 }
    return base * power(base, exp - 1)
}
print("2^10 = " + power(2, 10).to_string())
`
      },
      field: {
        name: "field_math.ach",
        code: `// BN254 Field Arithmetic
// All values are elements of the BN254 scalar field

let a = 0p42
let b = 0pxFF

print("a = " + a.to_string())
print("b = " + b.to_string())

// Arithmetic in the field
print("a + b = " + (a + b).to_string())
print("a * b = " + (a * b).to_string())
print("a / b = " + (a / b).to_string())

// Negation: -a + a = 0
let neg = -0p5
print("-5 + 5 = " + (neg + 0p5).to_string())

// Distributive: (a + b) * c == a*c + b*c
let c = 0p7
let lhs = (a + b) * c
let rhs = a * c + b * c
let eq = lhs == rhs
if eq { print("Distributive: PASS") } else { print("Distributive: FAIL") }

// Poseidon hash (ZK-friendly hash)
let h = poseidon(a, b)
print("")
print("poseidon(a, b) = " + h.to_string())

// Hash chain
let h2 = poseidon(h, a)
let h3 = poseidon(h2, b)
print("hash chain[3] = " + h3.to_string())

print("")
print("Field::ONE  = " + Field::ONE.to_string())
print("Field::ZERO = " + Field::ZERO.to_string())
print("Int::MAX    = " + Int::MAX.to_string())
`
      },
      prove: {
        name: "prove_demo.ach",
        code: `// Zero-Knowledge Prove Block
//
// Generates a real Groth16 proof server-side.
// The prover runs natively on the server —
// no WASM limitations.

let secret = 0p42
let public_hash = poseidon(secret, 0p0)

print("Secret:      " + secret.to_string())
print("Public hash: " + public_hash.to_string())
print("")

// This generates a real ZK proof:
// - Compiles to R1CS constraints
// - Runs Groth16 trusted setup
// - Generates proof + verification key
prove demo(public_hash: Public) {
    assert_eq(
        poseidon(secret, 0p0),
        public_hash,
        "hash mismatch"
    )
}

print("Proof generated and verified!")
`
      }
    };

    // ═══════════════════════════════════════════════════════════════
    // DOM
    // ═══════════════════════════════════════════════════════════════
    const output = document.getElementById("output");
    const runBtn = document.getElementById("run-btn");
    const clearBtn = document.getElementById("clear-btn");
    const exampleSelect = document.getElementById("examples");
    const tabName = document.getElementById("tab-name");
    const statusLine = document.getElementById("status-line");
    const serverDot = document.getElementById("server-dot");
    const serverLabel = document.getElementById("server-label");

    // API base: dev server on :3100, production on same origin
    const IS_DEV = window.location.port === "4321";
    const API_BASE = IS_DEV ? "http://localhost:3100" : "";

    // ═══════════════════════════════════════════════════════════════
    // CODEMIRROR EDITOR
    // ═══════════════════════════════════════════════════════════════
    const runKeymap = keymap.of([{
      key: "Ctrl-Enter",
      mac: "Cmd-Enter",
      run: () => { runCode(); return true; },
    }]);

    const cursorTracker = EditorView.updateListener.of((update) => {
      if (update.selectionSet || update.docChanged) {
        const pos = update.state.selection.main.head;
        const line = update.state.doc.lineAt(pos);
        const ln = line.number;
        const col = pos - line.from + 1;
        statusLine.textContent = `Ln ${ln}, Col ${col}`;
      }
    });

    const editorTheme = EditorView.theme({
      "&": { backgroundColor: "var(--bg-editor)" },
      ".cm-content": { caretColor: "var(--accent)", fontFamily: "var(--font-mono)" },
      ".cm-gutters": { backgroundColor: "#16161b", borderRight: "1px solid var(--border)", color: "#4a4a58" },
      ".cm-activeLineGutter": { color: "var(--text-secondary)", backgroundColor: "transparent" },
      ".cm-activeLine": { backgroundColor: "rgba(168, 85, 247, 0.04)" },
      "&.cm-focused .cm-cursor": { borderLeftColor: "var(--accent)" },
      "&.cm-focused .cm-selectionBackground, .cm-selectionBackground": { backgroundColor: "rgba(168, 85, 247, 0.25) !important" },
    }, { dark: true });

    const view = new EditorView({
      state: EditorState.create({
        doc: EXAMPLES.hello.code,
        extensions: [
          lineNumbers(),
          highlightActiveLine(),
          highlightActiveLineGutter(),
          history(),
          bracketMatching(),
          closeBrackets(),
          indentOnInput(),
          highlightSelectionMatches(),
          oneDark,
          editorTheme,
          syntaxHighlighting(defaultHighlightStyle, { fallback: true }),
          achronymeLanguage,
          keymap.of([
            indentWithTab,
            ...closeBracketsKeymap,
            ...defaultKeymap,
            ...historyKeymap,
          ]),
          runKeymap,
          cursorTracker,
          EditorView.lineWrapping,
        ],
      }),
      parent: document.getElementById("editor-container"),
    });

    // ═══════════════════════════════════════════════════════════════
    // OUTPUT
    // ═══════════════════════════════════════════════════════════════
    function clearOutput() {
      output.innerHTML = '<span class="output-cursor"></span>';
    }

    function appendOutput(text, cls = "stdout") {
      const cursor = output.querySelector(".output-cursor");
      const line = document.createElement("div");
      line.className = `output-line ${cls}`;
      line.textContent = text;
      output.insertBefore(line, cursor);
      output.scrollTop = output.scrollHeight;
    }

    // ═══════════════════════════════════════════════════════════════
    // RUN
    // ═══════════════════════════════════════════════════════════════
    let running = false;

    async function runCode() {
      if (running) return;

      clearOutput();
      const source = view.state.doc.toString();
      if (!source.trim()) {
        appendOutput("// Nothing to run", "info");
        return;
      }

      running = true;
      runBtn.disabled = true;
      serverDot.classList.add("loading");
      serverLabel.textContent = "Running...";

      try {
        const res = await fetch(`${API_BASE}/api/run`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ source }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
          appendOutput(err.error || `Server error (${res.status})`, "error");
          return;
        }

        const data = await res.json();

        if (data.output) {
          for (const line of data.output.split("\n")) {
            if (line) appendOutput(line, "stdout");
          }
        }

        if (!data.success) {
          if (data.output) appendOutput("", "stdout");
          appendOutput(data.error, "error");
        }

        appendOutput("", "stdout");
        appendOutput(`[${data.time_ms}ms server]`, "timing");
      } catch (e) {
        appendOutput("Server unavailable — is ach-server running?", "error");
        serverDot.classList.add("error");
        serverLabel.textContent = "Offline";
        return;
      } finally {
        running = false;
        runBtn.disabled = false;
        serverDot.classList.remove("loading");
        serverLabel.textContent = "Server";
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // EXAMPLES
    // ═══════════════════════════════════════════════════════════════
    function loadExample(key) {
      const ex = EXAMPLES[key];
      if (!ex) return;
      view.dispatch({
        changes: { from: 0, to: view.state.doc.length, insert: ex.code },
      });
      tabName.textContent = ex.name;
    }

    // ═══════════════════════════════════════════════════════════════
    // EVENTS
    // ═══════════════════════════════════════════════════════════════
    runBtn.addEventListener("click", runCode);
    clearBtn.addEventListener("click", clearOutput);
    exampleSelect.addEventListener("change", (e) => loadExample(e.target.value));

    // Health check — verify server is reachable
    fetch(`${API_BASE}/health`).then(r => {
      if (r.ok) {
        serverDot.classList.remove("loading", "error");
        serverLabel.textContent = "Server";
      }
    }).catch(() => {
      serverDot.classList.add("error");
      serverLabel.textContent = "Offline";
    });
  </script>
</body>
</html>
