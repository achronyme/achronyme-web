# Production environment for ach-server, read by the systemd unit via
# `EnvironmentFile=/etc/ach-server.env`. Copy this file to
# `/etc/ach-server.env` on vps1 and edit before enabling the service.
# DO NOT use the dev `.env.example` at the repo root — its CORS origin
# is `http://localhost:4321`, which 403s every real request.

# Loopback only; nginx terminates TLS and forwards to 127.0.0.1.
ACH_BIND=127.0.0.1
ACH_PORT=3100

# Exact origin allowed by CORS. No wildcards. Must match the public
# domain serving the playground UI.
ACH_CORS_ORIGIN=https://achrony.me

# tracing-subscriber filter. `info` is appropriate for production;
# bump to `debug` only while triaging.
RUST_LOG=ach_server=info

# Absolute path to the read-only circomlib mount served as
# `@circomlib` in user workspaces' `[circom] libs`. The deploy
# checkout pulls the vendored bundle via `git submodule update`, so
# this points at the in-checkout path. Canonicalized once at server
# startup; restart the unit if you swap mounts.
ACH_CIRCOMLIB_PATH=/opt/achronyme-web/vendor/circomlib/circuits
